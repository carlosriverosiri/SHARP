---
---

<div id="ac-rtw-root" class="not-prose mt-8 overflow-hidden">
  <div class="flex flex-wrap items-center gap-2 mb-3">
    <span
      class="bg-indigo-100 text-indigo-800 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide"
    >
      Clinical decision support
    </span>
  </div>
  <p class="text-slate-600 text-sm leading-relaxed mb-5">
    Compare <strong>illustrative sick-leave ranges (weeks)</strong> by injury pattern, workload, and typical treatment
    path. Not a substitute for workplace or insurance rules.
  </p>

  <div class="bg-slate-50 rounded-2xl border border-slate-200 p-5 sm:p-7">
    <h3 class="text-xl font-bold text-slate-900 mb-6 tracking-tight">Estimated Sick Leave Period</h3>

    <!-- Type of injury -->
    <fieldset class="border-0 p-0 m-0 mb-6">
      <legend class="sr-only">Type of injury</legend>
      <p id="ac-rtw-lbl-injury" class="text-sm font-semibold text-slate-800 mb-2">Type of injury:</p>
      <div
        class="flex flex-wrap gap-2 sm:flex-nowrap"
        role="radiogroup"
        aria-labelledby="ac-rtw-lbl-injury"
      >
        <label
          class="ac-rtw-seg flex-1 min-w-[5.5rem] cursor-pointer text-center sm:min-w-0"
        >
          <input type="radio" name="ac-rtw-rockwood" value="I-II" class="peer sr-only" />
          <span
            class="block rounded-xl border-2 border-slate-200 bg-white px-3 py-2.5 text-sm font-semibold text-slate-800 transition-all peer-checked:border-indigo-600 peer-checked:bg-indigo-50 peer-checked:text-indigo-950 peer-focus-visible:ring-2 peer-focus-visible:ring-indigo-500 peer-focus-visible:ring-offset-2"
          >
            Type I–II
          </span>
        </label>
        <label class="ac-rtw-seg flex-1 min-w-[5.5rem] cursor-pointer text-center sm:min-w-0">
          <input type="radio" name="ac-rtw-rockwood" value="III" class="peer sr-only" checked />
          <span
            class="block rounded-xl border-2 border-slate-200 bg-white px-3 py-2.5 text-sm font-semibold text-slate-800 transition-all peer-checked:border-indigo-600 peer-checked:bg-indigo-50 peer-checked:text-indigo-950 peer-focus-visible:ring-2 peer-focus-visible:ring-indigo-500 peer-focus-visible:ring-offset-2"
          >
            Type III
          </span>
        </label>
        <label class="ac-rtw-seg flex-1 min-w-[5.5rem] cursor-pointer text-center sm:min-w-0">
          <input type="radio" name="ac-rtw-rockwood" value="IV-VI" class="peer sr-only" />
          <span
            class="block rounded-xl border-2 border-slate-200 bg-white px-3 py-2.5 text-sm font-semibold text-slate-800 transition-all peer-checked:border-indigo-600 peer-checked:bg-indigo-50 peer-checked:text-indigo-950 peer-focus-visible:ring-2 peer-focus-visible:ring-indigo-500 peer-focus-visible:ring-offset-2"
          >
            Type IV–VI
          </span>
        </label>
      </div>
    </fieldset>

    <!-- Work load -->
    <fieldset class="border-0 p-0 m-0 mb-8">
      <legend class="sr-only">Work load</legend>
      <p id="ac-rtw-lbl-work" class="text-sm font-semibold text-slate-800 mb-2">Work load:</p>
      <div
        class="flex flex-wrap gap-2 sm:flex-nowrap"
        role="radiogroup"
        aria-labelledby="ac-rtw-lbl-work"
      >
        <label class="ac-rtw-seg flex-1 min-w-[5.5rem] cursor-pointer text-center sm:min-w-0">
          <input type="radio" name="ac-rtw-workclass" value="klass1" class="peer sr-only" />
          <span
            class="block rounded-xl border-2 border-slate-200 bg-white px-3 py-2.5 text-sm font-semibold text-slate-800 transition-all peer-checked:border-indigo-600 peer-checked:bg-indigo-50 peer-checked:text-indigo-950 peer-focus-visible:ring-2 peer-focus-visible:ring-indigo-500 peer-focus-visible:ring-offset-2"
          >
            Light
          </span>
        </label>
        <label class="ac-rtw-seg flex-1 min-w-[5.5rem] cursor-pointer text-center sm:min-w-0">
          <input type="radio" name="ac-rtw-workclass" value="klass2" class="peer sr-only" />
          <span
            class="block rounded-xl border-2 border-slate-200 bg-white px-3 py-2.5 text-sm font-semibold text-slate-800 transition-all peer-checked:border-indigo-600 peer-checked:bg-indigo-50 peer-checked:text-indigo-950 peer-focus-visible:ring-2 peer-focus-visible:ring-indigo-500 peer-focus-visible:ring-offset-2"
          >
            Moderate
          </span>
        </label>
        <label class="ac-rtw-seg flex-1 min-w-[5.5rem] cursor-pointer text-center sm:min-w-0">
          <input type="radio" name="ac-rtw-workclass" value="klass3" class="peer sr-only" checked />
          <span
            class="block rounded-xl border-2 border-slate-200 bg-white px-3 py-2.5 text-sm font-semibold text-slate-800 transition-all peer-checked:border-indigo-600 peer-checked:bg-indigo-50 peer-checked:text-indigo-950 peer-focus-visible:ring-2 peer-focus-visible:ring-indigo-500 peer-focus-visible:ring-offset-2"
          >
            Heavy
          </span>
        </label>
      </div>
    </fieldset>

    <div class="relative w-full h-[240px] sm:h-[260px] mb-6">
      <canvas id="ac-rtw-chart" aria-label="Horizontal bar chart of estimated sick leave in weeks"></canvas>
    </div>

    <div>
      <h4 class="text-xs uppercase tracking-wider font-bold text-slate-500 mb-3">Clinical notes for this profile</h4>
      <div
        id="ac-rtw-advice"
        class="bg-white rounded-xl p-4 border border-slate-200 text-slate-700 text-sm leading-relaxed space-y-3"
      >
      </div>
    </div>

    <p class="text-xs text-slate-500 mt-4 leading-relaxed">
      Timelines mirror published RTW cohorts and reviews; local protocols, union agreements, and symptom trajectories
      vary. Use with the references and discussion sections on this page.
    </p>
  </div>
</div>

<script>
  import Chart from 'chart.js/auto';

  type RockwoodKey = 'I-II' | 'III' | 'IV-VI';
  type WorkKey = 'klass1' | 'klass2' | 'klass3';

  type WeekRange = [number, number];

  interface GradeBlock {
    treatments: string[];
    rtw: Record<WorkKey, WeekRange[]>;
    getAdvice: (work: WorkKey) => string;
  }

  const clinicalData: Record<RockwoodKey, GradeBlock> = {
    'I-II': {
      treatments: ['Non-operative care'],
      rtw: {
        klass1: [[1, 2]],
        klass2: [[2, 4]],
        klass3: [[4, 8]],
      },
      getAdvice: (workclass) => {
        let advice =
          '<p><strong>Types I–II:</strong> Non-operative care is standard. Mobilise early within comfort and progress loading.</p>';
        if (workclass === 'klass3') {
          advice +=
            '<p class="mt-2 rounded-r-lg border-l-4 border-amber-400 bg-amber-50/80 p-3 text-slate-800"><strong class="text-amber-900">Heavy work:</strong> Even lower-grade sprains may need up to roughly two months before demanding overhead tasks feel acceptable, partly because pain inhibition and strength lag behind everyday function.</p>';
        }
        return advice;
      },
    },
    III: {
      treatments: ['Non-operative care', 'Hook plate fixation', 'Suspensory fixation'],
      rtw: {
        klass1: [
          [1, 3],
          [2, 4],
          [2, 3],
        ],
        klass2: [
          [4, 6],
          [12, 14],
          [8, 12],
        ],
        klass3: [
          [8, 12],
          [16, 24],
          [16, 24],
        ],
      },
      getAdvice: (workclass) => {
        let advice =
          '<p><strong>Type III:</strong> Both non-operative and operative pathways are valid. Trials and reviews often show similar long-term function between strategies, with higher complication rates when surgery is chosen.</p>';
        if (workclass === 'klass3') {
          advice +=
            '<div class="mt-3 rounded-r-lg border-l-4 border-indigo-500 bg-indigo-50 p-3 text-slate-800"><strong class="text-indigo-950">Type III and heavy labour:</strong> Historically, manual workers were steered quickly to surgery. Current evidence more often supports a structured non-operative trial first: aggregate data frequently show <em>earlier return to work</em> without worse long-term scores. If a hook plate is used, overhead rehabilitation and heavy loading are often delayed until hardware issues are addressed.</div>';
        }
        return advice;
      },
    },
    'IV-VI': {
      treatments: ['Hook plate fixation', 'Suspensory fixation'],
      rtw: {
        klass1: [
          [2, 4],
          [2, 3],
        ],
        klass2: [
          [12, 14],
          [8, 12],
        ],
        klass3: [
          [16, 24],
          [16, 24],
        ],
      },
      getAdvice: (workclass) => {
        let advice =
          '<p><strong>Types IV–VI:</strong> Surgery is generally indicated because of major displacement and soft-tissue disruption.</p>';
        if (workclass === 'klass2' || workclass === 'klass3') {
          advice +=
            '<p class="mt-2 rounded-r-lg border-l-4 border-amber-400 bg-amber-50/80 p-3 text-slate-800"><strong class="text-amber-900">Implant choice and RTW:</strong> Months of biologic healing are expected for moderate and heavy demands. Hook plates often postpone confident overhead loading until plate removal (commonly around 8–12 weeks) because of subacromial irritation risk.</p>';
        }
        return advice;
      },
    },
  };

  let patientChart: Chart<'bar', WeekRange[], string> | null = null;

  function initChart(canvas: HTMLCanvasElement): void {
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    patientChart = new Chart(ctx, {
      type: 'bar',
      data: { labels: [], datasets: [] },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        indexAxis: 'y',
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: (context) => {
                const raw = context.raw as WeekRange;
                if (Array.isArray(raw) && raw.length === 2) {
                  return ` Estimated sick leave: ${raw[0]}–${raw[1]} weeks`;
                }
                return '';
              },
            },
            backgroundColor: 'rgba(15, 23, 42, 0.95)',
            padding: 12,
          },
        },
        scales: {
          x: {
            beginAtZero: true,
            title: { display: true, text: 'Weeks', font: { weight: 'bold' } },
            max: 26,
            ticks: { stepSize: 4 },
            grid: { color: '#e2e8f0' },
          },
          y: {
            grid: { display: false },
            ticks: { font: { size: 12, weight: 'normal' }, color: '#1e293b' },
          },
        },
        animation: { duration: 400 },
      },
    });
  }

  function updateDashboard(): void {
    const root = document.getElementById('ac-rtw-root');
    if (!root) return;

    const rockInput = root.querySelector<HTMLInputElement>('input[name="ac-rtw-rockwood"]:checked');
    const workInput = root.querySelector<HTMLInputElement>('input[name="ac-rtw-workclass"]:checked');
    if (!rockInput || !workInput) return;

    const selectedRockwood = rockInput.value as RockwoodKey;
    const selectedWorkClass = workInput.value as WorkKey;

    const profileData = clinicalData[selectedRockwood];
    const rtwValues = profileData.rtw[selectedWorkClass];

    const adviceEl = document.getElementById('ac-rtw-advice');
    if (adviceEl) {
      adviceEl.innerHTML = profileData.getAdvice(selectedWorkClass);
    }

    const canvas = document.getElementById('ac-rtw-chart') as HTMLCanvasElement | null;
    if (!canvas) return;
    if (!patientChart) {
      initChart(canvas);
    }
    if (!patientChart) return;

    patientChart.data.labels = profileData.treatments;
    patientChart.data.datasets = [
      {
        label: 'Sick leave (weeks, range)',
        data: rtwValues,
        backgroundColor: 'rgba(99, 102, 241, 0.82)',
        borderColor: 'rgb(79, 70, 229)',
        borderWidth: 1,
        borderRadius: 4,
        barPercentage: 0.62,
      },
    ];
    patientChart.update();
  }

  function init(): void {
    const root = document.getElementById('ac-rtw-root');
    if (!root) return;
    root.querySelectorAll('input[name="ac-rtw-rockwood"], input[name="ac-rtw-workclass"]').forEach((el) => {
      el.addEventListener('change', updateDashboard);
    });
    updateDashboard();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
