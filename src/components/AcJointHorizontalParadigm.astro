---
/**
 * Tabbed deep-dive: horizontal instability paradigm (Rockwood III–IV, ISAKOS IIIA/IIIB).
 * Client Chart.js; IDs prefixed ac-hp-.
 */
import RefLink from './RefLink.astro';

const refs: { id: string; text: string; url: string }[] = [
  {
    id: '1',
    text: 'Feichtinger X, Dahm F, Schallmayer D, et al. Surgery improves the clinical and radiological outcome in Rockwood type IV dislocations, whereas Rockwood type III dislocations benefit from conservative treatment. Knee Surg Sports Traumatol Arthrosc. 2021;29(7):2143-2151.',
    url: 'https://doi.org/10.1007/s00167-020-06193-0',
  },
  {
    id: '2',
    text: 'Beitzel K, Mazzocca AD, Bak K, et al. ISAKOS upper extremity committee consensus statement on the classification of acromioclavicular joint injuries. Arthroscopy. 2014;30(3):271-278.',
    url: 'https://doi.org/10.1016/j.arthro.2013.11.078',
  },
  {
    id: '3',
    text: 'Ruiz Ibán MA, Moreno Romero MS, Diaz Heredia J, et al. The prevalence of intraarticular associated lesions after acute acromioclavicular joint injuries is 20%. A systematic review and meta-analysis. Knee Surg Sports Traumatol Arthrosc. 2021;29(7):2024-2038.',
    url: 'https://doi.org/10.1007/s00167-020-05917-6',
  },
  {
    id: '4',
    text: 'Aliberti GM, Kraeutler MJ, Trojan JD, Mulcahey MK. Horizontal Instability of the Acromioclavicular Joint: A Systematic Review. Am J Sports Med. 2020;48(2):504-510.',
    url: 'https://doi.org/10.1177/0363546519831013',
  },
  {
    id: '5',
    text: 'Xu J, Liu H, Lu W, et al. A retrospective comparative study of arthroscopic fixation in acute Rockwood type IV acromioclavicular joint dislocation: single versus double paired Endobutton technique. BMC Musculoskelet Disord. 2018;19:170.',
    url: 'https://doi.org/10.1186/s12891-018-2104-9',
  },
  {
    id: '6',
    text: 'Bianco Prevot L, Accetta R, Fozzato S, et al. Surgical vs conservative: what is the best treatment of acute Rockwood III acromioclavicular joint dislocation? A systematic review and meta-analysis. EFORT Open Rev. 2025;10(3):141-150.',
    url: 'https://doi.org/10.1530/EOR-2024-0077',
  },
  {
    id: '7',
    text: 'Tauber M, Hoffelner T, Lehmann L, et al. Prospective Multicenter Randomized Controlled Trial of Surgical Versus Nonsurgical Treatment for Acute Rockwood Type 3 Acromioclavicular Injury. Orthop J Sports Med. 2023;11(8).',
    url: 'https://doi.org/10.1177/23259671231190411',
  },
  {
    id: '8',
    text: 'Velasquez Garcia A, Abdo G. Reliability of the ISAKOS Modification to Subclassify Rockwood Type III Acromioclavicular Joint Injuries. Orthop J Sports Med. 2022;10(12).',
    url: 'https://doi.org/10.1177/23259671221133379',
  },
  {
    id: '9',
    text: 'Haugaard KB, Bak K, Ryberg D, et al. The ISAKOS subclassification of Rockwood type III AC joint dislocations in a stable type A and an unstable type B is not clinically relevant. Knee Surg Sports Traumatol Arthrosc. 2024;32(7):1821-1829.',
    url: 'https://doi.org/10.1002/ksa.12253',
  },
  {
    id: '10',
    text: 'Haugaard KB, Holm CE, Bjørnholdt K, et al. Ninety-one percent of patients with an acute acromioclavicular dislocation Rockwood type III or V treated nonoperatively will normalize within 1 year. Knee Surg Sports Traumatol Arthrosc. 2024;32(7):1810-1820.',
    url: 'https://doi.org/10.1002/ksa.12070',
  },
  {
    id: '11',
    text: 'Karargyris O, Murphy RJ, Arenas A, et al. Improved identification of unstable acromioclavicular joint injuries in a clinical population using the acromial center line to dorsal clavicle radiographic measurement. J Shoulder Elbow Surg. 2020;29(8):1599-1605.',
    url: 'https://doi.org/10.1016/j.jse.2019.12.014',
  },
  {
    id: '12',
    text: 'Rosso C, Martetschläger F, Saccomanno MF, et al. High degree of consensus achieved regarding diagnosis and treatment of acromioclavicular joint instability among ESA-ESSKA members. Knee Surg Sports Traumatol Arthrosc. 2021;29(7):2325-2332.',
    url: 'https://doi.org/10.1007/s00167-020-06286-w',
  },
  {
    id: '13',
    text: 'Berthold DP, Muench LN, Dyrna F, et al. Current concepts in acromioclavicular joint (AC) instability – a proposed treatment algorithm for acute and chronic AC-joint surgery. BMC Musculoskelet Disord. 2022;23:1078.',
    url: 'https://doi.org/10.1186/s12891-022-05935-0',
  },
];

const r = (n: number) => refs[n - 1]!;
---

<div id="ac-hp-root" class="not-prose">
  <nav
    class="sticky top-0 z-40 bg-white border-b-2 border-slate-200 shadow-sm -mx-4 px-4 sm:mx-0 sm:px-0"
    aria-label="Horizontal instability sections"
  >
    <div
      class="flex gap-0.5 overflow-x-auto pb-0 scrollbar-none max-w-full"
      style="scrollbar-width: none;"
      role="tablist"
      aria-label="Topic tabs"
    >
      {
        [
          { id: 'overview', n: '1', label: 'Concept' },
          { id: 'type4', n: '2', label: 'Rockwood IV' },
          { id: 'technique', n: '3', label: 'Surgical technique' },
          { id: 'type3', n: '4', label: 'Rockwood III' },
          { id: 'iiia', n: '5', label: 'IIIA vs IIIB' },
        ].map((t) => (
          <button
            type="button"
            role="tab"
            class="ac-hp-tab font-semibold text-sm whitespace-nowrap px-4 py-3 border-b-[3px] border-transparent text-slate-500 hover:text-slate-700 data-[active=true]:text-emerald-800 data-[active=true]:border-emerald-700 data-[active=true]:font-bold transition-colors"
            id={`ac-hp-tab-${t.id}`}
            aria-selected={t.id === 'overview' ? 'true' : 'false'}
            aria-controls={`ac-hp-panel-${t.id}`}
            data-tab={t.id}
            data-active={t.id === 'overview' ? 'true' : 'false'}
          >
            <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-slate-100 text-slate-600 text-xs font-bold mr-2 data-[active=true]:bg-emerald-700 data-[active=true]:text-white ac-hp-tab-num">
              {t.n}
            </span>
            {t.label}
          </button>
        ))
      }
    </div>
  </nav>

  <div class="mt-8 space-y-0">
    <!-- Panel 1 -->
    <section
      id="ac-hp-panel-overview"
      role="tabpanel"
      aria-labelledby="ac-hp-tab-overview"
      class="ac-hp-panel block ac-hp-panel-in"
    >
      <div class="rounded-xl bg-slate-900 text-slate-200 p-6 md:p-8 mb-8 border border-slate-800">
        <h2 class="text-xl md:text-2xl font-bold text-white mb-4 tracking-tight">
          The paradigm shift: type IV as reference frame
        </h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="space-y-3 text-sm md:text-base leading-relaxed text-slate-300">
            <p>
              While much of the literature still frames decisions around operative versus conservative <strong class="text-white">type III</strong>{' '}
              injuries, a biomechanical lens suggests that{' '}
              <strong class="text-emerald-300">type IV is a key reference pattern</strong> for how much{' '}
              <strong class="text-white">horizontal instability</strong> matters
              <RefLink id={r(1).id} text="Feichtinger et al., KSSTA 2021" url={r(1).url} />
              <RefLink id={r(4).id} text="Horizontal instability review" url={r(4).url} />.
            </p>
            <p>
              Type IV implies posterior displacement of the distal clavicle through the trapezius fascia — a pattern with
              marked AP translation that differs from a “vertical-dominant” type III presentation. The question in practice
              is how much horizontal instability is present across the spectrum, not the Rockwood label alone.
            </p>
          </div>
          <div class="rounded-lg bg-white/5 p-5 border border-white/10">
            <h3 class="text-xs font-bold uppercase tracking-wider text-slate-500 mb-4">
              Instability vectors (schematic)
            </h3>
            <p class="text-sm font-semibold text-white mb-1">Classic type III</p>
            <div class="flex justify-between text-[11px] text-slate-500 mb-0.5">
              <span>Vertical (CC rupture)</span><span class="text-slate-400">High</span>
            </div>
            <div class="h-2.5 rounded-full bg-white/10 overflow-hidden mb-3">
              <div class="h-full w-[80%] rounded-full bg-gradient-to-r from-amber-400 to-amber-600"></div>
            </div>
            <div class="flex justify-between text-[11px] text-slate-500 mb-0.5">
              <span>Horizontal (AP translation)</span><span class="text-slate-400">Lower</span>
            </div>
            <div class="h-2.5 rounded-full bg-white/10 overflow-hidden mb-5">
              <div class="h-full w-[25%] rounded-full bg-gradient-to-r from-sky-400 to-blue-600"></div>
            </div>
            <p class="text-sm font-semibold text-white mb-1">Type IV (reference)</p>
            <div class="flex justify-between text-[11px] text-slate-500 mb-0.5">
              <span>Vertical (CC rupture)</span><span class="text-slate-400">High</span>
            </div>
            <div class="h-2.5 rounded-full bg-white/10 overflow-hidden mb-3">
              <div class="h-full w-[80%] rounded-full bg-gradient-to-r from-amber-400 to-amber-600"></div>
            </div>
            <div class="flex justify-between text-[11px] text-slate-500 mb-0.5">
              <span>Horizontal (capsule / fascia)</span><span class="text-red-300">Critical</span>
            </div>
            <div class="h-2.5 rounded-full bg-white/10 overflow-hidden">
              <div class="h-full w-[95%] rounded-full bg-gradient-to-r from-red-400 to-red-600"></div>
            </div>
          </div>
        </div>
      </div>

      <h2 class="text-xl font-bold text-slate-900 mb-4">Consequences for treatment choice</h2>
      <div class="grid md:grid-cols-2 gap-4 mb-4">
        <button
          type="button"
          class="ac-hp-goto text-left rounded-xl border border-slate-200 bg-white p-5 shadow-sm hover:shadow-md transition-shadow border-l-4 border-l-emerald-600"
          data-goto="type4"
        >
          <h3 class="font-bold text-slate-900 mb-2">Type IV: strong operative signal</h3>
          <p class="text-slate-600 text-sm leading-relaxed mb-3">
            Horizontal instability is poorly tolerated in many high-demand shoulders. Cohort data show large radiological
            and score differences versus conservative care in type IV
            <RefLink id={r(1).id} text="Primary cohort" url={r(1).url} />.
          </p>
          <span class="text-sm font-bold text-emerald-700">Open Rockwood IV data →</span>
        </button>
        <button
          type="button"
          class="ac-hp-goto text-left rounded-xl border border-slate-200 bg-white p-5 shadow-sm hover:shadow-md transition-shadow border-l-4 border-l-amber-500"
          data-goto="type3"
        >
          <h3 class="font-bold text-slate-900 mb-2">Type III: conservative baseline</h3>
          <p class="text-slate-600 text-sm leading-relaxed mb-3">
            When vertical displacement dominates and horizontal translation is limited, structured non-operative care
            matches or beats early surgery on many clinical endpoints
            <RefLink id={r(1).id} text="Type III arm" url={r(1).url} />
            <RefLink id={r(6).id} text="Meta-analysis" url={r(6).url} />
            <RefLink id={r(7).id} text="RCT" url={r(7).url} />.
          </p>
          <span class="text-sm font-bold text-amber-700">Type III comparison →</span>
        </button>
      </div>
      <button
        type="button"
        class="ac-hp-goto w-full text-left rounded-xl border border-slate-200 bg-white p-5 shadow-sm hover:shadow-md transition-shadow border-l-4 border-l-sky-600"
        data-goto="iiia"
      >
        <h3 class="font-bold text-slate-900 mb-2">The IIIA / IIIB question</h3>
        <p class="text-slate-600 text-sm leading-relaxed mb-3">
          ISAKOS subclassified type III into stable versus unstable patterns
          <RefLink id={r(2).id} text="ISAKOS consensus" url={r(2).url} /> — recent work questions how reliably we can apply
          this in practice <RefLink id={r(8).id} text="Reliability" url={r(8).url} />
          <RefLink id={r(9).id} text="Clinical relevance" url={r(9).url} />.
        </p>
        <span class="text-sm font-bold text-sky-700">IIIA / IIIB evidence →</span>
      </button>
    </section>

    <!-- Panel 2 -->
    <section
      id="ac-hp-panel-type4"
      role="tabpanel"
      aria-labelledby="ac-hp-tab-type4"
      class="ac-hp-panel hidden"
      hidden
    >
      <h2 class="text-xl font-bold text-slate-900 mb-3">Rockwood type IV</h2>
      <p class="text-slate-600 leading-relaxed mb-6 max-w-3xl">
        Type IV injuries are defined by posterior displacement of the distal clavicle through the trapezius fascia, producing
        major horizontal instability — a different mechanical problem from vertical-dominant type III.
        <RefLink id={r(1).id} text="Feichtinger et al." url={r(1).url} />
      </p>

      <div
        class="rounded-lg border border-amber-200 bg-amber-50 text-amber-950 text-sm p-4 mb-6"
        role="note"
      >
        <strong>Methodological note:</strong> In the type IV subgroup of Feichtinger et al., operative and conservative
        cohorts differed in mean age and follow-up duration — interpret comparisons with this selection context in mind
        <RefLink id={r(1).id} text="KSSTA 2021" url={r(1).url} />.
      </div>

      <div class="grid sm:grid-cols-3 gap-4 mb-6">
        <div class="rounded-xl border border-slate-200 bg-white p-5 text-center">
          <div class="text-[11px] font-bold uppercase tracking-wide text-slate-500 mb-2">Operative cohort</div>
          <div class="text-4xl font-black text-emerald-800">18</div>
          <p class="text-xs text-slate-600 mt-2">Suture button, open or arthroscopic (illustrative n from publication)</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-5 text-center">
          <div class="text-[11px] font-bold uppercase tracking-wide text-slate-500 mb-2">Conservative cohort</div>
          <div class="text-4xl font-black text-amber-700">9</div>
          <p class="text-xs text-slate-600 mt-2">Sling + physiotherapy</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-5 text-center">
          <div class="text-[11px] font-bold uppercase tracking-wide text-slate-500 mb-2">Mean follow-up</div>
          <div class="text-4xl font-black text-slate-800">
            4.8<span class="text-lg font-bold"> yr</span>
          </div>
          <p class="text-xs text-slate-600 mt-2">Pooled context per paper</p>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-4 mb-6">
        <div class="rounded-xl border border-slate-200 bg-white p-5">
          <h3 class="font-bold text-slate-900 mb-2 flex flex-wrap items-center gap-2">
            ACJI score
            <span class="text-[10px] font-bold px-2 py-0.5 rounded bg-emerald-100 text-emerald-800">p &lt; 0.001</span>
          </h3>
          <div class="relative h-[280px] md:h-[320px] w-full">
            <canvas id="ac-hp-chart-t4-acji" aria-label="Bar chart ACJI operative versus conservative"></canvas>
          </div>
          <p class="text-xs text-slate-500 mt-2">
            Acromioclavicular Joint Instability Score (higher is better). Data from Feichtinger et al.
            <RefLink id={r(1).id} text="Table / results" url={r(1).url} />.
          </p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-5">
          <h3 class="font-bold text-slate-900 mb-2">AP translation and CC distance</h3>
          <div class="relative h-[280px] md:h-[320px] w-full">
            <canvas id="ac-hp-chart-t4-radio" aria-label="Bar chart AP translation and CC distance percent"></canvas>
          </div>
          <p class="text-xs text-slate-500 mt-2">
            Values as % of the healthy side (illustrative summary from published means).
            <RefLink id={r(1).id} text="Source" url={r(1).url} />
          </p>
        </div>
      </div>

      <div class="rounded-xl border border-slate-200 bg-slate-50 p-5 mb-6">
        <h3 class="font-bold text-slate-900 mb-2">Concomitant intra-articular pathology</h3>
        <p class="text-slate-600 text-sm leading-relaxed">
          In acute high-grade AC injury cohorts, a substantial minority have treatable glenohumeral lesions at arthroscopy —
          supporting routine joint inspection when the shoulder is explored
          <RefLink id={r(3).id} text="Meta-analysis ~20%" url={r(3).url} />.
        </p>
      </div>
    </section>

    <!-- Panel 3 -->
    <section
      id="ac-hp-panel-technique"
      role="tabpanel"
      aria-labelledby="ac-hp-tab-technique"
      class="ac-hp-panel hidden"
      hidden
    >
      <h2 class="text-xl font-bold text-slate-900 mb-3">Reduction, capsule, and fixation density</h2>
      <p class="text-slate-600 leading-relaxed mb-6 max-w-3xl">
        Implant choice matters, but horizontal control often hinges on achieving and holding anatomic reduction and
        addressing AC capsular integrity — not CC suspension alone.
      </p>

      <div class="grid md:grid-cols-2 gap-4 mb-8">
        <div class="rounded-xl bg-slate-900 text-slate-300 p-5 border border-slate-800">
          <h3 class="text-emerald-300 font-bold mb-2">1. Reduction control (cerclage / tension band)</h3>
          <p class="text-sm leading-relaxed">
            Strong suture cerclage or tension-band concepts around the coracoid can help deliver and lock reduction before
            final fixation — especially when beach-chair positioning makes manual control difficult. (Expert commentary:
            Dr. Carlos Rivero Siri, clinical practice.)
          </p>
        </div>
        <div class="rounded-xl bg-slate-900 text-slate-300 p-5 border border-slate-800">
          <h3 class="text-sky-300 font-bold mb-2">2. AC capsular shift</h3>
          <p class="text-sm leading-relaxed">
            CC fixation alone may not fully restore horizontal stability if the AC capsule and ligaments remain incompetent.
            Open joint visualization with capsular shift / imbrication is one strategy to rebuild intrinsic AP stability.
            (Expert commentary: Dr. Carlos Rivero Siri, clinical practice.)
          </p>
        </div>
      </div>

      <h2 class="text-lg font-bold text-slate-900 mb-2">Single versus double paired EndoButton (type IV)</h2>
      <p class="text-slate-600 text-sm mb-4">
        In acute Rockwood IV treated arthroscopically, doubling fixation points reduced mechanical complications versus a
        single paired construct in a retrospective comparative series
        <RefLink id={r(5).id} text="Xu et al., BMC 2018" url={r(5).url} />.
      </p>

      <div class="grid sm:grid-cols-3 gap-4 mb-6">
        <div class="rounded-xl border-l-4 border-red-600 border border-slate-200 bg-white p-4 text-center">
          <div class="text-[11px] font-bold uppercase text-slate-500 mb-1">Complications — single PET</div>
          <div class="text-3xl font-black text-red-700">17.9%</div>
          <p class="text-xs text-slate-600 mt-2">Including redislocation and loss of reduction</p>
        </div>
        <div class="rounded-xl border-l-4 border-emerald-600 border border-slate-200 bg-white p-4 text-center">
          <div class="text-[11px] font-bold uppercase text-slate-500 mb-1">Complications — double PET</div>
          <div class="text-3xl font-black text-emerald-800">2.5%</div>
          <p class="text-xs text-slate-600 mt-2">Isolated infection in series; no mechanical loosening reported</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
          <div class="text-[11px] font-bold uppercase text-slate-500 mb-1">Return to sport (double)</div>
          <div class="text-3xl font-black text-slate-900">89.7%</div>
          <p class="text-xs text-slate-600 mt-2">vs 61.5% single (same cohort definitions as publication)</p>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-4">
        <div class="rounded-xl border border-slate-200 bg-white p-5">
          <h3 class="font-bold text-slate-900 mb-2 flex flex-wrap items-center gap-2">
            Recovery time (months)
            <span class="text-[10px] font-bold px-2 py-0.5 rounded bg-emerald-100 text-emerald-800">p &lt; 0.05</span>
          </h3>
          <div class="relative h-[280px] w-full">
            <canvas id="ac-hp-chart-tech-recov" aria-label="Bar chart months to return to activity"></canvas>
          </div>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-5">
          <h3 class="font-bold text-slate-900 mb-2 flex flex-wrap items-center gap-2">
            Constant score (post-op)
            <span class="text-[10px] font-bold px-2 py-0.5 rounded bg-emerald-100 text-emerald-800">p &lt; 0.001</span>
          </h3>
          <div class="relative h-[280px] w-full">
            <canvas id="ac-hp-chart-tech-cs" aria-label="Bar chart Constant score"></canvas>
          </div>
        </div>
      </div>
    </section>

    <!-- Panel 4 -->
    <section
      id="ac-hp-panel-type3"
      role="tabpanel"
      aria-labelledby="ac-hp-tab-type3"
      class="ac-hp-panel hidden"
      hidden
    >
      <h2 class="text-xl font-bold text-slate-900 mb-3">Rockwood type III comparison</h2>
      <p class="text-slate-600 leading-relaxed mb-6 max-w-3xl">
        Understanding horizontal instability clarifies why many type III injuries do well without surgery: the “cost” of
        operation is often time and risk, while clinical scores frequently converge
        <RefLink id={r(1).id} text="Feichtinger type III" url={r(1).url} />
        <RefLink id={r(6).id} text="EFORT meta-analysis" url={r(6).url} />
        <RefLink id={r(7).id} text="Multicenter RCT" url={r(7).url} />.
      </p>

      <div class="grid md:grid-cols-2 gap-4 mb-6">
        <div class="rounded-xl border border-slate-200 bg-white p-5">
          <h3 class="font-bold text-slate-900 mb-3">Time advantage of conservative care</h3>
          <p class="text-slate-600 text-sm leading-relaxed mb-3">
            Feichtinger et al. reported longer treatment duration in the operative type III arm versus conservative care,
            with several purely clinical scores showing no significant difference — ACJI (which incorporates radiographic
            features) differed
            <RefLink id={r(1).id} text="Primary paper" url={r(1).url} />.
          </p>
          <div class="flex flex-wrap gap-2 text-[11px]">
            <span class="font-bold px-2 py-0.5 rounded bg-slate-100 text-slate-600">VAS — n.s.</span>
            <span class="font-bold px-2 py-0.5 rounded bg-slate-100 text-slate-600">Constant — n.s.</span>
            <span class="font-bold px-2 py-0.5 rounded bg-slate-100 text-slate-600">ASES — n.s.</span>
            <span class="font-bold px-2 py-0.5 rounded bg-emerald-100 text-emerald-800">ACJI — p &lt; 0.05</span>
          </div>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-5">
          <h3 class="font-bold text-slate-900 mb-2">Radiological restoration (vertical plane)</h3>
          <div class="relative h-[280px] w-full">
            <canvas id="ac-hp-chart-t3-radio" aria-label="Bar chart CC and AC distance percent"></canvas>
          </div>
          <p class="text-xs text-slate-500 mt-2">
            CC and AC distance as % of contralateral side (summary values from Feichtinger et al.).
            <RefLink id={r(1).id} text="Source" url={r(1).url} />
          </p>
        </div>
      </div>

      <div class="rounded-xl border border-emerald-200 bg-emerald-50 p-5">
        <h3 class="font-bold text-emerald-900 mb-2">Practical bottom line</h3>
        <p class="text-slate-700 text-sm leading-relaxed">
          For uncomplicated acute Rockwood III, structured conservative care remains the default in many guidelines; surgery
          is reserved for persistent symptoms, clear instability, or patient-specific goals
          <RefLink id={r(12).id} text="ESSKA consensus context" url={r(12).url} />
          <RefLink id={r(13).id} text="Treatment algorithms" url={r(13).url} />.
        </p>
      </div>
    </section>

    <!-- Panel 5 -->
    <section
      id="ac-hp-panel-iiia"
      role="tabpanel"
      aria-labelledby="ac-hp-tab-iiia"
      class="ac-hp-panel hidden"
      hidden
    >
      <h2 class="text-xl font-bold text-slate-900 mb-3">ISAKOS IIIA versus IIIB</h2>
      <p class="text-slate-600 leading-relaxed mb-6 max-w-3xl">
        The 2014 ISAKOS proposal aimed to separate “stable” from “unstable” type III injuries using clinical and Alexander
        view features <RefLink id={r(2).id} text="Beitzel et al." url={r(2).url} />. Subsequent studies stress measurement
        reliability and real-world predictive value
        <RefLink id={r(8).id} text="Reliability" url={r(8).url} />
        <RefLink id={r(9).id} text="Prospective cohort" url={r(9).url} />
        <RefLink id={r(10).id} text="Natural history" url={r(10).url} />.
      </p>

      <div class="grid md:grid-cols-2 gap-4 mb-6">
        <div class="rounded-xl border-l-4 border-emerald-600 border border-slate-200 bg-white p-5">
          <h3 class="font-bold text-emerald-800 mb-2">Type IIIA — “stable”</h3>
          <ul class="text-slate-600 text-sm list-disc pl-5 space-y-1">
            <li>No clavicle override on cross-body (Alexander / Basamania) view</li>
            <li>No major scapular dyskinesis</li>
            <li>Typical pathway: continue conservative care</li>
          </ul>
        </div>
        <div class="rounded-xl border-l-4 border-red-600 border border-slate-200 bg-white p-5">
          <h3 class="font-bold text-red-800 mb-2">Type IIIB — “unstable”</h3>
          <ul class="text-slate-600 text-sm list-disc pl-5 space-y-1">
            <li>Therapy-resistant scapular dyskinesis</li>
            <li>Override on Alexander view</li>
            <li>Algorithm: consider operative stabilization after failed conservative trial</li>
          </ul>
        </div>
      </div>

      <div class="rounded-xl border-2 border-amber-300 bg-amber-50 p-5 mb-6">
        <h3 class="font-bold text-amber-900 mb-3">ISAKOS timeline (simplified)</h3>
        <ol class="space-y-3 text-sm text-slate-700 border-l-2 border-amber-300 pl-4 ml-1">
          <li>
            <strong class="text-slate-900">0–3 weeks:</strong> sling and early structured rehab for all type III.
          </li>
          <li>
            <strong class="text-slate-900">6 weeks – 3 months:</strong> reassess clinically and radiographically; scrutinize
            scapular mechanics and Alexander view.
          </li>
          <li>
            <strong class="text-slate-900">Decision:</strong> continue conservative care for IIIA pattern; discuss surgery
            for persistent IIIB pattern symptoms.
          </li>
        </ol>
        <p class="text-xs text-amber-900/80 mt-3">
          Summary of published guidance — not a substitute for local protocol
          <RefLink id={r(2).id} text="ISAKOS" url={r(2).url} />.
        </p>
      </div>

      <div class="space-y-4 mb-6">
        <div class="rounded-xl border border-slate-200 bg-white p-5">
          <h3 class="font-bold text-slate-900 mb-2">
            Velasquez Garcia &amp; Abdo (2022) — radiological reliability
          </h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            Fellowship-trained shoulder surgeons showed only fair / moderate interobserver agreement subclassifying IIIA vs
            IIIB on the modified scheme, while quantitative CC distance measurement was highly reliable
            <RefLink id={r(8).id} text="OJSM" url={r(8).url} />.
          </p>
        </div>
        <div class="rounded-xl border-2 border-red-200 bg-red-50 p-5">
          <h3 class="font-bold text-red-900 mb-2">Haugaard et al. (2024) — clinical relevance</h3>
          <p class="text-slate-700 text-sm leading-relaxed mb-3">
            In a prospective conservative cohort with optional delayed surgery, most patients did well; subclassification
            did not separate meaningful 1-year WOSI outcomes in the analysis presented
            <RefLink id={r(9).id} text="KSSTA" url={r(9).url} />
            <RefLink id={r(10).id} text="Companion outcomes" url={r(10).url} />.
          </p>
          <div class="grid sm:grid-cols-3 gap-2 text-center text-sm">
            <div class="bg-white/80 rounded-lg p-3 border border-red-100">
              <div class="text-[10px] font-bold text-slate-500 uppercase">Stable group — surgery</div>
              <div class="text-2xl font-black text-emerald-700">0%</div>
            </div>
            <div class="bg-white/80 rounded-lg p-3 border border-red-100">
              <div class="text-[10px] font-bold text-slate-500 uppercase">Unstable group — surgery</div>
              <div class="text-2xl font-black text-amber-700">13%</div>
            </div>
            <div class="bg-white/80 rounded-lg p-3 border border-red-100">
              <div class="text-[10px] font-bold text-slate-500 uppercase">WOSI at 1 yr</div>
              <div class="text-2xl font-black text-slate-500">n.s.</div>
            </div>
          </div>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-5">
          <h3 class="font-bold text-slate-900 mb-2">Karargyris et al. (2020) — AC–DC distance</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            The acromial center line to dorsal clavicle (AC–DC) measurement on Alexander view may better capture horizontal
            displacement than CC distance alone in borderline patterns
            <RefLink id={r(11).id} text="JSES" url={r(11).url} />.
          </p>
        </div>
      </div>

      <div class="rounded-xl border border-emerald-200 bg-emerald-50 p-5">
        <h3 class="font-bold text-emerald-900 mb-2">Clinical synthesis</h3>
        <p class="text-slate-700 text-sm leading-relaxed">
          Treat most acute type III injuries conservatively, re-evaluate at 6–12 weeks, and individualize surgery for the
          minority with ongoing symptoms, functional limitation, and demonstrable instability — using the best available
          imaging and examination tools rather than labels alone
          <RefLink id={r(13).id} text="Algorithms" url={r(13).url} />.
        </p>
      </div>
    </section>
  </div>

  <details class="mt-10 rounded-lg border border-slate-200 bg-slate-50 p-4">
    <summary class="font-bold text-slate-800 cursor-pointer text-sm">Full reference list ({refs.length})</summary>
    <ul class="mt-4 space-y-2 text-xs text-slate-600 list-none p-0">
      {
        refs.map((ref, i) => (
          <li>
            <a
              href={ref.url}
              class="text-sky-700 hover:underline break-words"
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="font-bold text-slate-400">[{i + 1}]</span> {ref.text}
            </a>
          </li>
        ))
      }
    </ul>
  </details>
</div>

<style>
  @keyframes acHpIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .ac-hp-panel-in {
    animation: acHpIn 0.35s ease forwards;
  }
  .ac-hp-tab[data-active='true'] .ac-hp-tab-num {
    background-color: rgb(6 95 70);
    color: white;
  }
  #ac-hp-root .scrollbar-none::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  import Chart from 'chart.js/auto';

  type TabId = 'overview' | 'type4' | 'technique' | 'type3' | 'iiia';

  const state: { chartsInit: Partial<Record<TabId, boolean>>; charts: import('chart.js').Chart[] } = {
    chartsInit: {},
    charts: [],
  };

  const C = {
    op: { bg: 'rgba(6,95,70,0.85)', border: '#064e3b' },
    cons: { bg: 'rgba(180,83,9,0.85)', border: '#92400e' },
    single: { bg: 'rgba(185,28,28,0.85)', border: '#7f1d1d' },
    double: { bg: 'rgba(6,95,70,0.85)', border: '#064e3b' },
    ink: '#0f172a',
  };

  function baseOpts(yMax?: number): import('chart.js').ChartOptions<'bar'> {
    return {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          position: 'bottom',
          labels: { color: C.ink, font: { family: 'system-ui, sans-serif', size: 12 }, padding: 12 },
        },
        tooltip: {
          backgroundColor: '#0f172a',
          titleFont: { size: 13 },
          bodyFont: { size: 12 },
          padding: 10,
          cornerRadius: 6,
        },
      },
      scales: {
        y: {
          beginAtZero: true,
          max: yMax,
          grid: { color: '#e2e8f0' },
          ticks: { color: '#64748b', font: { family: 'system-ui, sans-serif' } },
        },
        x: {
          grid: { display: false },
          ticks: { color: '#475569', font: { family: 'system-ui, sans-serif', weight: 600 } },
        },
      },
    };
  }

  function ds(
    label: string,
    data: number[],
    palette: { bg: string; border: string },
  ): import('chart.js').ChartDataset<'bar', number[]> {
    return {
      label,
      data,
      backgroundColor: palette.bg,
      borderColor: palette.border,
      borderWidth: 1,
      borderRadius: 4,
      maxBarThickness: 56,
    };
  }

  function initCharts(tab: TabId): void {
    if (state.chartsInit[tab]) return;
    state.chartsInit[tab] = true;

    const add = (ch: import('chart.js').Chart | undefined): void => {
      if (ch) state.charts.push(ch);
    };

    if (tab === 'type4') {
      const el1 = document.getElementById('ac-hp-chart-t4-acji') as HTMLCanvasElement | null;
      const el2 = document.getElementById('ac-hp-chart-t4-radio') as HTMLCanvasElement | null;
      if (el1) {
        add(
          new Chart(el1.getContext('2d')!, {
            type: 'bar',
            data: {
              labels: ['ACJI (0–100)'],
              datasets: [
                ds('Operative (n=18)', [88], C.op),
                ds('Conservative (n=9)', [62], C.cons),
              ],
            },
            options: baseOpts(100),
          }),
        );
      }
      if (el2) {
        add(
          new Chart(el2.getContext('2d')!, {
            type: 'bar',
            data: {
              labels: ['AP translation (%)', 'CC distance (%)'],
              datasets: [
                ds('Operative', [101.8, 125.8], C.op),
                ds('Conservative', [370.9, 193.9], C.cons),
              ],
            },
            options: baseOpts(),
          }),
        );
      }
    }

    if (tab === 'technique') {
      const el1 = document.getElementById('ac-hp-chart-tech-recov') as HTMLCanvasElement | null;
      const el2 = document.getElementById('ac-hp-chart-tech-cs') as HTMLCanvasElement | null;
      if (el1) {
        add(
          new Chart(el1.getContext('2d')!, {
            type: 'bar',
            data: {
              labels: ['Return to activity (months)'],
              datasets: [
                ds('Single PET (n=39)', [5.43], C.single),
                ds('Double PET (n=39)', [3.25], C.double),
              ],
            },
            options: baseOpts(),
          }),
        );
      }
      if (el2) {
        add(
          new Chart(el2.getContext('2d')!, {
            type: 'bar',
            data: {
              labels: ['Constant score (post-op)'],
              datasets: [ds('Single PET', [83.2], C.single), ds('Double PET', [92.15], C.double)],
            },
            options: baseOpts(100),
          }),
        );
      }
    }

    if (tab === 'type3') {
      const el = document.getElementById('ac-hp-chart-t3-radio') as HTMLCanvasElement | null;
      if (el) {
        add(
          new Chart(el.getContext('2d')!, {
            type: 'bar',
            data: {
              labels: ['CC distance (%)', 'AC distance (%)'],
              datasets: [
                ds('Operative (n=10)', [128.8, 159.7], C.op),
                ds('Conservative (n=19)', [190.1, 240.1], C.cons),
              ],
            },
            options: baseOpts(),
          }),
        );
      }
    }
  }

  function setActiveTab(id: TabId): void {
    const tabs = document.querySelectorAll<HTMLButtonElement>('.ac-hp-tab');
    const panels = document.querySelectorAll<HTMLElement>('.ac-hp-panel');

    tabs.forEach((btn) => {
      const tid = btn.dataset.tab as TabId | undefined;
      const active = tid === id;
      btn.dataset.active = active ? 'true' : 'false';
      btn.setAttribute('aria-selected', active ? 'true' : 'false');
    });

    panels.forEach((panel) => {
      const pid = panel.id.replace('ac-hp-panel-', '') as TabId;
      const show = pid === id;
      panel.classList.toggle('hidden', !show);
      panel.toggleAttribute('hidden', !show);
    });

    initCharts(id);
  }

  function init(): void {
    document.querySelectorAll('.ac-hp-tab').forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLButtonElement).dataset.tab as TabId | undefined;
        if (id) setActiveTab(id);
      });
    });

    document.querySelectorAll('.ac-hp-goto').forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLButtonElement).dataset.goto as TabId | undefined;
        if (id) setActiveTab(id);
      });
    });

    initCharts('overview');
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
