---
/**
 * Admin-sida för personalportalen
 * URL: /personal/admin
 * 
 * Hantera användare, roller, lösenordsåterställning och läkare.
 */

export const prerender = false;

import PortalLayout from '../../layouts/PortalLayout.astro';
import { hamtaAnvandare, skickaAterställningslank } from '../../lib/auth';
import {
  harMinstPortalRoll,
  normalizePortalRole,
  portalRoleLabel,
  portalRoleRank,
  type PortalRole
} from '../../lib/portal-roles';
import { supabaseAdmin } from '../../lib/supabase';

const anvandare = await hamtaAnvandare(Astro.cookies);

// Endast inloggade
if (!anvandare) {
  return Astro.redirect('/personal');
}

function hamtaRollFranAuthUser(user: { app_metadata?: Record<string, unknown> | null }): PortalRole {
  return normalizePortalRole(user.app_metadata?.role);
}

function sorteraPersonal<T extends { roll: PortalRole; email?: string | null }>(lista: T[]): T[] {
  return lista.sort((a, b) => {
    const rankDiff = portalRoleRank(b.roll) - portalRoleRank(a.roll);
    if (rankDiff !== 0) return rankDiff;
    return (a.email || '').localeCompare(b.email || '', 'sv');
  });
}

async function loggaAdminAtgard(
  handelseTyp: string,
  detaljer: Record<string, unknown>
) {
  if (!anvandare) return;
  try {
    await supabaseAdmin.from('audit_logg').insert({
      anvandare_id: anvandare.id,
      anvandare_email: anvandare.email,
      handelse_typ: handelseTyp,
      detaljer,
      ip_adress: Astro.request.headers.get('x-forwarded-for')
        || Astro.request.headers.get('x-real-ip')
        || 'unknown',
      user_agent: Astro.request.headers.get('user-agent') || 'unknown'
    });
  } catch (error) {
    console.error(`Kunde inte logga adminåtgärd ${handelseTyp}:`, error);
  }
}

const arAdmin = harMinstPortalRoll(anvandare.roll, 'admin');
const arSuperadmin = anvandare.roll === 'superadmin';

type PersonalPost = {
  id: string;
  email: string | undefined;
  skapad: string;
  mobilnummer: string | null;
  vill_ha_notifikationer: boolean;
  avatar_url: string | null;
  roll: PortalRole;
  ar_nuvarande: boolean;
};

type LakarePost = {
  id: string;
  namn: string;
  kortnamn: string | null;
  aktiv: boolean;
};

// Hämta alla profiler med notifikationsinställningar
let personal: PersonalPost[] = [];
let personalError = '';

try {
  if (arAdmin) {
    // Hämta alla användare från auth och deras profiler
    const { data: authUsers, error: authError } = await supabaseAdmin.auth.admin.listUsers();
    
    if (authError) {
      personalError = 'Kunde inte hämta användare';
      console.error('Auth error:', authError);
    } else {
      // Hämta profiler
      const { data: profiles } = await supabaseAdmin
        .from('profiles')
        .select('*');
      
      // Kombinera
      personal = (authUsers?.users || []).map(user => {
        const profil = profiles?.find(p => p.id === user.id);
        const roll = hamtaRollFranAuthUser(user);
        return {
          id: user.id,
          email: user.email,
          skapad: user.created_at,
          mobilnummer: profil?.mobilnummer || null,
          vill_ha_notifikationer: profil?.vill_ha_notifikationer || false,
          avatar_url: profil?.avatar_url || null,
          roll,
          ar_nuvarande: user.id === anvandare.id
        };
      });
      sorteraPersonal(personal);
    }
  } else {
    personalError = 'Endast administratör kan hantera användare och roller.';
  }
} catch (e) {
  console.error('Error fetching personal:', e);
  personalError = 'Ett fel uppstod';
}

// Hämta läkare
let lakare: LakarePost[] = [];
let lakareError = '';

try {
  if (arAdmin) {
    const { data, error } = await supabaseAdmin
      .from('lakare')
      .select('*')
      .order('namn');
    
    if (error) {
      lakareError = error.message;
    } else {
      lakare = data || [];
    }
  } else {
    lakareError = 'Endast administratör kan hantera läkare.';
  }
} catch (e) {
  lakareError = 'Kunde inte hämta läkare';
}

// Hantera formulär
let meddelande = '';
let meddelandeTyp: 'success' | 'error' = 'success';

if (Astro.request.method === 'POST') {
  try {
    if (!arAdmin) {
      meddelande = 'Endast administratör kan göra ändringar här.';
      meddelandeTyp = 'error';
    } else {
    const formData = await Astro.request.formData();
    const action = formData.get('action');

    // === SKAPA NY ANVÄNDARE ===
    if (action === 'skapa_anvandare') {
      const email = formData.get('email')?.toString().trim();
      const password = formData.get('password')?.toString();
      const onskadRoll = normalizePortalRole(formData.get('roll'));
      const roll = arSuperadmin ? onskadRoll : 'personal';

      if (!email || !password) {
        meddelande = 'E-post och lösenord krävs';
        meddelandeTyp = 'error';
      } else if (password.length < 6) {
        meddelande = 'Lösenordet måste vara minst 6 tecken';
        meddelandeTyp = 'error';
      } else {
        const { data, error } = await supabaseAdmin.auth.admin.createUser({
          email,
          password,
          email_confirm: true,
          app_metadata: { role: roll }
        });

        if (error) {
          meddelande = `Kunde inte skapa användare: ${error.message}`;
          meddelandeTyp = 'error';
        } else {
          meddelande = `✅ Användare ${email} skapad som ${portalRoleLabel(roll).toLowerCase()}!`;
          meddelandeTyp = 'success';
          await loggaAdminAtgard('ANVANDARE_SKAPAD', {
            ny_anvandare_email: email,
            roll
          });
          
          // Lägg till i personal-listan
          personal.push({
            id: data.user.id,
            email: data.user.email,
            skapad: data.user.created_at,
            mobilnummer: null,
            vill_ha_notifikationer: false,
            avatar_url: null,
            roll,
            ar_nuvarande: false
          });
          sorteraPersonal(personal);
        }
      }
    }

    // === ÄNDRA ANVÄNDARROLL ===
    if (action === 'andra_roll') {
      if (!arSuperadmin) {
        meddelande = 'Endast superadmin kan ändra användarroller.';
        meddelandeTyp = 'error';
      } else {
      const userId = formData.get('user_id')?.toString();
      const nyRoll = normalizePortalRole(formData.get('ny_roll'));
      const nuvarandeRoll = normalizePortalRole(formData.get('nuvarande_roll'));
      const targetUser = personal.find((p) => p.id === userId);
      const antalSuperadmins = personal.filter((p) => p.roll === 'superadmin').length;

      if (!userId || !targetUser) {
        meddelande = 'Kunde inte hitta användaren.';
        meddelandeTyp = 'error';
      } else if (userId === anvandare.id) {
        meddelande = 'Din egen roll ändras inte här. Använd en annan superadmin eller Supabase Dashboard vid behov.';
        meddelandeTyp = 'error';
      } else if (nuvarandeRoll === nyRoll) {
        meddelande = 'Ingen rolländring att spara.';
        meddelandeTyp = 'error';
      } else if (nuvarandeRoll === 'superadmin' && nyRoll !== 'superadmin' && antalSuperadmins <= 1) {
        meddelande = 'Det måste alltid finnas minst en superadmin.';
        meddelandeTyp = 'error';
      } else {
        const { data: authUserData, error: authUserError } = await supabaseAdmin.auth.admin.getUserById(userId);

        if (authUserError || !authUserData?.user) {
          meddelande = `Kunde inte läsa användaren: ${authUserError?.message || 'Okänt fel'}`;
          meddelandeTyp = 'error';
        } else {
          const existingAppMetadata = authUserData.user.app_metadata && typeof authUserData.user.app_metadata === 'object'
            ? authUserData.user.app_metadata
            : {};

          const { error } = await supabaseAdmin.auth.admin.updateUserById(userId, {
            app_metadata: {
              ...existingAppMetadata,
              role: nyRoll
            }
          });

          if (error) {
            meddelande = `Kunde inte uppdatera roll: ${error.message}`;
            meddelandeTyp = 'error';
          } else {
            meddelande = `✅ ${targetUser.email} är nu ${portalRoleLabel(nyRoll).toLowerCase()}.`;
            meddelandeTyp = 'success';
            await loggaAdminAtgard('ROLL_ANDRAD', {
              target_user_id: userId,
              target_user_email: targetUser.email,
              tidigare_roll: nuvarandeRoll,
              ny_roll: nyRoll
            });

            const idx = personal.findIndex((p) => p.id === userId);
            if (idx >= 0) {
              personal[idx].roll = nyRoll;
            }
            sorteraPersonal(personal);
          }
        }
      }
      }
    }

    // === SKICKA ÅTERSTÄLLNINGSLÄNK ===
    if (action === 'skicka_aterstallningslank') {
      const userId = formData.get('user_id')?.toString();
      const targetUser = personal.find((p) => p.id === userId);

      if (!userId || !targetUser || !targetUser.email) {
        meddelande = 'Kunde inte hitta användaren eller e-postadress saknas.';
        meddelandeTyp = 'error';
      } else {
        const result = await skickaAterställningslank(targetUser.email);

        if (!result.success) {
          meddelande = result.error || 'Kunde inte skicka återställningslänk.';
          meddelandeTyp = 'error';
        } else {
          meddelande = `✅ Återställningslänk skickad till ${targetUser.email}.`;
          meddelandeTyp = 'success';
          await loggaAdminAtgard('LOSENORD_ATERSTALLNING_SKICKAD', {
            target_user_id: userId,
            target_user_email: targetUser.email
          });
        }
      }
    }

    // === LÄGG TILL LÄKARE ===
    if (action === 'lagg_till_lakare') {
      const namn = formData.get('lakare_namn')?.toString().trim();
      const kortnamn = formData.get('lakare_kortnamn')?.toString().trim();

      if (!namn) {
        meddelande = 'Läkarens namn krävs';
        meddelandeTyp = 'error';
      } else {
        const { error } = await supabaseAdmin
          .from('lakare')
          .insert({ namn, kortnamn: kortnamn || null });

        if (error) {
          if (error.code === '23505') {
            meddelande = 'En läkare med detta namn finns redan';
          } else {
            meddelande = `Kunde inte lägga till läkare: ${error.message}`;
          }
          meddelandeTyp = 'error';
        } else {
          meddelande = `✅ Läkare "${namn}" tillagd!`;
          meddelandeTyp = 'success';
          await loggaAdminAtgard('LAKARE_SKAPAD', { namn, kortnamn: kortnamn || null });
          
          // Hämta uppdaterad lista
          const { data } = await supabaseAdmin
            .from('lakare')
            .select('*')
            .order('namn');
          lakare = data || [];
        }
      }
    }

    // === TA BORT LÄKARE ===
    if (action === 'ta_bort_lakare') {
      const lakareId = formData.get('lakare_id')?.toString();

      if (lakareId) {
        const { error } = await supabaseAdmin
          .from('lakare')
          .delete()
          .eq('id', lakareId);

        if (error) {
          meddelande = `Kunde inte ta bort läkare: ${error.message}`;
          meddelandeTyp = 'error';
        } else {
          meddelande = '✅ Läkare borttagen!';
          meddelandeTyp = 'success';
          await loggaAdminAtgard('LAKARE_BORTTAGEN', { lakare_id: lakareId });
          lakare = lakare.filter(l => l.id !== lakareId);
        }
      }
    }

    // === UPPDATERA LÄKARE STATUS ===
    if (action === 'toggle_lakare_aktiv') {
      const lakareId = formData.get('lakare_id')?.toString();
      const nuvarandeAktiv = formData.get('nuvarande_aktiv') === 'true';

      if (lakareId) {
        const { error } = await supabaseAdmin
          .from('lakare')
          .update({ aktiv: !nuvarandeAktiv })
          .eq('id', lakareId);

        if (error) {
          meddelande = `Kunde inte uppdatera läkare: ${error.message}`;
          meddelandeTyp = 'error';
        } else {
          meddelande = nuvarandeAktiv ? '⏸️ Läkare inaktiverad' : '✅ Läkare aktiverad';
          meddelandeTyp = 'success';
          await loggaAdminAtgard('LAKARE_AKTIV_STATUS_ANDRAD', {
            lakare_id: lakareId,
            aktiv: !nuvarandeAktiv
          });
          
          // Uppdatera lokalt
          const idx = lakare.findIndex(l => l.id === lakareId);
          if (idx >= 0) {
            lakare[idx].aktiv = !nuvarandeAktiv;
          }
        }
      }
    }
    }

  } catch (e) {
    console.error('Form error:', e);
    meddelande = 'Ett oväntat fel uppstod';
    meddelandeTyp = 'error';
  }
}

// Formatera mobilnummer för visning
function formateraNummer(nummer: string | null): string {
  if (!nummer) return '—';
  const clean = nummer.replace(/^\+46/, '0');
  if (clean.length === 10) {
    return `${clean.slice(0, 3)}-${clean.slice(3, 6)} ${clean.slice(6, 8)} ${clean.slice(8)}`;
  }
  return clean;
}

function formateraDatum(datum: string): string {
  return new Date(datum).toLocaleDateString('sv-SE', {
    year: 'numeric',
    month: 'short',
    day: 'numeric'
  });
}
---

<PortalLayout
  title="Administration"
  activePath="/personal/admin"
  email={anvandare?.email}
  role={anvandare?.roll}
  userId={anvandare?.id}
  userName={anvandare?.namn}
>
  <div class="min-h-screen" style="background:#f8fafc;">
    <div class="max-w-6xl mx-auto px-4 py-4">
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-2xl font-bold text-gray-900">⚙️ Administration</h1>
          </div>
          <div class="flex items-center gap-3">
            <a 
              href="/admin/ai-council" 
              class="px-4 py-1.5 text-sm bg-indigo-600 text-white hover:bg-indigo-700 rounded-lg transition-colors flex items-center gap-2"
            >
              🧠 AI Council
            </a>
            <a 
              href="/personal/oversikt?logout=true" 
              class="px-3 py-1.5 text-sm text-gray-600 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors"
            >
              Logga ut
            </a>
          </div>
        </div>
      </div>
    </header>

    <main class="max-w-6xl mx-auto px-4 py-8">
      
      {/* Meddelande */}
      {meddelande && (
        <div class={`mb-6 p-4 rounded-lg border ${
          meddelandeTyp === 'success' 
            ? 'bg-green-50 border-green-200 text-green-800' 
            : 'bg-red-50 border-red-200 text-red-800'
        }`}>
          {meddelande}
        </div>
      )}

      {!arAdmin ? (
        <section class="bg-white rounded-xl shadow-sm border overflow-hidden">
          <div class="bg-amber-500 px-6 py-4">
            <h2 class="text-xl font-semibold text-white">🔒 Administratör krävs</h2>
            <p class="text-amber-50 text-sm">Den här sidan är avsedd för användar- och rollhantering.</p>
          </div>
          <div class="p-6 space-y-4">
            <p class="text-gray-700">
              Din nuvarande inloggning har rollen <strong>{portalRoleLabel(anvandare.roll)}</strong>. För att kunna skapa användare,
              ändra roller eller hantera läkare behöver kontot ha admin-roll i Supabase Auth.
            </p>
            <div class="rounded-lg border border-amber-200 bg-amber-50 p-4 text-sm text-amber-900">
              Första superadmin sätts säkrast i Supabase Dashboard genom att lägga <code>{`"role": "superadmin"`}</code> i
              användarens <code>app_metadata</code>. Därefter kan superadmin hantera roller här i adminpanelen.
            </div>
          </div>
        </section>
      ) : (

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        
        <!-- ANVÄNDARE -->
        <section class="bg-white rounded-xl shadow-sm border overflow-hidden">
          <div class="bg-gradient-to-r from-sky-500 to-sky-600 px-6 py-4">
            <h2 class="text-xl font-semibold text-white">👥 Användare</h2>
            <p class="text-sky-100 text-sm">Personal som kan logga in i portalen</p>
          </div>
          
          <div class="p-6">
            {/* Formulär för ny användare */}
            <form method="POST" class="mb-6 p-4 bg-gray-50 rounded-lg border">
              <h3 class="font-medium text-gray-900 mb-4">➕ Bjud in ny användare</h3>
              
              <input type="hidden" name="action" value="skapa_anvandare" />
              
              <div class="space-y-3">
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">E-postadress</label>
                  <input 
                    type="email" 
                    name="email" 
                    required
                    placeholder="anna@sodermalmsortopedi.se"
                    class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-sky-500"
                  />
                </div>
                
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Tillfälligt lösenord</label>
                  <input 
                    type="text" 
                    name="password" 
                    required
                    minlength="6"
                    placeholder="Minst 6 tecken"
                    class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-sky-500"
                  />
                  <p class="text-xs text-gray-500 mt-1">Användaren kan byta lösenord senare</p>
                </div>

                {arSuperadmin ? (
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Roll</label>
                    <select
                      name="roll"
                      class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-sky-500 bg-white"
                    >
                      <option value="personal" selected>Personal</option>
                      <option value="admin">Administratör</option>
                      <option value="superadmin">Superadmin</option>
                    </select>
                    <p class="text-xs text-gray-500 mt-1">Roll lagras i Supabase Auth och styr åtkomst i hela personalportalen.</p>
                  </div>
                ) : (
                  <div class="rounded-lg border border-sky-200 bg-sky-50 p-3 text-sm text-sky-800">
                    Nya användare skapas som <strong>Personal</strong>. Endast superadmin kan tilldela rollerna administratör eller superadmin.
                  </div>
                )}
                
                <button 
                  type="submit"
                  class="w-full px-4 py-2 bg-sky-600 text-white font-medium rounded-lg hover:bg-sky-700 transition-colors"
                >
                  Skapa användare
                </button>
              </div>
            </form>
            
            {/* Lista över användare */}
            <div>
              <h3 class="font-medium text-gray-900 mb-3">Registrerade användare ({personal.length})</h3>
              
              {personalError && (
                <p class="text-red-600 text-sm">{personalError}</p>
              )}
              
              <div class="space-y-3">
                {personal.map(p => (
                  <div class="p-3 bg-gray-50 rounded-lg border" data-user-id={p.id}>
                    <div class="flex items-center gap-3">
                      {/* Profilbild */}
                      <div class="relative group">
                        <div class="w-12 h-12 rounded-full overflow-hidden bg-gray-200 flex items-center justify-center">
                          {p.avatar_url ? (
                            <img 
                              src={p.avatar_url} 
                              alt={p.email}
                              class="w-full h-full object-cover avatar-img"
                            />
                          ) : (
                            <span class="text-gray-400 text-lg">👤</span>
                          )}
                        </div>
                        {/* Ladda upp-knapp */}
                        <label class="absolute inset-0 flex items-center justify-center bg-black/50 rounded-full opacity-0 group-hover:opacity-100 cursor-pointer transition-opacity">
                          <span class="text-white text-xs">📷</span>
                          <input 
                            type="file" 
                            accept="image/*"
                            class="hidden avatar-input"
                            data-user-id={p.id}
                          />
                        </label>
                      </div>
                      
                      {/* Info */}
                      <div class="flex-1 min-w-0">
                        <div class="font-medium text-gray-900 text-sm truncate">{p.email}</div>
                        <div class="text-xs text-gray-500">
                          📱 {formateraNummer(p.mobilnummer)}
                          {p.vill_ha_notifikationer && (
                            <span class="ml-2 text-green-600">🔔</span>
                          )}
                        </div>
                        <div class="mt-2 flex flex-wrap items-center gap-2 text-xs">
                          <span class={`inline-flex items-center rounded-full px-2 py-0.5 font-medium ${
                            p.roll === 'superadmin'
                              ? 'bg-purple-100 text-purple-700'
                              : p.roll === 'admin'
                              ? 'bg-indigo-100 text-indigo-700'
                              : 'bg-gray-200 text-gray-700'
                          }`}>
                            {portalRoleLabel(p.roll)}
                          </span>
                          {p.ar_nuvarande && (
                            <span class="inline-flex items-center rounded-full bg-sky-100 px-2 py-0.5 font-medium text-sky-700">
                              Du
                            </span>
                          )}
                        </div>
                      </div>
                      
                      {/* Datum */}
                      <div class="text-xs text-gray-400">
                        {formateraDatum(p.skapad)}
                      </div>
                    </div>
                    {/* Upload status */}
                    <div class="upload-status hidden mt-2 text-xs"></div>

                    {!p.ar_nuvarande && arSuperadmin ? (
                      <form method="POST" class="mt-3 flex flex-col gap-2 sm:flex-row sm:items-center">
                        <input type="hidden" name="action" value="andra_roll" />
                        <input type="hidden" name="user_id" value={p.id} />
                        <input type="hidden" name="nuvarande_roll" value={p.roll} />
                        <select
                          name="ny_roll"
                          class="w-full sm:w-48 px-3 py-2 border rounded-lg focus:ring-2 focus:ring-sky-500 bg-white text-sm"
                        >
                          <option value="personal" selected={p.roll === 'personal'}>Personal</option>
                          <option value="admin" selected={p.roll === 'admin'}>Administratör</option>
                          <option value="superadmin" selected={p.roll === 'superadmin'}>Superadmin</option>
                        </select>
                        <button
                          type="submit"
                          class="px-3 py-2 bg-white border border-sky-200 text-sky-700 text-sm font-medium rounded-lg hover:bg-sky-50 transition-colors"
                        >
                          Uppdatera roll
                        </button>
                      </form>
                    ) : p.ar_nuvarande ? (
                      <p class="mt-3 text-xs text-gray-500">
                        Din egen roll ändras inte här för att minska risken att du låser ute dig själv.
                      </p>
                    ) : (
                      <p class="mt-3 text-xs text-gray-500">
                        Endast superadmin kan ändra användarroller.
                      </p>
                    )}

                    <form method="POST" class="mt-2">
                      <input type="hidden" name="action" value="skicka_aterstallningslank" />
                      <input type="hidden" name="user_id" value={p.id} />
                      <button
                        type="submit"
                        class="px-3 py-2 bg-white border border-amber-200 text-amber-700 text-sm font-medium rounded-lg hover:bg-amber-50 transition-colors"
                      >
                        Skicka återställningslänk
                      </button>
                    </form>
                  </div>
                ))}
              </div>
              
              <p class="text-xs text-gray-500 mt-4">
                💡 Användare lägger till sitt mobilnummer via <a href="/personal/profil" class="text-sky-600 underline">Min profil</a>
              </p>
            </div>
          </div>
        </section>

        <!-- LÄKARE -->
        <section class="bg-white rounded-xl shadow-sm border overflow-hidden">
          <div class="bg-gradient-to-r from-emerald-500 to-emerald-600 px-6 py-4">
            <h2 class="text-xl font-semibold text-white">🩺 Läkare</h2>
            <p class="text-emerald-100 text-sm">Kirurger för Kort Varsel-kampanjer</p>
          </div>
          
          <div class="p-6">
            {/* Formulär för ny läkare */}
            <form method="POST" class="mb-6 p-4 bg-gray-50 rounded-lg border">
              <h3 class="font-medium text-gray-900 mb-4">➕ Lägg till läkare</h3>
              
              <input type="hidden" name="action" value="lagg_till_lakare" />
              
              <div class="space-y-3">
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Namn</label>
                  <input 
                    type="text" 
                    name="lakare_namn" 
                    required
                    placeholder="Dr. Andersson"
                    class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-emerald-500"
                  />
                </div>
                
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Kortnamn (valfritt)</label>
                  <input 
                    type="text" 
                    name="lakare_kortnamn" 
                    placeholder="Andersson"
                    class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-emerald-500"
                  />
                  <p class="text-xs text-gray-500 mt-1">Används i SMS om det är kortare</p>
                </div>
                
                <button 
                  type="submit"
                  class="w-full px-4 py-2 bg-emerald-600 text-white font-medium rounded-lg hover:bg-emerald-700 transition-colors"
                >
                  Lägg till läkare
                </button>
              </div>
            </form>
            
            {/* Lista över läkare */}
            <div>
              <h3 class="font-medium text-gray-900 mb-3">Registrerade läkare ({lakare.length})</h3>
              
              {lakareError && (
                <p class="text-red-600 text-sm">{lakareError}</p>
              )}
              
              <div class="space-y-2">
                {lakare.map(l => (
                  <div class={`p-3 rounded-lg border flex items-center justify-between ${
                    l.aktiv ? 'bg-gray-50' : 'bg-gray-100 opacity-60'
                  }`}>
                    <div>
                      <div class="font-medium text-gray-900 text-sm flex items-center gap-2">
                        {l.namn}
                        {!l.aktiv && <span class="text-xs bg-gray-300 text-gray-600 px-2 py-0.5 rounded">Inaktiv</span>}
                      </div>
                      {l.kortnamn && (
                        <div class="text-xs text-gray-500">Kortnamn: {l.kortnamn}</div>
                      )}
                    </div>
                    <div class="flex gap-2">
                      {/* Toggle aktiv */}
                      <form method="POST" class="inline">
                        <input type="hidden" name="action" value="toggle_lakare_aktiv" />
                        <input type="hidden" name="lakare_id" value={l.id} />
                        <input type="hidden" name="nuvarande_aktiv" value={l.aktiv.toString()} />
                        <button 
                          type="submit"
                          class={`px-2 py-1 text-xs rounded ${
                            l.aktiv 
                              ? 'bg-yellow-100 text-yellow-700 hover:bg-yellow-200' 
                              : 'bg-green-100 text-green-700 hover:bg-green-200'
                          }`}
                          title={l.aktiv ? 'Inaktivera' : 'Aktivera'}
                        >
                          {l.aktiv ? '⏸️' : '▶️'}
                        </button>
                      </form>
                      
                      {/* Ta bort */}
                      <form method="POST" class="inline" onsubmit="return confirm('Vill du verkligen ta bort denna läkare?')">
                        <input type="hidden" name="action" value="ta_bort_lakare" />
                        <input type="hidden" name="lakare_id" value={l.id} />
                        <button 
                          type="submit"
                          class="px-2 py-1 text-xs bg-red-100 text-red-700 rounded hover:bg-red-200"
                          title="Ta bort"
                        >
                          🗑️
                        </button>
                      </form>
                    </div>
                  </div>
                ))}
                
                {lakare.length === 0 && (
                  <p class="text-gray-500 text-sm italic">Inga läkare tillagda ännu</p>
                )}
              </div>
            </div>
          </div>
        </section>
        
      </div>
      
      <!-- Info-ruta -->
      <div class="mt-8 bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h3 class="font-medium text-amber-900 mb-2">💡 Tips</h3>
        <ul class="text-sm text-amber-800 space-y-1 list-disc list-inside">
          <li>Nya användare kan logga in direkt med e-post och det tillfälliga lösenordet</li>
          <li>Roller lagras i Supabase Auth (<code>app_metadata.role</code>) och hanteras här för långsiktig säkerhet</li>
          <li><strong>Superadmin</strong> hanterar roller. Vanlig administratör kan fortsätta arbeta med användare, återställningslänkar och läkare.</li>
          <li>Det måste alltid finnas minst en superadmin i systemet</li>
          <li>Knappen <strong>Skicka återställningslänk</strong> använder det vanliga Supabase-flödet för glömt lösenord</li>
          <li>Be användare gå till <strong>Min profil</strong> för att lägga till sitt mobilnummer och aktivera notifikationer</li>
          <li>Läkare som är inaktiverade visas inte i Kort Varsel-dropdown:en</li>
          <li>Hovra över en profilbild och klicka på 📷 för att ladda upp en ny bild</li>
        </ul>
      </div>
      )}
      
    </main>
  </div>

  <script>
    // Hantera bilduppladdning
    let isUploading = false;
    
    document.querySelectorAll('.avatar-input').forEach(input => {
      input.addEventListener('change', async (e) => {
        // Förhindra dubbla uppladdningar
        if (isUploading) {
          (e.target as HTMLInputElement).value = '';
          return;
        }
        
        const target = e.target as HTMLInputElement;
        const file = target.files?.[0];
        const userId = target.dataset.userId;
        
        if (!file || !userId) {
          target.value = '';
          return;
        }
        
        // Kontrollera filstorlek tidigt (max 2MB)
        if (file.size > 2 * 1024 * 1024) {
          alert('Bilden är för stor. Max 2 MB.');
          target.value = '';
          return;
        }
        
        isUploading = true;
        
        // Hitta status-elementet
        const container = target.closest('[data-user-id]');
        const statusEl = container?.querySelector('.upload-status');
        const imgEl = container?.querySelector('.avatar-img') as HTMLImageElement;
        const placeholder = container?.querySelector('.text-gray-400');
        
        if (statusEl) {
          statusEl.classList.remove('hidden');
          statusEl.textContent = '⏳ Laddar upp...';
          statusEl.className = 'upload-status mt-2 text-xs text-blue-600';
        }
        
        try {
          const formData = new FormData();
          formData.append('userId', userId);
          formData.append('avatar', file);
          
          const response = await fetch('/api/admin/upload-avatar', {
            method: 'POST',
            body: formData,
            credentials: 'include'
          });
          
          const result = await response.json();
          
          if (result.success) {
            // Uppdatera bilden
            if (imgEl) {
              imgEl.src = result.avatarUrl + '?t=' + Date.now();
            } else if (placeholder) {
              const img = document.createElement('img');
              img.src = result.avatarUrl;
              img.alt = 'Profilbild';
              img.className = 'w-full h-full object-cover avatar-img';
              placeholder.replaceWith(img);
            }
            
            if (statusEl) {
              statusEl.textContent = '✅ Bild uppladdad!';
              statusEl.className = 'upload-status mt-2 text-xs text-green-600';
              setTimeout(() => statusEl.classList.add('hidden'), 3000);
            }
          } else {
            if (statusEl) {
              statusEl.textContent = '❌ ' + (result.error || 'Uppladdning misslyckades');
              statusEl.className = 'upload-status mt-2 text-xs text-red-600';
            }
          }
        } catch (error) {
          if (statusEl) {
            statusEl.textContent = '❌ Nätverksfel';
            statusEl.className = 'upload-status mt-2 text-xs text-red-600';
          }
        } finally {
          // Alltid återställ
          isUploading = false;
          target.value = '';
        }
      });
    });
  </script>
</PortalLayout>
