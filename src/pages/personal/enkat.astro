---
export const prerender = false;

import { arInloggad, hamtaAnvandare } from '../../lib/auth';
import { supabaseAdmin } from '../../lib/supabase';
import {
  formatExcludedBookingTypePatterns,
  getDefaultExcludedBookingTypePatternText
} from '../../lib/enkat-follow-up-rules';
import { harMinstPortalRoll } from '../../lib/portal-roles';

if (!await arInloggad(Astro.cookies)) {
  return Astro.redirect('/personal');
}

const anvandare = await hamtaAnvandare(Astro.cookies);
if (!anvandare) {
  return Astro.redirect('/personal');
}

const isAdmin = harMinstPortalRoll(anvandare.roll, 'admin');
const defaultExcludedBookingTypePatternsText = getDefaultExcludedBookingTypePatternText();
let initialExcludedBookingTypePatternsText = defaultExcludedBookingTypePatternsText;
let sharedTemplateHelperText = isAdmin
  ? 'Listan lagras i Supabase och används som gemensam lista för vilka bokningstyper som alltid ska sorteras bort.'
  : 'Listan hämtas från Supabase. Du kan läsa och använda den här, men endast administratör kan spara ändringar.';

try {
  const { data, error } = await supabaseAdmin
    .from('enkat_installningar')
    .select('exkludera_bokningstyper, updated_at')
    .eq('id', 'standard')
    .maybeSingle();

  if (error) {
    sharedTemplateHelperText = isAdmin
      ? 'Visar inbyggd lista. Kör SQL-migreringen för att kunna spara den gemensamt i Supabase.'
      : 'Visar inbyggd lista. En administratör behöver köra SQL-migreringen för att aktivera gemensam lagring i Supabase.';
  } else if (data) {
    initialExcludedBookingTypePatternsText = formatExcludedBookingTypePatterns(data.exkludera_bokningstyper);
  }
} catch (error) {
  console.warn('Kunde inte läsa gemensam enkätsmall från Supabase:', error);
  sharedTemplateHelperText = isAdmin
    ? 'Visar inbyggd lista. Kör SQL-migreringen för att kunna spara den gemensamt i Supabase.'
    : 'Visar inbyggd lista. En administratör behöver köra SQL-migreringen för att aktivera gemensam lagring i Supabase.';
}
import PortalLayout from '../../layouts/PortalLayout.astro';
---

<PortalLayout
  title="Patientupplevelse"
  activePath="/personal/enkat"
  email={anvandare.email}
  role={anvandare.roll}
  userId={anvandare.id}
  userName={anvandare.namn}
>
  <style>
    :root {
      --bg: #f8fafc;
      --card: #ffffff;
      --text: #0f172a;
      --muted: #64748b;
      --line: #e2e8f0;
      --primary: #0284c7;
      --primary-soft: #e0f2fe;
      --success: #059669;
      --success-soft: #d1fae5;
      --warning: #d97706;
      --warning-soft: #fef3c7;
      --danger: #dc2626;
      --danger-soft: #fee2e2;
    }

    * { box-sizing: border-box; }

    .page {
      max-width: 1200px;
      margin: 0 auto;
      padding: 24px 16px 48px;
    }

    .header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 16px;
      margin-bottom: 24px;
      flex-wrap: wrap;
    }

    h1 {
      margin: 0 0 8px;
      font-size: 28px;
      line-height: 1.1;
    }

    .page-intro {
      max-width: 760px;
      margin: 0;
      color: var(--muted);
      font-size: 15px;
      line-height: 1.6;
    }

    .grid {
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      gap: 20px;
    }

    .card {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 20px;
      box-shadow: 0 10px 30px rgba(15, 23, 42, 0.04);
    }

    .import-card {
      grid-column: 1 / -1;
    }

    .booking-types-card {
      grid-column: 1;
      align-self: start;
    }

    .settings-card {
      grid-column: 2;
      align-self: start;
    }

    .card h2, .card h3 {
      margin: 0 0 12px;
    }

    .helper {
      color: var(--muted);
      font-size: 14px;
      line-height: 1.5;
    }

    .card-intro {
      margin: 0;
      color: var(--muted);
      font-size: 14px;
      line-height: 1.5;
    }

    .dropzone {
      border: 2px dashed #93c5fd;
      background: #f8fbff;
      border-radius: 16px;
      padding: 28px;
      text-align: center;
      transition: all 0.15s ease;
      cursor: pointer;
      position: relative;
    }
    /* already patched */

    .dropzone-clear {
      position: absolute;
      top: 10px;
      right: 10px;
      background: none;
      border: 1px solid transparent;
      border-radius: 8px;
      padding: 6px;
      cursor: pointer;
      color: #94a3b8;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.15s ease;
    }

    .dropzone-clear:hover {
      color: #ef4444;
      background: #fee2e2;
      border-color: #fecaca;
    }

    .dropzone-clear.hidden {
      display: none;
    }

    .dropzone.dragover {
      border-color: var(--primary);
      background: var(--primary-soft);
    }

    .dropzone strong {
      display: block;
      font-size: 16px;
      margin-bottom: 6px;
    }

    .dropzone p {
      margin: 0;
      color: var(--muted);
      font-size: 14px;
    }

    .dropzone-file-name {
      margin-top: 10px;
      display: inline-block;
      padding: 6px 10px;
      border-radius: 999px;
      border: 1px solid #bfdbfe;
      background: #eff6ff;
      color: #475569;
      font-size: 13px;
      font-weight: 500;
    }

    .dropzone-file-name.has-file {
      color: #0f172a;
      border-color: #93c5fd;
      background: #dbeafe;
    }

    .form-group {
      margin-top: 16px;
    }

    .form-group label {
      display: block;
      margin-bottom: 8px;
      font-weight: 600;
      font-size: 14px;
    }

    .input, .file-input {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 12px 14px;
      font-size: 15px;
      background: white;
    }

    .actions {
      display: flex;
      gap: 12px;
      margin-top: 20px;
      flex-wrap: wrap;
    }

    .btn {
      border: none;
      border-radius: 12px;
      padding: 12px 16px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: transform 0.12s ease, opacity 0.12s ease;
    }

    .btn:hover { transform: translateY(-1px); }
    .btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
    .btn-primary { background: var(--primary); color: white; }
    .btn-secondary { background: #eef2ff; color: #1e293b; }

    .banner {
      display: none;
      margin-top: 16px;
      padding: 12px 14px;
      border-radius: 12px;
      font-size: 14px;
      line-height: 1.45;
      border: 1px solid transparent;
    }

    .banner.visible { display: block; }
    .banner.info { background: #eff6ff; color: #1d4ed8; border-color: #bfdbfe; }
    .banner.error { background: var(--danger-soft); color: var(--danger); border-color: #fecaca; }
    .banner.success { background: var(--success-soft); color: var(--success); border-color: #a7f3d0; }

    .summary-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
      margin-top: 16px;
    }

    #summaryGrid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
    }

    #summaryGrid .summary-card {
      padding: 12px;
    }

    #summaryGrid .summary-value {
      font-size: 24px;
    }

    .summary-card {
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 14px;
      background: #fbfdff;
    }

    .summary-label {
      color: var(--muted);
      font-size: 13px;
      margin-bottom: 4px;
    }

    .summary-value {
      font-size: 28px;
      font-weight: 700;
    }

    .section {
      margin-top: 20px;
    }

    .table-wrap {
      overflow: auto;
      border: 1px solid var(--line);
      border-radius: 14px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px;
    }

    th, td {
      padding: 12px;
      border-bottom: 1px solid var(--line);
      text-align: left;
      vertical-align: top;
    }

    th {
      background: #f8fafc;
      font-size: 13px;
      color: var(--muted);
      position: sticky;
      top: 0;
    }

    .pill {
      display: inline-block;
      padding: 4px 8px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 600;
    }

    .pill.info { background: var(--primary-soft); color: var(--primary); }
    .pill.warn { background: var(--warning-soft); color: var(--warning); }
    .pill.ok { background: var(--success-soft); color: var(--success); }

    .muted-box {
      margin-top: 20px;
      background: #f8fafc;
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 16px;
      color: var(--muted);
      font-size: 14px;
      line-height: 1.5;
    }

    .workflow-box {
      margin-top: 20px;
      background: linear-gradient(180deg, #f8fbff 0%, #f8fafc 100%);
      border: 1px solid #dbeafe;
      border-radius: 16px;
      padding: 16px;
    }

    .workflow-title {
      margin: 0 0 12px;
      color: var(--text);
      font-size: 14px;
      font-weight: 700;
    }

    .workflow-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: 10px;
    }

    .workflow-step {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 10px 12px;
      background: #ffffff;
      border: 1px solid var(--line);
      border-radius: 12px;
      color: var(--text);
      font-weight: 500;
    }

    .workflow-step-number {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 26px;
      height: 26px;
      border-radius: 999px;
      background: var(--primary-soft);
      color: var(--primary);
      font-size: 13px;
      font-weight: 700;
      flex-shrink: 0;
    }

    .workflow-note {
      margin: 12px 0 0;
      color: var(--muted);
      font-size: 14px;
      line-height: 1.5;
    }

    .rule-preview-list {
      display: grid;
      gap: 10px;
      margin-top: 14px;
    }

    .rule-preview-item {
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 12px;
      background: white;
    }

    .rule-preview-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
    }

    .rule-preview-top strong {
      line-height: 1.4;
    }

    .booking-type-option {
      display: flex;
      align-items: flex-start;
      gap: 12px;
    }

    .booking-type-option input[type='checkbox'] {
      margin-top: 2px;
      width: 16px;
      height: 16px;
      flex-shrink: 0;
    }

    .booking-type-option-main {
      flex: 1;
      min-width: 0;
    }

    .booking-type-option-title {
      font-weight: 600;
      line-height: 1.4;
      color: var(--text);
    }

    .selection-placeholder {
      margin-top: 16px;
      border: 1px dashed #cbd5e1;
      border-radius: 14px;
      padding: 16px;
      background: #f8fafc;
      color: var(--muted);
      font-size: 14px;
      line-height: 1.5;
    }

    #bookingTypeSelectionBox:not(.hidden) + #bookingTypeSelectionPlaceholder {
      display: none;
    }

    .settings-panel {
      margin-top: 20px;
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 18px;
      background: linear-gradient(180deg, #fbfdff 0%, #ffffff 100%);
    }

    .field-grid-2 {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }

    .field-label {
      display: block;
      margin-bottom: 8px;
      font-weight: 600;
      font-size: 14px;
    }

    .toggle-row {
      display: flex;
      align-items: center;
      gap: 10px;
      width: fit-content;
      padding: 10px 12px;
      border: 1px solid var(--line);
      border-radius: 12px;
      background: #f8fafc;
      color: var(--muted);
      font-size: 14px;
    }

    .toolbar-select {
      max-width: 260px;
    }

    .toolbar-select.narrow {
      max-width: 220px;
    }

    .data-card {
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 18px;
      background: linear-gradient(180deg, #ffffff 0%, #fcfdff 100%);
      box-shadow: 0 8px 22px rgba(15, 23, 42, 0.04);
    }

    .data-card-header {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: flex-start;
      flex-wrap: wrap;
    }

    .data-card-title {
      margin: 0 0 4px;
      color: var(--text);
      font-size: 18px;
      line-height: 1.3;
    }

    .data-card-subtitle {
      color: var(--muted);
      font-size: 13px;
      line-height: 1.4;
    }

    .metric-grid-4 {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 10px;
      margin-top: 14px;
    }

    .metric-grid-4 .summary-card {
      padding: 12px;
    }

    .data-card--metrics .metric-grid-4 .summary-value {
      font-size: 22px;
    }

    .data-card--campaign .metric-grid-4 .summary-value {
      font-size: 20px;
    }

    .meta-list {
      display: grid;
      gap: 6px;
      margin-top: 12px;
      color: var(--muted);
      font-size: 14px;
      line-height: 1.45;
    }

    .comment-grid {
      display: grid;
      gap: 10px;
      margin-top: 14px;
    }

    .comment-card {
      padding: 10px 12px;
      border: 1px solid var(--line);
      border-radius: 12px;
      background: #ffffff;
    }

    .comment-label {
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 4px;
    }

    .link-stack {
      display: grid;
      gap: 8px;
    }

    .link-card {
      border: 1px solid var(--line);
      border-radius: 10px;
      padding: 8px 10px;
      background: #f8fafc;
    }

    .link-card a {
      font-size: 13px;
      line-height: 1.4;
      word-break: break-all;
    }

    .details-toggle {
      cursor: pointer;
      color: var(--muted);
      font-size: 13px;
    }

    .template-panel {
      margin-top: 8px;
      white-space: pre-wrap;
      word-break: break-word;
      background: #f8fafc;
      border: 1px solid var(--line);
      border-radius: 10px;
      padding: 10px;
      font-size: 13px;
      line-height: 1.45;
    }

    .card-list {
      display: grid;
      gap: 16px;
    }

    .empty-note {
      margin-top: 14px;
      color: var(--muted);
      font-size: 14px;
    }

    .history-card {
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 16px;
      background: #fff;
    }

    .hidden { display: none; }

    .import-layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(260px, 320px);
      gap: 20px;
      align-items: start;
    }

    .csv-cols-block {
      margin: 12px 0 0;
    }

    .csv-cols-intro {
      margin: 0 0 10px;
      color: var(--muted);
      font-size: 14px;
      line-height: 1.5;
    }

    .csv-cols-row {
      display: grid;
      grid-template-columns: repeat(6, minmax(0, 1fr));
      gap: 0;
      border: 1px solid #cbd5e1;
      border-radius: 10px;
      overflow: hidden;
      background: #fff;
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.8);
    }

    .csv-col-cell {
      padding: 10px 8px;
      font-size: 12px;
      font-weight: 600;
      color: var(--text);
      text-align: center;
      background: linear-gradient(180deg, #f1f5f9 0%, #e8eef4 100%);
      border-right: 1px solid #cbd5e1;
      border-bottom: 1px solid #cbd5e1;
      line-height: 1.3;
      word-break: break-word;
    }

    .csv-col-cell:last-child {
      border-right: none;
    }

    .csv-cols-note {
      margin: 10px 0 0;
    }

    .import-upload {
      width: 100%;
    }

    .import-upload .dropzone {
      min-height: 170px;
      padding: 18px 18px 16px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .import-upload .dropzone strong {
      font-size: 15px;
    }

    .import-upload .dropzone p {
      font-size: 13px;
    }

    .import-upload .dropzone-file-name {
      max-width: 100%;
      overflow-wrap: anywhere;
    }

    @media (max-width: 900px) {
      .import-layout {
        grid-template-columns: 1fr;
      }

      .csv-cols-row {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .csv-col-cell:nth-child(3n) {
        border-right: none;
      }

      .csv-col-cell:not(:nth-last-child(-n + 3)) {
        border-bottom: 1px solid #cbd5e1;
      }

      .grid { grid-template-columns: 1fr; }
      .booking-types-card,
      .settings-card {
        grid-column: 1;
      }
      .field-grid-2,
      .metric-grid-4 {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .summary-grid { grid-template-columns: 1fr 1fr; }
    }

    @media (max-width: 640px) {
      .page { padding: 16px 12px 40px; }
      h1 { font-size: 28px; }
      .summary-grid { grid-template-columns: 1fr; }
      #summaryGrid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .field-grid-2,
      .metric-grid-4 {
        grid-template-columns: 1fr;
      }
      .toolbar-select,
      .toolbar-select.narrow {
        max-width: none;
      }
      .toggle-row {
        width: 100%;
      }
    }
  </style>
  <div class="page">

    <div class="header">
      <div>
        <h1>Patientupplevelse via SMS</h1>
        <p class="page-intro">
          Importera en CSV, filtrera bort irrelevanta bokningstyper och skapa enkätutskick utan att lämna sidan.
        </p>
      </div>
    </div>

    <div class="grid">
      <section class="card import-card">
        <h2>1. Importera CSV-fil</h2>
        <div class="import-layout">
          <div class="csv-cols-block">
            <p class="csv-cols-intro">Kolumnerna som måste finnas:</p>
            <div class="csv-cols-row" aria-label="Obligatoriska kolumnnamn">
              <span class="csv-col-cell">Patient-ID</span>
              <span class="csv-col-cell">Mobiltelefon</span>
              <span class="csv-col-cell">Vårdgivare</span>
              <span class="csv-col-cell">Datum</span>
              <span class="csv-col-cell">Bokningstyp</span>
              <span class="csv-col-cell">Diagnoser</span>
            </div>
            <p class="helper csv-cols-note">Rader utan diagnos sorteras bort. <code>Starttid</code> är valfri.</p>
          </div>

          <form id="uploadForm" class="import-upload">
            <input id="fileInput" name="file" type="file" accept=".csv,.txt" required hidden />

            <div class="dropzone" id="dropzone" role="button" tabindex="0" aria-label="Ladda upp CSV-fil genom att klicka eller dra in en fil">
              <button type="button" class="dropzone-clear hidden" id="clearBtn" title="Ta bort vald fil" aria-label="Ta bort vald fil">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
              </button>
              <strong>Dra in CSV-fil här</strong>
              <p>eller klicka för att välja. CSV/TXT stöds.</p>
              <span id="fileName" class="dropzone-file-name" aria-live="polite">Ingen fil har valts</span>
            </div>
          </form>
        </div>

        <div id="statusBanner" class="banner info"></div>

        <div class="workflow-box">
          <p class="workflow-title">Fortsätt med att:</p>
          <ol class="workflow-list">
            <li class="workflow-step"><span class="workflow-step-number">1</span><span>Förhandsgranska filen</span></li>
            <li class="workflow-step"><span class="workflow-step-number">2</span><span>Sortera bort bokningstyper</span></li>
            <li class="workflow-step"><span class="workflow-step-number">3</span><span>Skicka SMS</span></li>
          </ol>
          <p class="workflow-note">För större kampanjer används en kömodell.</p>
        </div>
      </section>

      <section class="card booking-types-card">
        <h3>Bokningstyper i denna fil</h3>
        <p class="card-intro">
          Markera de bokningstyper som ska ingå i just detta utskick. Alla är ikryssade första gången filen läses in.
        </p>

        <div class="muted-box hidden" id="bookingTypeSelectionBox">
          <div class="actions" style="margin-top: 0;">
            <button type="button" class="btn btn-secondary" id="selectAllBookingTypesBtn">Markera alla</button>
            <button type="button" class="btn btn-secondary" id="clearAllBookingTypesBtn">Avmarkera alla</button>
          </div>
          <div class="rule-preview-list" id="bookingTypeSelectionList"></div>
        </div>
        <div class="selection-placeholder" id="bookingTypeSelectionPlaceholder">
          Läs in en fil för att se vilka bokningstyper som går att välja för just detta utskick.
        </div>
      </section>

      <aside class="card settings-card">
        <h3>Bokningstyper som aldrig ska följas upp</h3>
        <p class="card-intro">
          Skriv en bokningstyp per rad. Om texten matchar en bokningstyp i filen sorteras raden bort automatiskt före previewn.
        </p>

        <div class="form-group" style="margin-top: 12px;">
          <label for="excludedBookingTypePatterns">Lista som alltid sorteras bort</label>
          <textarea
            id="excludedBookingTypePatterns"
            name="excludedBookingTypePatterns"
            class="input"
            style="min-height: 180px;"
            data-default-value={initialExcludedBookingTypePatternsText}
          >{initialExcludedBookingTypePatternsText}</textarea>
        </div>

        <div class="actions" style="margin-top: 12px;">
          <button type="button" class="btn btn-secondary" id="resetExcludedBookingTypesBtn">Återställ sparad lista</button>
          <button
            type="button"
            class="btn btn-primary"
            id="saveExcludedBookingTypesBtn"
            disabled={!isAdmin}
            title={isAdmin ? 'Spara listan så att samma bokningstyper sorteras bort för alla användare' : 'Endast administratör kan spara listan för alla användare'}
          >
            Spara lista för alla
          </button>
        </div>

        <div id="excludedBookingTypeSettingsStatus" class="banner visible info" style="margin-top: 12px;">
          {sharedTemplateHelperText}
        </div>

        <div class="muted-box hidden" id="excludedBookingTypesSummaryBox">
          <strong>Sorterades bort före preview</strong>
          <p class="helper" style="margin: 8px 0 0;">
            Dessa rader togs bort automatiskt, antingen för att bokningstypen finns i listan ovan eller för att diagnos saknades.
          </p>
          <div class="rule-preview-list" id="excludedBookingTypesSummary"></div>
        </div>
      </aside>
    </div>

    <section class="card section hidden" id="previewSection">
      <h2>2. Förhandsgranskning</h2>

      <div class="section settings-panel">
        <h3>3. Kampanjinställningar</h3>
        <div class="field-grid-2">
          <div>
            <label for="campaignName" class="field-label">Kampanjnamn</label>
            <input id="campaignName" class="input" type="text" placeholder="T.ex. Patientupplevelse vecka 11" />
          </div>
          <div>
            <label for="reminderHours" class="field-label">Påminn efter (timmar)</label>
            <input id="reminderHours" class="input" type="number" min="1" value="48" />
          </div>
        </div>

        <div class="form-group">
          <label for="smsTemplate">SMS-mall</label>
          <textarea id="smsTemplate" class="input" style="min-height:120px;">Hej! Hur nöjd var du med ditt besök hos [VÅRDGIVARE] den [DATUM]?
Svara här: [LÄNK]
Enkäten är anonym. Tack!</textarea>
        </div>

        <div class="actions">
          <label class="toggle-row">
            <input id="sendReminder" type="checkbox" checked />
            Skicka påminnelse till obesvarade
          </label>
        </div>

        <div class="actions">
          <button type="button" class="btn btn-primary" id="createCampaignBtn">Skapa kampanj</button>
        </div>
      </div>

      <div class="section">
        <h3>Valda rader</h3>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Rad</th>
                <th>Patient-ID</th>
                <th>Vårdgivare</th>
                <th>Datum</th>
                <th>Starttid</th>
                <th>Bokningstyp</th>
                <th>Klass</th>
              </tr>
            </thead>
            <tbody id="selectedRowsBody"></tbody>
          </table>
        </div>
      </div>

      <div class="section">
        <h3>Dubletter</h3>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Nyckel</th>
                <th>Behållen rad</th>
                <th>Bortvalda rader</th>
                <th>Motivering</th>
              </tr>
            </thead>
            <tbody id="duplicatesBody"></tbody>
          </table>
        </div>
      </div>

      <div class="section">
        <h3>Felrader</h3>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Rad</th>
                <th>Fält</th>
                <th>Fel</th>
              </tr>
            </thead>
            <tbody id="errorsBody"></tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="card section">
      <h2>Resultatöversikt</h2>
      <p class="card-intro">
        Vårdgivare ser bara sina egna resultat. Administratörer ser alla vårdgivare sida vid sida.
      </p>
      {isAdmin && (
        <div class="actions">
          <select id="dashboardProviderFilter" class="input toolbar-select">
            <option value="">Alla vårdgivare</option>
          </select>
        </div>
      )}
      <div id="dashboardBanner" class="banner visible info">Laddar resultatöversikt...</div>
      <div id="dashboardContent" class="section"></div>
    </section>

    <section class="card section">
      <h2>Kampanjhistorik</h2>
      <p class="card-intro">Visar de senaste enkätkampanjerna och om det finns obesvarade utskick som kan få en påminnelse.</p>
      <div class="actions">
        <button type="button" class="btn btn-secondary" id="refreshCampaignsBtn">Uppdatera historik</button>
      </div>
      <div id="campaignsBanner" class="banner visible info">Laddar kampanjhistorik...</div>
      <div id="campaignsContent" class="section"></div>
    </section>

    <section class="card section">
      <h2>Rapport</h2>
      <p class="card-intro">En enkel periodsammanfattning för de senaste 7, 30 eller 90 dagarna.</p>
      <div class="actions">
        {isAdmin && (
          <select id="reportProviderFilter" class="input toolbar-select">
            <option value="">Alla vårdgivare</option>
          </select>
        )}
        <select id="reportPeriod" class="input toolbar-select narrow">
          <option value="week">Senaste 7 dagarna</option>
          <option value="month" selected>Senaste 30 dagarna</option>
          <option value="quarter">Senaste 90 dagarna</option>
        </select>
        <button type="button" class="btn btn-secondary" id="refreshReportBtn">Uppdatera rapport</button>
      </div>
      <div id="reportBanner" class="banner visible info">Laddar rapport...</div>
      <div id="reportContent" class="section"></div>
    </section>

  <script>
    import {
      normalizePatternText,
      setElementBanner
    } from '../../lib/enkat-page-helpers';
    import { createEnkatPreviewUi } from '../../lib/enkat-page-preview';
    import {
      createCampaignAction,
      saveExcludedBookingTypesAction,
      submitPreviewAction
    } from '../../lib/enkat-page-actions';
    import {
      loadCampaignHistorySection,
      loadDashboardSection,
      loadReportSection
    } from '../../lib/enkat-page-sections';

    type BannerType = 'info' | 'error' | 'success';

    const form = document.getElementById('uploadForm') as HTMLFormElement;
    const fileInput = document.getElementById('fileInput') as HTMLInputElement;
    const fileName = document.getElementById('fileName') as HTMLElement;
    const clearBtn = document.getElementById('clearBtn') as HTMLButtonElement;
    const dropzone = document.getElementById('dropzone') as HTMLElement;
    const previewSection = document.getElementById('previewSection') as HTMLElement;
    const statusBanner = document.getElementById('statusBanner') as HTMLElement;
    const excludedBookingTypePatternsInput = document.getElementById('excludedBookingTypePatterns') as HTMLTextAreaElement;
    const resetExcludedBookingTypesBtn = document.getElementById('resetExcludedBookingTypesBtn') as HTMLButtonElement;
    const saveExcludedBookingTypesBtn = document.getElementById('saveExcludedBookingTypesBtn') as HTMLButtonElement;
    const excludedBookingTypeSettingsStatus = document.getElementById('excludedBookingTypeSettingsStatus') as HTMLElement;
    const bookingTypeSelectionBox = document.getElementById('bookingTypeSelectionBox') as HTMLElement;
    const bookingTypeSelectionList = document.getElementById('bookingTypeSelectionList') as HTMLElement;
    const selectAllBookingTypesBtn = document.getElementById('selectAllBookingTypesBtn') as HTMLButtonElement | null;
    const clearAllBookingTypesBtn = document.getElementById('clearAllBookingTypesBtn') as HTMLButtonElement | null;
    const excludedBookingTypesSummaryBox = document.getElementById('excludedBookingTypesSummaryBox') as HTMLElement;
    const excludedBookingTypesSummary = document.getElementById('excludedBookingTypesSummary') as HTMLElement;
    const selectedRowsBody = document.getElementById('selectedRowsBody') as HTMLTableSectionElement;
    const duplicatesBody = document.getElementById('duplicatesBody') as HTMLTableSectionElement;
    const errorsBody = document.getElementById('errorsBody') as HTMLTableSectionElement;
    const createCampaignBtn = document.getElementById('createCampaignBtn') as HTMLButtonElement | null;
    const campaignNameInput = document.getElementById('campaignName') as HTMLInputElement;
    const smsTemplateInput = document.getElementById('smsTemplate') as HTMLInputElement | HTMLTextAreaElement;
    const sendReminderInput = document.getElementById('sendReminder') as HTMLInputElement;
    const reminderHoursInput = document.getElementById('reminderHours') as HTMLInputElement;
    const dashboardBanner = document.getElementById('dashboardBanner') as HTMLElement;
    const dashboardContent = document.getElementById('dashboardContent') as HTMLElement;
    const dashboardProviderFilter = document.getElementById('dashboardProviderFilter') as HTMLSelectElement | null;
    const campaignsBanner = document.getElementById('campaignsBanner') as HTMLElement;
    const campaignsContent = document.getElementById('campaignsContent') as HTMLElement;
    const refreshCampaignsBtn = document.getElementById('refreshCampaignsBtn') as HTMLButtonElement | null;
    const reportBanner = document.getElementById('reportBanner') as HTMLElement;
    const reportContent = document.getElementById('reportContent') as HTMLElement;
    const reportPeriod = document.getElementById('reportPeriod') as HTMLSelectElement;
    const reportProviderFilter = document.getElementById('reportProviderFilter') as HTMLSelectElement | null;
    const refreshReportBtn = document.getElementById('refreshReportBtn') as HTMLButtonElement | null;

    if (!campaignNameInput.value.trim()) {
      campaignNameInput.value = `Patientupplevelse ${new Date().toLocaleDateString('sv-SE')}`;
    }

    function setBanner(type: BannerType, message: string) {
      setElementBanner(statusBanner, type, message);
    }

    function setExcludedBookingTypeSettingsStatus(type: BannerType, message: string) {
      setElementBanner(excludedBookingTypeSettingsStatus, type, message);
    }

    const previewUi = createEnkatPreviewUi({
      fileInput,
      fileName,
      previewSection,
      selectedRowsBody,
      duplicatesBody,
      errorsBody,
      bookingTypeSelectionBox,
      bookingTypeSelectionList,
      excludedBookingTypesSummaryBox,
      excludedBookingTypesSummary
    }, setBanner);

    async function runAutoPreview() {
      if (!fileInput.files?.length) return;
      await submitPreviewAction({
        form,
        fileInput,
        excludedBookingTypePatternsInput,
        previewUi,
        setBanner
      });
    }

    function syncClearButton() {
      clearBtn.classList.toggle('hidden', !fileInput.files?.length);
    }

    dropzone.addEventListener('click', (event: MouseEvent) => {
      if ((event.target as HTMLElement).closest('.dropzone-clear')) return;
      previewUi.openFilePicker();
    });
    dropzone.addEventListener('keydown', (event: KeyboardEvent) => {
      if (event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        previewUi.openFilePicker();
      }
    });

    dropzone.addEventListener('dragover', (event: DragEvent) => {
      event.preventDefault();
      dropzone.classList.add('dragover');
    });

    dropzone.addEventListener('dragleave', () => {
      dropzone.classList.remove('dragover');
    });

    dropzone.addEventListener('drop', (event: DragEvent) => {
      event.preventDefault();
      dropzone.classList.remove('dragover');
      if (event.dataTransfer?.files?.length) {
        fileInput.files = event.dataTransfer.files;
        previewUi.syncSelectedFileName();
        syncClearButton();
        void runAutoPreview();
      }
    });

    fileInput.addEventListener('change', () => {
      previewUi.syncSelectedFileName();
      syncClearButton();
      void runAutoPreview();
    });

    selectAllBookingTypesBtn?.addEventListener('click', () => {
      const checkboxes = previewUi.getBookingTypeCheckboxes();
      if (!checkboxes.length) return;
      checkboxes.forEach((input) => { input.checked = true; });
      void runAutoPreview();
    });

    clearAllBookingTypesBtn?.addEventListener('click', () => {
      const checkboxes = previewUi.getBookingTypeCheckboxes();
      if (!checkboxes.length) return;
      checkboxes.forEach((input) => { input.checked = false; });
      void runAutoPreview();
    });

    let excludedPatternsDebounce: ReturnType<typeof setTimeout> | null = null;
    excludedBookingTypePatternsInput?.addEventListener('input', () => {
      if (excludedPatternsDebounce) clearTimeout(excludedPatternsDebounce);
      previewUi.clearPreview();
      excludedPatternsDebounce = setTimeout(() => {
        if (fileInput.files?.length) void runAutoPreview();
      }, 400);
    });

    resetExcludedBookingTypesBtn?.addEventListener('click', () => {
      excludedBookingTypePatternsInput.value = normalizePatternText(excludedBookingTypePatternsInput.dataset.defaultValue || '');
      setExcludedBookingTypeSettingsStatus('info', 'Listan återställdes till senast sparade värde.');
      if (fileInput.files?.length) void runAutoPreview();
    });

    saveExcludedBookingTypesBtn?.addEventListener('click', async () => {
      await saveExcludedBookingTypesAction({
        button: saveExcludedBookingTypesBtn,
        input: excludedBookingTypePatternsInput,
        setStatus: setExcludedBookingTypeSettingsStatus
      });
    });

    clearBtn.addEventListener('click', (event: MouseEvent) => {
      event.stopPropagation();
      form.reset();
      previewUi.syncSelectedFileName();
      syncClearButton();
      statusBanner.className = 'banner info';
      statusBanner.textContent = '';
      previewUi.clearAnalysis();
    });

    previewUi.syncSelectedFileName();
    syncClearButton();

    form.addEventListener('submit', async (event: SubmitEvent) => {
      event.preventDefault();
      await runAutoPreview();
    });

    createCampaignBtn?.addEventListener('click', async () => {
      await createCampaignAction({
        button: createCampaignBtn,
        campaignNameInput,
        smsTemplateInput,
        sendReminderInput,
        reminderHoursInput,
        previewUi,
        setBanner,
        afterCreate: () => {
          void loadCampaignHistory();
          void loadDashboard();
          void loadReport();
        }
      });
    });

    const loadDashboard = () => loadDashboardSection({
      bannerEl: dashboardBanner,
      contentEl: dashboardContent,
      providerFilterEl: dashboardProviderFilter
    });

    dashboardProviderFilter?.addEventListener('change', () => {
      void loadDashboard();
    });

    const loadCampaignHistory = () => loadCampaignHistorySection({
      bannerEl: campaignsBanner,
      contentEl: campaignsContent,
      afterReminderSent: loadDashboard
    });

    refreshCampaignsBtn?.addEventListener('click', () => {
      void loadCampaignHistory();
    });

    const loadReport = () => loadReportSection({
      bannerEl: reportBanner,
      contentEl: reportContent,
      periodEl: reportPeriod,
      providerFilterEl: reportProviderFilter
    });

    refreshReportBtn?.addEventListener('click', () => {
      void loadReport();
    });

    reportProviderFilter?.addEventListener('change', () => {
      void loadReport();
    });

    void loadDashboard();
    void loadCampaignHistory();
    void loadReport();
  </script>
  </div>
</PortalLayout>
