---
export const prerender = false;

import { arInloggad, hamtaAnvandare } from '../../lib/auth';

if (!await arInloggad(Astro.cookies)) {
  return Astro.redirect('/personal');
}

const anvandare = await hamtaAnvandare(Astro.cookies);
if (!anvandare) {
  return Astro.redirect('/personal');
}

const isAdmin = anvandare.roll === 'admin';
---

<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title>Patientupplevelse | Personalportal</title>
  <link rel="icon" type="image/svg+xml" href="/favicons/favicon.svg">
  <style>
    :root {
      --bg: #f8fafc;
      --card: #ffffff;
      --text: #0f172a;
      --muted: #64748b;
      --line: #e2e8f0;
      --primary: #0284c7;
      --primary-soft: #e0f2fe;
      --success: #059669;
      --success-soft: #d1fae5;
      --warning: #d97706;
      --warning-soft: #fef3c7;
      --danger: #dc2626;
      --danger-soft: #fee2e2;
    }

    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: var(--bg);
      color: var(--text);
    }

    .page {
      max-width: 1200px;
      margin: 0 auto;
      padding: 24px 16px 48px;
    }

    .header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 16px;
      margin-bottom: 24px;
      flex-wrap: wrap;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      text-decoration: none;
      color: var(--muted);
      font-size: 14px;
      margin-bottom: 12px;
    }

    h1 {
      margin: 0 0 8px;
      font-size: 32px;
      line-height: 1.1;
    }

    .subtitle {
      margin: 0;
      color: var(--muted);
      max-width: 820px;
      line-height: 1.5;
    }

    .role-chip {
      background: #0f172a;
      color: white;
      border-radius: 999px;
      padding: 8px 12px;
      font-size: 13px;
      white-space: nowrap;
    }

    .grid {
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      gap: 20px;
    }

    .card {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 20px;
      box-shadow: 0 10px 30px rgba(15, 23, 42, 0.04);
    }

    .card h2, .card h3 {
      margin: 0 0 12px;
    }

    .helper {
      color: var(--muted);
      font-size: 14px;
      line-height: 1.5;
    }

    .dropzone {
      border: 2px dashed #93c5fd;
      background: #f8fbff;
      border-radius: 16px;
      padding: 28px;
      text-align: center;
      transition: all 0.15s ease;
    }

    .dropzone.dragover {
      border-color: var(--primary);
      background: var(--primary-soft);
    }

    .dropzone strong {
      display: block;
      font-size: 16px;
      margin-bottom: 6px;
    }

    .dropzone p {
      margin: 0;
      color: var(--muted);
      font-size: 14px;
    }

    .form-group {
      margin-top: 16px;
    }

    .form-group label {
      display: block;
      margin-bottom: 8px;
      font-weight: 600;
      font-size: 14px;
    }

    .input, .file-input {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 12px 14px;
      font-size: 15px;
      background: white;
    }

    .file-picker {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
    }

    .file-picker-name {
      font-size: 14px;
      color: var(--muted);
    }

    .file-picker-name.has-file {
      color: var(--text);
      font-weight: 500;
    }

    .actions {
      display: flex;
      gap: 12px;
      margin-top: 20px;
      flex-wrap: wrap;
    }

    .btn {
      border: none;
      border-radius: 12px;
      padding: 12px 16px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: transform 0.12s ease, opacity 0.12s ease;
    }

    .btn:hover { transform: translateY(-1px); }
    .btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
    .btn-primary { background: var(--primary); color: white; }
    .btn-secondary { background: #eef2ff; color: #1e293b; }

    .banner {
      display: none;
      margin-top: 16px;
      padding: 12px 14px;
      border-radius: 12px;
      font-size: 14px;
      line-height: 1.45;
    }

    .banner.visible { display: block; }
    .banner.info { background: #eff6ff; color: #1d4ed8; }
    .banner.error { background: var(--danger-soft); color: var(--danger); }
    .banner.success { background: var(--success-soft); color: var(--success); }

    .summary-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
      margin-top: 16px;
    }

    .summary-card {
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 14px;
      background: #fbfdff;
    }

    .summary-label {
      color: var(--muted);
      font-size: 13px;
      margin-bottom: 4px;
    }

    .summary-value {
      font-size: 28px;
      font-weight: 700;
    }

    .section {
      margin-top: 20px;
    }

    .table-wrap {
      overflow: auto;
      border: 1px solid var(--line);
      border-radius: 14px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px;
    }

    th, td {
      padding: 12px;
      border-bottom: 1px solid var(--line);
      text-align: left;
      vertical-align: top;
    }

    th {
      background: #f8fafc;
      font-size: 13px;
      color: var(--muted);
      position: sticky;
      top: 0;
    }

    .pill {
      display: inline-block;
      padding: 4px 8px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 600;
    }

    .pill.info { background: var(--primary-soft); color: var(--primary); }
    .pill.warn { background: var(--warning-soft); color: var(--warning); }
    .pill.ok { background: var(--success-soft); color: var(--success); }

    .muted-box {
      margin-top: 20px;
      background: #f8fafc;
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 16px;
      color: var(--muted);
      font-size: 14px;
      line-height: 1.5;
    }

    .intro-box {
      margin: 0 0 20px;
    }

    .intro-box h2 {
      margin: 0 0 6px;
      font-size: 16px;
    }

    .intro-box p {
      margin: 0;
    }

    .history-card {
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 16px;
      background: #fff;
    }

    .hidden { display: none; }

    @media (max-width: 900px) {
      .grid { grid-template-columns: 1fr; }
      .summary-grid { grid-template-columns: 1fr 1fr; }
    }

    @media (max-width: 640px) {
      .page { padding: 16px 12px 40px; }
      h1 { font-size: 28px; }
      .summary-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <main class="page">
    <a href="/personal/oversikt" class="back-link">← Tillbaka till personalöversikten</a>

    <div class="header">
      <div>
        <h1>Patientupplevelse via SMS</h1>
        <p class="subtitle">
          Ladda upp dagens exportfil, förhandsgranska vilka patienter som blir valda och kontrollera dubbletter innan utskick byggs vidare i nästa steg.
        </p>
      </div>
      <div class="role-chip">{anvandare.roll === 'admin' ? 'Administratör' : 'Personal'}</div>
    </div>

    <section class="muted-box intro-box" aria-labelledby="pagePurposeTitle">
      <h2 id="pagePurposeTitle">Det här gör sidan</h2>
      <p class="helper">
        Använd sidan för att importera dagens exportfil, granska vilka patienter som väljs ut och skapa en kampanj innan första SMS-batchen skickas.
      </p>
    </section>

    <div class="grid">
      <section class="card">
        <h2>1. Importera fil</h2>
        <p class="helper">
          Fasta kärnkolumner är <code>Patient-ID</code>, <code>Mobiltelefon</code>, <code>Vårdgivare</code> och <code>Datum</code>.
          <code>Bokningstyp</code> och <code>Starttid</code> är valfria.
        </p>

        <form id="uploadForm">
          <div class="dropzone" id="dropzone">
            <strong>Dra in CSV-filen här</strong>
            <p>eller välj fil manuellt. Semikolonseparerat format förväntas.</p>
          </div>

          <div class="form-group">
            <label for="fileInput">CSV-fil</label>
            <div class="file-picker">
              <input id="fileInput" name="file" type="file" accept=".csv,.txt" required hidden />
              <button type="button" class="btn btn-secondary" id="fileInputTrigger">Välj fil</button>
              <span id="fileName" class="file-picker-name" aria-live="polite">Ingen fil har valts</span>
            </div>
          </div>

          <div class="form-group">
            <label for="globalBookingType">Global fallback för bokningstyp</label>
            <input
              id="globalBookingType"
              name="globalBookingType"
              type="text"
              class="input"
              placeholder="Används bara om Bokningstyp saknas i filen"
            />
          </div>

          <div class="actions">
            <button type="submit" class="btn btn-primary" id="previewBtn">Ladda och förhandsgranska</button>
            <button type="button" class="btn btn-secondary" id="clearBtn">Rensa</button>
          </div>
        </form>

        <div id="statusBanner" class="banner info"></div>

        <div class="muted-box">
          Du kan nu både förhandsgranska filen, skapa kampanj och skicka första batchen. För större kampanjer används en kömodell i bakgrunden.
        </div>
      </section>

      <aside class="card">
        <h3>Vad previewn visar</h3>
        <ul class="helper" style="padding-left: 18px; margin: 0;">
          <li>hur många rader som lästes in</li>
          <li>hur många rader som är giltiga</li>
          <li>vilka telefonnummer som är ogiltiga</li>
          <li>vilka dubletter som hittades</li>
          <li>varför en viss rad valdes vid dubletter</li>
        </ul>

        <h3 style="margin-top: 20px;">Deduplikering</h3>
        <p class="helper">
          Systemet deduplicerar främst på <code>Patient-ID</code> och prioriterar nybesök/remiss före återbesök.
          Om flera likvärdiga rader finns väljs normalt det senaste besöket.
        </p>
      </aside>
    </div>

    <section class="card section hidden" id="previewSection">
      <h2>2. Förhandsgranskning</h2>
      <div class="summary-grid" id="summaryGrid"></div>

      <div class="section">
        <h3>3. Kampanjinställningar</h3>
        <div class="summary-grid" style="grid-template-columns: 1fr 1fr;">
          <div>
            <label for="campaignName" style="display:block;margin-bottom:8px;font-weight:600;font-size:14px;">Kampanjnamn</label>
            <input id="campaignName" class="input" type="text" placeholder="T.ex. Patientupplevelse vecka 11" />
          </div>
          <div>
            <label for="reminderHours" style="display:block;margin-bottom:8px;font-weight:600;font-size:14px;">Påminn efter (timmar)</label>
            <input id="reminderHours" class="input" type="number" min="1" value="48" />
          </div>
        </div>

        <div class="form-group">
          <label for="smsTemplate">SMS-mall</label>
          <textarea id="smsTemplate" class="input" style="min-height:120px;">Hej! Hur nöjd var du med ditt besök hos [VÅRDGIVARE] den [DATUM] ([BOKNINGSTYP])?
Svara här: [LÄNK]
Enkäten är anonym. Tack!</textarea>
        </div>

        <div class="actions">
          <label style="display:flex;align-items:center;gap:8px;font-size:14px;color:var(--muted);">
            <input id="sendReminder" type="checkbox" checked />
            Skicka påminnelse till obesvarade
          </label>
        </div>

        <div class="actions">
          <button type="button" class="btn btn-primary" id="createCampaignBtn">Skapa kampanj</button>
        </div>
      </div>

      <div class="section">
        <h3>Valda rader</h3>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Rad</th>
                <th>Patient-ID</th>
                <th>Vårdgivare</th>
                <th>Datum</th>
                <th>Starttid</th>
                <th>Bokningstyp</th>
                <th>Klass</th>
              </tr>
            </thead>
            <tbody id="selectedRowsBody"></tbody>
          </table>
        </div>
      </div>

      <div class="section">
        <h3>Dubletter</h3>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Nyckel</th>
                <th>Behållen rad</th>
                <th>Bortvalda rader</th>
                <th>Motivering</th>
              </tr>
            </thead>
            <tbody id="duplicatesBody"></tbody>
          </table>
        </div>
      </div>

      <div class="section">
        <h3>Felrader</h3>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Rad</th>
                <th>Fält</th>
                <th>Fel</th>
              </tr>
            </thead>
            <tbody id="errorsBody"></tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="card section">
      <h2>Resultatöversikt</h2>
      <p class="helper">
        Vårdgivare ser bara sina egna resultat. Administratörer ser alla vårdgivare sida vid sida.
      </p>
      {isAdmin && (
        <div class="actions">
          <select id="dashboardProviderFilter" class="input" style="max-width:260px;">
            <option value="">Alla vårdgivare</option>
          </select>
        </div>
      )}
      <div id="dashboardBanner" class="banner info" style="display:block;margin-top:16px;">Laddar resultatöversikt...</div>
      <div id="dashboardContent" class="section"></div>
    </section>

    <section class="card section">
      <h2>Kampanjhistorik</h2>
      <p class="helper">Visar de senaste enkätkampanjerna och om det finns obesvarade utskick som kan få en påminnelse.</p>
      <div class="actions">
        <button type="button" class="btn btn-secondary" id="refreshCampaignsBtn">Uppdatera historik</button>
      </div>
      <div id="campaignsBanner" class="banner info" style="display:block;margin-top:16px;">Laddar kampanjhistorik...</div>
      <div id="campaignsContent" class="section"></div>
    </section>

    <section class="card section">
      <h2>Rapport</h2>
      <p class="helper">En enkel periodsammanfattning för de senaste 7, 30 eller 90 dagarna.</p>
      <div class="actions">
        {isAdmin && (
          <select id="reportProviderFilter" class="input" style="max-width:260px;">
            <option value="">Alla vårdgivare</option>
          </select>
        )}
        <select id="reportPeriod" class="input" style="max-width:220px;">
          <option value="week">Senaste 7 dagarna</option>
          <option value="month" selected>Senaste 30 dagarna</option>
          <option value="quarter">Senaste 90 dagarna</option>
        </select>
        <button type="button" class="btn btn-secondary" id="refreshReportBtn">Uppdatera rapport</button>
      </div>
      <div id="reportBanner" class="banner info" style="display:block;margin-top:16px;">Laddar rapport...</div>
      <div id="reportContent" class="section"></div>
    </section>
  </main>

  <script is:inline>
    const form = document.getElementById('uploadForm');
    const fileInput = document.getElementById('fileInput');
    const fileInputTrigger = document.getElementById('fileInputTrigger');
    const fileName = document.getElementById('fileName');
    const clearBtn = document.getElementById('clearBtn');
    const previewBtn = document.getElementById('previewBtn');
    const dropzone = document.getElementById('dropzone');
    const previewSection = document.getElementById('previewSection');
    const statusBanner = document.getElementById('statusBanner');
    const summaryGrid = document.getElementById('summaryGrid');
    const selectedRowsBody = document.getElementById('selectedRowsBody');
    const duplicatesBody = document.getElementById('duplicatesBody');
    const errorsBody = document.getElementById('errorsBody');
    const createCampaignBtn = document.getElementById('createCampaignBtn');
    const campaignNameInput = document.getElementById('campaignName');
    const smsTemplateInput = document.getElementById('smsTemplate');
    const sendReminderInput = document.getElementById('sendReminder');
    const reminderHoursInput = document.getElementById('reminderHours');
    const dashboardBanner = document.getElementById('dashboardBanner');
    const dashboardContent = document.getElementById('dashboardContent');
    const dashboardProviderFilter = document.getElementById('dashboardProviderFilter');
    const campaignsBanner = document.getElementById('campaignsBanner');
    const campaignsContent = document.getElementById('campaignsContent');
    const refreshCampaignsBtn = document.getElementById('refreshCampaignsBtn');
    const reportBanner = document.getElementById('reportBanner');
    const reportContent = document.getElementById('reportContent');
    const reportPeriod = document.getElementById('reportPeriod');
    const reportProviderFilter = document.getElementById('reportProviderFilter');
    const refreshReportBtn = document.getElementById('refreshReportBtn');
    let currentPreview = null;

    function setBanner(type, message) {
      statusBanner.className = `banner visible ${type}`;
      statusBanner.textContent = message;
    }

    function syncSelectedFileName() {
      const selectedFile = fileInput.files?.[0];
      fileName.textContent = selectedFile ? selectedFile.name : 'Ingen fil har valts';
      fileName.classList.toggle('has-file', Boolean(selectedFile));
    }

    fileInputTrigger.addEventListener('click', () => {
      if (typeof fileInput.showPicker === 'function') {
        fileInput.showPicker();
        return;
      }

      fileInput.click();
    });

    function clearPreview() {
      previewSection.classList.add('hidden');
      summaryGrid.innerHTML = '';
      selectedRowsBody.innerHTML = '';
      duplicatesBody.innerHTML = '';
      errorsBody.innerHTML = '';
    }

    function escapeHtml(value) {
      return String(value ?? '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');
    }

    function renderSummary(data) {
      const cards = [
        ['Totala rader', data.totalRows],
        ['Giltiga rader', data.validRows],
        ['Ogiltiga rader', data.invalidRows],
        ['Bortvalda dubletter', data.duplicateRows]
      ];

      summaryGrid.innerHTML = cards.map(([label, value]) => `
        <div class="summary-card">
          <div class="summary-label">${escapeHtml(label)}</div>
          <div class="summary-value">${escapeHtml(value)}</div>
        </div>
      `).join('');
    }

    function renderSelectedRows(rows) {
      selectedRowsBody.innerHTML = rows.length
        ? rows.map((row) => `
            <tr>
              <td>${escapeHtml(row.rowIndex)}</td>
              <td>${escapeHtml(row.patientId)}</td>
              <td>${escapeHtml(row.providerName)}</td>
              <td>${escapeHtml(row.visitDate)}</td>
              <td>${escapeHtml(row.visitStartTime || '—')}</td>
              <td>${escapeHtml(row.bookingTypeRaw || '—')}</td>
              <td><span class="pill info">${escapeHtml(row.bookingTypeNormalized)}</span></td>
            </tr>
          `).join('')
        : '<tr><td colspan="7">Inga giltiga rader hittades.</td></tr>';
    }

    function renderDuplicates(rows) {
      duplicatesBody.innerHTML = rows.length
        ? rows.map((row) => `
            <tr>
              <td>${escapeHtml(row.dedupKey)}</td>
              <td>${escapeHtml(row.keptRowIndex)}</td>
              <td>${escapeHtml(row.discardedRowIndexes.join(', '))}</td>
              <td>${escapeHtml(row.chosenReason)}</td>
            </tr>
          `).join('')
        : '<tr><td colspan="4">Inga dubletter hittades.</td></tr>';
    }

    function renderErrors(rows) {
      errorsBody.innerHTML = rows.length
        ? rows.map((row) => `
            <tr>
              <td>${escapeHtml(row.rowIndex)}</td>
              <td>${escapeHtml(row.field)}</td>
              <td>${escapeHtml(row.message)}</td>
            </tr>
          `).join('')
        : '<tr><td colspan="3">Inga valideringsfel hittades.</td></tr>';
    }

    dropzone.addEventListener('dragover', (event) => {
      event.preventDefault();
      dropzone.classList.add('dragover');
    });

    dropzone.addEventListener('dragleave', () => {
      dropzone.classList.remove('dragover');
    });

    dropzone.addEventListener('drop', (event) => {
      event.preventDefault();
      dropzone.classList.remove('dragover');
      if (event.dataTransfer?.files?.length) {
        fileInput.files = event.dataTransfer.files;
        syncSelectedFileName();
      }
    });

    fileInput.addEventListener('change', syncSelectedFileName);

    clearBtn.addEventListener('click', () => {
      form.reset();
      syncSelectedFileName();
      statusBanner.className = 'banner info';
      statusBanner.textContent = '';
      clearPreview();
    });

    syncSelectedFileName();

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      clearPreview();

      if (!fileInput.files?.length) {
        setBanner('error', 'Välj en fil först.');
        return;
      }

      previewBtn.disabled = true;
      setBanner('info', 'Läser fil och bygger preview...');

      try {
        const formData = new FormData(form);
        const response = await fetch('/api/enkat/upload', {
          method: 'POST',
          body: formData
        });

        const payload = await response.json();
        if (!response.ok || !payload.success) {
          setBanner('error', payload.error || 'Kunde inte förhandsgranska filen.');
          return;
        }

        const data = payload.data;
        currentPreview = data;
        renderSummary(data);
        renderSelectedRows(data.selectedRows || []);
        renderDuplicates(data.duplicates || []);
        renderErrors(data.errors || []);
        previewSection.classList.remove('hidden');

        setBanner(
          'success',
          `Preview klar: ${data.validRows} giltiga rader, ${data.invalidRows} ogiltiga och ${data.duplicateRows} bortvalda dublettrader.`
        );
      } catch (error) {
        console.error(error);
        setBanner('error', 'Ett oväntat fel uppstod vid uppladdning.');
      } finally {
        previewBtn.disabled = false;
      }
    });

    createCampaignBtn?.addEventListener('click', async () => {
      if (!currentPreview?.selectedRows?.length) {
        setBanner('error', 'Ladda och förhandsgranska en fil först.');
        return;
      }

      createCampaignBtn.disabled = true;
      setBanner('info', 'Skapar kampanj...');

      try {
        const response = await fetch('/api/enkat/send', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            campaignName: campaignNameInput?.value || '',
            globalBookingType: document.getElementById('globalBookingType')?.value || '',
            smsTemplate: smsTemplateInput?.value || '',
            sendNow: true,
            sendReminder: !!sendReminderInput?.checked,
            reminderAfterHours: Number(reminderHoursInput?.value || 48),
            rows: currentPreview.selectedRows
          })
        });

        const payload = await response.json();
        if (!response.ok || !payload.success) {
          setBanner('error', payload.error || 'Kunde inte skapa kampanjen.');
          createCampaignBtn.disabled = false;
          return;
        }

        const data = payload.data;
        setBanner(
          'success',
          `Kampanj skapad. Status: ${data.status}. Skickade: ${data.totalSent}, misslyckade: ${data.totalFailed}.`
        );
        createCampaignBtn.disabled = false;
        void loadCampaignHistory();
        void loadDashboard();
        void loadReport();
      } catch (error) {
        console.error(error);
        setBanner('error', 'Ett oväntat fel uppstod när kampanjen skulle skapas.');
        createCampaignBtn.disabled = false;
      }
    });

    function renderProviderCard(item) {
      const comments = (item.latestComments || [])
        .slice(0, 4)
        .map((comment) => `
          <div style="padding:10px 12px;border:1px solid var(--line);border-radius:12px;background:#fff;">
            <div style="font-size:12px;color:var(--muted);margin-bottom:4px;">${comment.type === 'bra' ? 'Bra' : 'Förbättra'}</div>
            <div style="font-size:14px;line-height:1.45;">${escapeHtml(comment.text)}</div>
          </div>
        `)
        .join('');

      const details = item.canShowDetails
        ? `
          <div class="summary-grid" style="grid-template-columns:repeat(4,minmax(0,1fr));margin-top:14px;">
            <div class="summary-card"><div class="summary-label">Helhet</div><div class="summary-value" style="font-size:22px;">${escapeHtml(item.overallAverage)}</div></div>
            <div class="summary-card"><div class="summary-label">Bemötande</div><div class="summary-value" style="font-size:22px;">${escapeHtml(item.subscores.bemotande)}</div></div>
            <div class="summary-card"><div class="summary-label">Info</div><div class="summary-value" style="font-size:22px;">${escapeHtml(item.subscores.information)}</div></div>
            <div class="summary-card"><div class="summary-label">Plan</div><div class="summary-value" style="font-size:22px;">${escapeHtml(item.subscores.planFramat)}</div></div>
          </div>
          <div style="margin-top:14px;font-size:14px;color:var(--muted);">
            Svarsfrekvens: <strong>${escapeHtml(item.responseRate)}</strong> · Svar: <strong>${escapeHtml(item.sampleSize)}</strong> · Påminnelser: <strong>${escapeHtml(item.reminderCount || 0)}</strong>
          </div>
          <div style="margin-top:6px;font-size:14px;color:var(--muted);">
            Genomsnittlig tid till första SMS: <strong>${escapeHtml(item.delayMetrics?.averageDelayHours ?? 0)} h</strong>
          </div>
          <div style="margin-top:6px;font-size:14px;color:var(--muted);">
            Fördröjningsfönster: ${(item.delayMetrics?.buckets || []).map((bucket) => `${escapeHtml(bucket.bucket)} (${escapeHtml(bucket.responseRate)})`).join(' · ') || 'Ingen data ännu'}
          </div>
          ${comments ? `<div style="display:grid;gap:10px;margin-top:14px;">${comments}</div>` : '<div style="margin-top:14px;color:var(--muted);font-size:14px;">Inga kommentarer ännu.</div>'}
        `
        : `<div style="margin-top:14px;color:var(--muted);font-size:14px;">För få svar för att visa resultat på ett integritetssäkert sätt.</div>`;

      return `
        <div class="card" style="padding:16px;">
          <h3 style="margin-bottom:4px;">${escapeHtml(item.providerName)}</h3>
          <div style="color:var(--muted);font-size:13px;">Underlag: ${escapeHtml(item.sampleSize)}</div>
          ${details}
        </div>
      `;
    }

    function formatDateTime(value) {
      if (!value) return '—';
      try {
        return new Date(value).toLocaleString('sv-SE');
      } catch {
        return value;
      }
    }

    function renderCampaignCard(item) {
      const statusText =
        item.status === 'skickar' && item.queuedInitial > 0
          ? `Köad batch kvar: ${item.queuedInitial}`
          : item.status === 'klar'
            ? 'Utskicket är klart'
            : item.status === 'fel'
              ? 'Något gick fel i utskicket'
              : 'Kampanjen väntar eller bearbetas';

      return `
        <div class="history-card">
          <div style="display:flex;justify-content:space-between;gap:12px;align-items:flex-start;flex-wrap:wrap;">
            <div>
              <h3 style="margin:0 0 4px;">${escapeHtml(item.namn || 'Namnlös kampanj')}</h3>
              <div style="color:var(--muted);font-size:13px;">Skapad ${escapeHtml(formatDateTime(item.created_at))}</div>
            </div>
            <span class="pill ${item.status === 'klar' ? 'ok' : item.status === 'fel' ? 'warn' : 'info'}">${escapeHtml(item.status)}</span>
          </div>

          <div class="summary-grid" style="grid-template-columns:repeat(4,minmax(0,1fr));margin-top:14px;">
            <div class="summary-card"><div class="summary-label">Importerade</div><div class="summary-value" style="font-size:20px;">${escapeHtml(item.total_importerade)}</div></div>
            <div class="summary-card"><div class="summary-label">Skickade</div><div class="summary-value" style="font-size:20px;">${escapeHtml(item.total_skickade)}</div></div>
            <div class="summary-card"><div class="summary-label">Svar</div><div class="summary-value" style="font-size:20px;">${escapeHtml(item.total_svar)}</div></div>
            <div class="summary-card"><div class="summary-label">Påminn möjliga</div><div class="summary-value" style="font-size:20px;">${escapeHtml(item.unansweredEligible)}</div></div>
          </div>

          <div style="margin-top:12px;color:var(--muted);font-size:14px;">
            Giltiga: <strong>${escapeHtml(item.total_giltiga)}</strong> · Dubletter: <strong>${escapeHtml(item.total_dubletter)}</strong> · Ogiltiga: <strong>${escapeHtml(item.total_ogiltiga)}</strong> · Påminnelser skickade: <strong>${escapeHtml(item.remindersSent)}</strong>
          </div>
          <div style="margin-top:6px;color:var(--muted);font-size:14px;">
            Svarsfrekvens: <strong>${escapeHtml(item.responseRate)}</strong> · ${escapeHtml(statusText)}
          </div>

          <div class="actions">
            <button
              type="button"
              class="btn btn-secondary remind-btn"
              data-campaign-id="${escapeHtml(item.id)}"
              ${item.unansweredEligible > 0 && item.skicka_paminnelse ? '' : 'disabled'}
            >
              Skicka påminnelse
            </button>
          </div>
        </div>
      `;
    }

    function renderReportProvider(item) {
      return `
        <div class="history-card">
          <div style="display:flex;justify-content:space-between;gap:12px;align-items:flex-start;flex-wrap:wrap;">
            <div>
              <h3 style="margin:0 0 4px;">${escapeHtml(item.providerName)}</h3>
              <div style="color:var(--muted);font-size:13px;">Underlag: ${escapeHtml(item.sampleSize)}</div>
            </div>
            <span class="pill ${item.deltaVsPrevious >= 0 ? 'ok' : 'warn'}">
              ${item.deltaVsPrevious >= 0 ? '+' : ''}${escapeHtml(item.deltaVsPrevious)}
            </span>
          </div>

          ${
            item.canShowDetails
              ? `
                <div class="summary-grid" style="grid-template-columns:repeat(4,minmax(0,1fr));margin-top:14px;">
                  <div class="summary-card"><div class="summary-label">Helhet</div><div class="summary-value" style="font-size:22px;">${escapeHtml(item.overallAverage)}</div></div>
                  <div class="summary-card"><div class="summary-label">Bemötande</div><div class="summary-value" style="font-size:22px;">${escapeHtml(item.subscores.bemotande)}</div></div>
                  <div class="summary-card"><div class="summary-label">Info</div><div class="summary-value" style="font-size:22px;">${escapeHtml(item.subscores.information)}</div></div>
                  <div class="summary-card"><div class="summary-label">Plan</div><div class="summary-value" style="font-size:22px;">${escapeHtml(item.subscores.planFramat)}</div></div>
                </div>
                <div style="margin-top:10px;color:var(--muted);font-size:14px;">
                  Genomsnittlig tid till första SMS: <strong>${escapeHtml(item.delayMetrics?.averageDelayHours ?? 0)} h</strong>
                </div>
                <div style="margin-top:6px;color:var(--muted);font-size:14px;">
                  Fördröjningsfönster: ${(item.delayMetrics?.buckets || []).map((bucket) => `${escapeHtml(bucket.bucket)} (${escapeHtml(bucket.responseRate)})`).join(' · ') || 'Ingen data ännu'}
                </div>
              `
              : `<div style="margin-top:14px;color:var(--muted);font-size:14px;">För få svar för att visa resultat på ett integritetssäkert sätt.</div>`
          }
        </div>
      `;
    }

    function updateSelectOptions(selectEl, values, selectedValue) {
      if (!selectEl) return;
      const current = new Set(
        Array.from(selectEl.querySelectorAll('option'))
          .map((option) => option.value)
      );

      for (const value of values || []) {
        if (!current.has(value)) {
          const option = document.createElement('option');
          option.value = value;
          option.textContent = value;
          selectEl.appendChild(option);
        }
      }

      if (selectedValue !== undefined) {
        selectEl.value = selectedValue;
      }
    }

    async function loadDashboard() {
      dashboardBanner.className = 'banner info visible';
      dashboardBanner.textContent = 'Laddar resultatöversikt...';
      dashboardContent.innerHTML = '';

      try {
        const provider = dashboardProviderFilter?.value || '';
        const response = await fetch(`/api/enkat/dashboard?days=90${provider ? `&provider=${encodeURIComponent(provider)}` : ''}`);
        const payload = await response.json();

        if (!response.ok || !payload.success) {
          dashboardBanner.className = 'banner error visible';
          dashboardBanner.textContent = payload.error || 'Kunde inte läsa dashboarddata.';
          return;
        }

        const data = payload.data;
        updateSelectOptions(dashboardProviderFilter, data.availableProviders || [], provider);
        dashboardBanner.className = 'banner success visible';
        dashboardBanner.textContent = data.scope === 'admin'
          ? `Visar resultat för ${data.totals.providerCount} vårdgivare.`
          : 'Visar dina egna resultat för de senaste 90 dagarna.';

        if (data.scope === 'self') {
          if (!data.configured) {
            dashboardContent.innerHTML = `<div class="muted-box">${escapeHtml(data.message)}</div>`;
            return;
          }
          dashboardContent.innerHTML = renderProviderCard(data);
          return;
        }

        const providers = data.providers || [];
        if (!providers.length) {
          dashboardContent.innerHTML = '<div class="muted-box">Inga enkätsvar hittades ännu för vald period.</div>';
          return;
        }

        dashboardContent.innerHTML = `
          <div style="display:grid;gap:16px;">
            ${providers.map((item) => renderProviderCard(item)).join('')}
          </div>
        `;
      } catch (error) {
        console.error(error);
        dashboardBanner.className = 'banner error visible';
        dashboardBanner.textContent = 'Kunde inte ladda resultatöversikten.';
      }
    }

    void loadDashboard();

    dashboardProviderFilter?.addEventListener('change', () => {
      void loadDashboard();
    });

    async function loadCampaignHistory() {
      campaignsBanner.className = 'banner info visible';
      campaignsBanner.textContent = 'Laddar kampanjhistorik...';
      campaignsContent.innerHTML = '';

      try {
        const response = await fetch('/api/enkat/campaigns');
        const payload = await response.json();

        if (!response.ok || !payload.success) {
          campaignsBanner.className = 'banner error visible';
          campaignsBanner.textContent = payload.error || 'Kunde inte läsa kampanjhistoriken.';
          return;
        }

        const campaigns = payload.data?.campaigns || [];
        if (!campaigns.length) {
          campaignsBanner.className = 'banner success visible';
          campaignsBanner.textContent = 'Ingen kampanjhistorik ännu.';
          campaignsContent.innerHTML = '<div class="muted-box">När du skapar dina första kampanjer visas de här.</div>';
          return;
        }

        campaignsBanner.className = 'banner success visible';
        campaignsBanner.textContent = `Visar ${campaigns.length} kampanjer.`;
        campaignsContent.innerHTML = `<div style="display:grid;gap:16px;">${campaigns.map((item) => renderCampaignCard(item)).join('')}</div>`;

        campaignsContent.querySelectorAll('.remind-btn').forEach((button) => {
          button.addEventListener('click', async () => {
            const campaignId = button.getAttribute('data-campaign-id');
            if (!campaignId) return;

            button.disabled = true;
            campaignsBanner.className = 'banner info visible';
            campaignsBanner.textContent = 'Skickar påminnelser...';

            try {
              const response = await fetch('/api/enkat/remind', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ campaignId })
              });
              const payload = await response.json();

              if (!response.ok || !payload.success) {
                campaignsBanner.className = 'banner error visible';
                campaignsBanner.textContent = payload.error || 'Kunde inte skicka påminnelser.';
                button.disabled = false;
                return;
              }

              const data = payload.data;
              campaignsBanner.className = 'banner success visible';
              campaignsBanner.textContent = `Påminnelser skickade. Berörda: ${data.eligible}, skickade: ${data.sent}, misslyckade: ${data.failed}.`;
              await loadCampaignHistory();
              await loadDashboard();
            } catch (error) {
              console.error(error);
              campaignsBanner.className = 'banner error visible';
              campaignsBanner.textContent = 'Ett oväntat fel uppstod vid påminnelseutskick.';
              button.disabled = false;
            }
          });
        });
      } catch (error) {
        console.error(error);
        campaignsBanner.className = 'banner error visible';
        campaignsBanner.textContent = 'Kunde inte ladda kampanjhistoriken.';
      }
    }

    refreshCampaignsBtn?.addEventListener('click', () => {
      void loadCampaignHistory();
    });

    void loadCampaignHistory();

    async function loadReport() {
      reportBanner.className = 'banner info visible';
      reportBanner.textContent = 'Laddar rapport...';
      reportContent.innerHTML = '';

      try {
        const period = reportPeriod?.value || 'month';
        const provider = reportProviderFilter?.value || '';
        const response = await fetch(`/api/enkat/report?period=${encodeURIComponent(period)}${provider ? `&provider=${encodeURIComponent(provider)}` : ''}`);
        const payload = await response.json();

        if (!response.ok || !payload.success) {
          reportBanner.className = 'banner error visible';
          reportBanner.textContent = payload.error || 'Kunde inte läsa rapporten.';
          return;
        }

        const data = payload.data;
        updateSelectOptions(reportProviderFilter, data.availableProviders || [], provider);
        reportBanner.className = 'banner success visible';
        reportBanner.textContent = `Rapport laddad: ${data.periodLabel}.`;

        if (data.scope === 'self') {
          if (!data.configured) {
            reportContent.innerHTML = `<div class="muted-box">${escapeHtml(data.message)}</div>`;
            return;
          }

          if (!data.canShowDetails) {
            reportContent.innerHTML = `<div class="muted-box">${escapeHtml(data.message || 'För få svar för att visa resultat på ett integritetssäkert sätt.')}</div>`;
            return;
          }

          reportContent.innerHTML = renderReportProvider(data);
          return;
        }

        const providers = data.providers || [];
        if (!providers.length) {
          reportContent.innerHTML = '<div class="muted-box">Inga rapportdata hittades för vald period.</div>';
          return;
        }

        reportContent.innerHTML = `
          <div style="display:grid;gap:16px;">
            ${providers.map((item) => renderReportProvider(item)).join('')}
          </div>
        `;
      } catch (error) {
        console.error(error);
        reportBanner.className = 'banner error visible';
        reportBanner.textContent = 'Kunde inte ladda rapporten.';
      }
    }

    refreshReportBtn?.addEventListener('click', () => {
      void loadReport();
    });

    reportProviderFilter?.addEventListener('change', () => {
      void loadReport();
    });

    void loadReport();
  </script>
</body>
</html>
