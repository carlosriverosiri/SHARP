      border: 1px solid #e2e8f0;
      border-radius: 0.5rem;
      padding: 0.75rem;
      margin-bottom: 0.5rem;
      transition: all 0.2s;
      cursor: pointer;
      display: block;
      text-decoration: none;
      color: inherit;
    }

    .resource-card:hover {
      background: #f1f5f9;
      border-color: #94a3b8;
