---
/**
 * Profilsida för personal
 * URL: /personal/profil
 * 
 * Här kan personal lägga till sitt mobilnummer för att få SMS-notifieringar.
 */

export const prerender = false;

import PortalLayout from '../../layouts/PortalLayout.astro';
import { hamtaAnvandare } from '../../lib/auth';
import { supabaseAdmin } from '../../lib/supabase';

const anvandare = await hamtaAnvandare(Astro.cookies);

// Hämta profil
let profil: any = null;
let felmeddelande = '';
let framgangsmeddelande = '';
let lakare: any[] = [];

if (anvandare) {
  const { data } = await supabaseAdmin
    .from('profiles')
    .select('*')
    .eq('id', anvandare.id)
    .single();
  
  if (data) {
    profil = data;
  }

  const { data: lakareData } = await supabaseAdmin
    .from('lakare')
    .select('id, namn, aktiv')
    .eq('aktiv', true)
    .order('namn');
  lakare = lakareData || [];
}

// Hantera POST
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const mobilnummer = formData.get('mobilnummer')?.toString() || '';
    const villHaNotifikationer = formData.get('villHaNotifikationer') === 'on';
    const vardgivareNamn = formData.get('vardgivare_namn')?.toString().trim() || null;

    // Validera mobilnummer om det finns
    let formateratNummer = '';
    if (mobilnummer) {
      const cleanNumber = mobilnummer.replace(/\D/g, '');
      if (cleanNumber.length < 9 || cleanNumber.length > 12) {
        felmeddelande = 'Ogiltigt mobilnummer';
      } else {
        // Formatera till +46-format
        if (cleanNumber.startsWith('46')) {
          formateratNummer = '+' + cleanNumber;
        } else if (cleanNumber.startsWith('0')) {
          formateratNummer = '+46' + cleanNumber.slice(1);
        } else {
          formateratNummer = '+46' + cleanNumber;
        }
      }
    }

    if (!felmeddelande && anvandare) {
      // Kontrollera om profil finns
      const { data: existing } = await supabaseAdmin
        .from('profiles')
        .select('id')
        .eq('id', anvandare.id)
        .single();

      if (existing) {
        // Uppdatera befintlig
        const { error } = await supabaseAdmin
          .from('profiles')
          .update({
            mobilnummer: formateratNummer || null,
            vill_ha_notifikationer: villHaNotifikationer,
            vardgivare_namn: vardgivareNamn,
          })
          .eq('id', anvandare.id);

        if (error) {
          felmeddelande = 'Kunde inte spara ändringar';
          console.error('Profil update error:', error);
        } else {
          framgangsmeddelande = 'Profilen har sparats!';
          profil = { ...profil, mobilnummer: formateratNummer, vill_ha_notifikationer: villHaNotifikationer, vardgivare_namn: vardgivareNamn };
        }
      } else {
        // Skapa ny profil
        const { error } = await supabaseAdmin
          .from('profiles')
          .insert({
            id: anvandare.id,
            email: anvandare.email,
            mobilnummer: formateratNummer || null,
            vill_ha_notifikationer: villHaNotifikationer,
            vardgivare_namn: vardgivareNamn,
          });

        if (error) {
          felmeddelande = 'Kunde inte skapa profil';
          console.error('Profil insert error:', error);
        } else {
          framgangsmeddelande = 'Profilen har skapats!';
          profil = { mobilnummer: formateratNummer, vill_ha_notifikationer: villHaNotifikationer, vardgivare_namn: vardgivareNamn };
        }
      }
    }
  } catch (e) {
    console.error('Form error:', e);
    felmeddelande = 'Ett fel uppstod';
  }
}

// Formatera nummer för visning
function formateraNummer(nummer: string | null): string {
  if (!nummer) return '';
  // +46701234567 → 070-123 45 67
  const clean = nummer.replace(/^\+46/, '0');
  if (clean.length === 10) {
    return `${clean.slice(0, 3)}-${clean.slice(3, 6)} ${clean.slice(6, 8)} ${clean.slice(8)}`;
  }
  return clean;
}
---

<PortalLayout title="Min profil" activePath="/personal/profil" email={anvandare?.email} role={anvandare?.roll}>
  <div class="min-h-screen" style="background:#f8fafc;">

    <main class="max-w-5xl mx-auto px-4 py-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        
        <!-- Vänster kolumn: Formulär -->
        <div class="lg:col-span-2">
          <div class="bg-white rounded-xl shadow-sm border overflow-hidden">
            
            <!-- Profil-header -->
            <div class="bg-linear-to-r from-sky-500 to-sky-600 px-6 py-8 text-white">
              <div class="flex items-center gap-4">
                <div class="w-16 h-16 bg-white/20 rounded-full flex items-center justify-center text-2xl overflow-hidden">
                  {profil?.avatar_url ? (
                    <img 
                      src={profil.avatar_url} 
                      alt="Profilbild"
                      class="w-full h-full object-cover"
                    />
                  ) : (
                    <span>👤</span>
                  )}
                </div>
                <div>
                  <h2 class="text-xl font-semibold">{anvandare?.email}</h2>
                  <p class="text-sky-100">
                    {anvandare?.roll === 'admin' ? 'Administratör' : 'Personal'}
                  </p>
                </div>
              </div>
            </div>

            <!-- Formulär -->
            <form method="POST" class="p-6 space-y-6">
              
              {felmeddelande && (
                <div class="p-4 bg-red-50 border border-red-200 rounded-lg text-red-800 flex items-center gap-2">
                  <span>❌</span>
                  {felmeddelande}
                </div>
              )}
              
              {framgangsmeddelande && (
                <div class="p-4 bg-green-50 border border-green-200 rounded-lg text-green-800 flex items-center gap-2">
                  <span>✅</span>
                  {framgangsmeddelande}
                </div>
              )}

              <!-- Mobilnummer -->
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">
                  📱 Mobilnummer för SMS-notifikationer
                </label>
                <input 
                  type="tel" 
                  name="mobilnummer" 
                  value={formateraNummer(profil?.mobilnummer)}
                  placeholder="070-123 45 67"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-sky-500 focus:border-sky-500 text-lg"
                >
                <p class="text-sm text-gray-500 mt-2">
                  Används för att få SMS när en patient svarar JA på kort varsel-förfrågningar.
                </p>
              </div>

              <!-- Koppling till vårdgivarnamn -->
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">
                  🩺 Vårdgivarnamn för patientupplevelse
                </label>
                <select
                  name="vardgivare_namn"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-sky-500 focus:border-sky-500 text-base bg-white"
                >
                  <option value="">Ingen koppling vald</option>
                  {lakare.map((l) => (
                    <option value={l.namn} selected={profil?.vardgivare_namn === l.namn}>{l.namn}</option>
                  ))}
                </select>
                <p class="text-sm text-gray-500 mt-2">
                  Används för att begränsa enkätresultat så att du som vårdgivare bara ser dina egna resultat.
                </p>
              </div>

              <!-- Notifikationsinställningar -->
              <div class="bg-gray-50 rounded-lg p-4">
                <label class="flex items-start gap-3 cursor-pointer">
                  <input 
                    type="checkbox" 
                    name="villHaNotifikationer" 
                    checked={profil?.vill_ha_notifikationer}
                    class="mt-1 rounded"
                  >
                  <div>
                    <div class="font-medium text-gray-900">
                      Jag vill ta emot SMS-notifikationer vid JA-svar
                    </div>
                    <div class="text-sm text-gray-500 mt-1">
                      När denna är aktiverad kan du väljas som mottagare när kollegor skapar kort varsel-kampanjer.
                      Du får då ett SMS direkt när en patient svarar JA.
                    </div>
                  </div>
                </label>
              </div>

              <!-- Spara-knapp -->
              <div class="pt-4 border-t">
                <button 
                  type="submit"
                  class="w-full px-6 py-3 bg-sky-600 text-white font-semibold rounded-lg hover:bg-sky-700 transition-colors"
                >
                  Spara ändringar
                </button>
              </div>
            </form>
          </div>
        </div>

        <!-- Höger kolumn: Info -->
        <div class="lg:col-span-1 space-y-6">
          <!-- Hur det fungerar -->
          <div class="bg-sky-50 border border-sky-100 rounded-lg p-4">
            <h3 class="font-medium text-sky-900 mb-2">ℹ️ Så fungerar notifikationer</h3>
            <ol class="text-sm text-sky-800 space-y-2 list-decimal list-inside">
              <li>Du eller en kollega skapar en kort varsel-kampanj</li>
              <li>Du väljs som mottagare av notifikationer</li>
              <li>SMS skickas till patienterna</li>
              <li>När en patient svarar JA får du ett SMS:
                <div class="mt-1 p-2 bg-white rounded border border-sky-200 font-mono text-xs">
                  🎉 KORT VARSEL: Anna svarade JA!<br>
                  Tid: tis 28/1 kl 08:00<br>
                  Gå till personalportalen...
                </div>
              </li>
              <li>Du kan då ringa patienten och bekräfta bokningen</li>
            </ol>
          </div>

          <!-- Snabblänkar -->
          <div class="bg-white rounded-lg border p-4">
            <h3 class="font-medium text-gray-900 mb-3">⚡ Snabblänkar</h3>
            <div class="space-y-2">
              <a 
                href="/personal/kort-varsel" 
                class="block p-3 rounded-lg border border-gray-200 hover:border-sky-300 hover:bg-sky-50 transition-colors"
              >
                <div class="flex items-center gap-3">
                  <span class="text-lg">📱</span>
                  <div>
                    <div class="font-medium text-gray-900 text-sm">Kort varsel SMS</div>
                    <div class="text-xs text-gray-500">Skapa kampanjer</div>
                  </div>
                </div>
              </a>
              <a 
                href="/personal/lankar-sms" 
                class="block p-3 rounded-lg border border-gray-200 hover:border-sky-300 hover:bg-sky-50 transition-colors"
              >
                <div class="flex items-center gap-3">
                  <span class="text-lg">📎</span>
                  <div>
                    <div class="font-medium text-gray-900 text-sm">Länkar & SMS</div>
                    <div class="text-xs text-gray-500">Skicka info till patienter</div>
                  </div>
                </div>
              </a>
              <a 
                href="/personal/enkat" 
                class="block p-3 rounded-lg border border-gray-200 hover:border-sky-300 hover:bg-sky-50 transition-colors"
              >
                <div class="flex items-center gap-3">
                  <span class="text-lg">🩺</span>
                  <div>
                    <div class="font-medium text-gray-900 text-sm">Patientupplevelse</div>
                    <div class="text-xs text-gray-500">Se dina egna enkätsvar</div>
                  </div>
                </div>
              </a>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</PortalLayout>
