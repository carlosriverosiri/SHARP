---
/**
 * Kopiera Länkar & Skicka SMS - Personalverktyg
 * 
 * Sida: /personal/lankar-sms
 * Kräver: Inloggning
 * 
 * Kombinerar:
 * - Kopiera kortlänkar till patientinfo
 * - Skicka SMS med fördefinierade mallar via 46elks
 */
export const prerender = false;

import { arInloggad, hamtaAnvandare } from '../../lib/auth';

// Kontrollera inloggning
if (!await arInloggad(Astro.cookies)) {
  return Astro.redirect(`/personal?next=${encodeURIComponent(`${new URL(Astro.request.url).pathname}${new URL(Astro.request.url).search}`)}`);
}

const anvandare = await hamtaAnvandare(Astro.cookies);

// Importera kortlänkar från central JSON-fil
import shortLinksData from '../../data/shortLinks.json';

// Ikoner för varje kategori
const categoryIcons: Record<string, string> = {
  "Diagnoser": "🩺",
  "Operationer": "🔪",
  "Rehab": "🏋️",
  "Frågeformulär": "📋",
  "Info": "ℹ️"
};

// SMS-mallar per kategori
const smsMallar: Record<string, string> = {
  "Diagnoser": "Hej! Läs mer om {namn}: {länk} /Södermalms Ortopedi",
  "Operationer": "Hej! Du är planerad för {namn}. Läs mer här: {länk} /Södermalms Ortopedi",
  "Rehab": "Hej! Efter din operation, läs igenom rehabinformationen: {länk} /Södermalms Ortopedi",
  "Frågeformulär": "Hej! Vänligen fyll i detta formulär inför ditt besök: {länk} /Södermalms Ortopedi",
  "Info": "Hej! Här finns information som kan vara bra att läsa: {länk} /Södermalms Ortopedi"
};

// Filtrera bort metadata-nycklar och bygg länklista
const categories = Object.entries(shortLinksData)
  .filter(([key]) => !key.startsWith('_'))
  .map(([categoryName, items]) => ({
    category: categoryName,
    icon: categoryIcons[categoryName] || "📄",
    smsMall: smsMallar[categoryName] || "Hej! Se denna länk: {länk} /Södermalms Ortopedi",
    items: (items as Array<{name: string; shortCode: string; target: string; isExternal: boolean}>)
      .filter(item => item.shortCode && item.name)
  }));

const baseDomain = "www.specialist.se";

// Kontrollera om 46elks är konfigurerat
const elksConfigured = !!(import.meta.env.ELKS_API_USER && import.meta.env.ELKS_API_PASSWORD);

// Prefill telefon från query-param (SSR)
const requestUrl = new URL(Astro.request.url);
const phoneParam = requestUrl.searchParams.get('phone')
  || requestUrl.searchParams.get('mobil')
  || requestUrl.searchParams.get('tel')
  || '';

const normalizePhone = (raw: string) => {
  let value = raw.replace(/\D/g, '');
  if (value.startsWith('46')) value = value.substring(2);
  if (value.startsWith('0')) value = value.substring(1);
  return value;
};

const initialPhone = phoneParam ? normalizePhone(phoneParam) : '';
