        )}
        <a href="/personal/oversikt?logout=true" class="logout-btn">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" width="18" height="18">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
          </svg>
          Logga ut
        </a>
      </div>
    </aside>

    <!-- Main content -->
    <main class="main-content">
      <div class="page-header">
        <h1 class="page-title">📎 Kopiera länkar & Skicka SMS</h1>
        <p class="page-subtitle">Välj en länk till vänster för att kopiera eller skicka som SMS till patient</p>
      </div>

      {!elksConfigured && (
        <div class="message warning">
          ⚠️ SMS-funktionen är inte konfigurerad. Lägg till 46elks API-nycklar i miljövariablerna för att aktivera.
        </div>
      )}

      <div class="two-columns">
        <!-- Links column -->
        <div class="links-column">
          <div class="search-box">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <input 
              type="text" 
              id="search-input"
              placeholder="Sök diagnos, operation eller rehab..."
            />
          </div>

          <button type="button" id="addLinkBtn" class="btn-add-link" title="Lägg till ny länk">
            + Ny länk
          </button>

          <!-- Inline form for adding new link -->
          <div id="addLinkForm" class="add-link-form" style="display:none;">
            <div class="add-link-form-inner">
              <input type="text" id="newLinkName" placeholder="Namn (t.ex. Distal bicepsruptur)" class="add-link-input">
              <input type="text" id="newLinkCode" placeholder="Kortkod (t.ex. /d/biceps-dist)" class="add-link-input">
              <input type="text" id="newLinkTarget" placeholder="Mål-URL (t.ex. /sjukdomar/axel/...)" class="add-link-input">
              <div class="add-link-category-row"><select id="newLinkCategory" class="add-link-input" style="flex:1"><option value="Diagnoser">Diagnoser</option><option value="Operationer">Operationer</option><option value="Rehab">Rehab</option><option value="Info" selected>Info</option><option value="__new__">+ Ny kategori...</option></select><input type="text" id="newCategoryInput" class="add-link-input" placeholder="Kategorinamn..." style="display:none;flex:1"></div>
              <label class="add-link-check"><input type="checkbox" id="newLinkExternal"> Extern URL</label>
              <div class="add-link-actions">
                <button type="button" id="cancelAddLink" class="btn btn-cancel">Avbryt</button>
                <button type="button" id="saveAddLink" class="btn btn-save">Spara</button>
              </div>
            </div>
          </div>

          <div id="dynamicLinksContainer"></div>

          {categories.map((cat) => (
            <section class="category-section" data-category={cat.category}>
              <h2>
                <span>{cat.icon}</span>
                {cat.category}
              </h2>
              <div class="links-list">
                {cat.items.map((item) => (
                  <div 
                    class="link-item"
                    data-name={item.name}
                    data-url={`${baseDomain}${item.shortCode}`}
                    data-category={cat.category}
                    data-template={cat.smsMall}
                  >
                    <div class="link-info">
                      <div class="link-name">{item.name}</div>
                      <div class="link-url">{baseDomain}{item.shortCode}</div>
                    </div>
                    <div class="link-actions">
                      <button 
                        type="button" 
                        class="btn btn-copy"
                        data-url={`${baseDomain}${item.shortCode}`}
                        title="Kopiera länk"
                      >
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                        </svg>
                        Kopiera
                      </button>
                      {elksConfigured && (
                        <button 
                          type="button" 
                          class="btn btn-sms"
                          title="Fyll i SMS"
                        >
                          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                          </svg>
                          SMS
                        </button>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            </section>
          ))}

          <div id="dynamicLinksContainer"></div>

          <div id="no-results" class="message warning" style="display: none;">
            Inga resultat hittades för din sökning.
          </div>
        </div>

        <!-- SMS Panel -->
        <div class="sms-panel">
          <div class="sms-header">
            <h2>
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="24" height="24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
              </svg>
              Skicka SMS
            </h2>
            <p>via 46elks (~0,35 kr/SMS)</p>
          </div>

          <div class="sms-body">
            <div id="sms-message-area"></div>

            {elksConfigured ? (
              <form id="sms-form">
                <div class="sms-field">
                  <label for="sms-phone">📞 Mobilnummer</label>
                  <div class="phone-input-wrapper">
                    <span class="phone-prefix">+46</span>
                    <input 
                      type="tel" 
                      id="sms-phone" 
                      class="phone-input"
                      value={initialPhone}
                      placeholder="701234567"
                      pattern="[0-9]{9}"
                      maxlength="10"
                      required
                    />
                  </div>
                </div>

                <div class="sms-field">
                  <label for="sms-category">📁 Kategori</label>
                  <select id="sms-category">
                    {categories.map((cat) => (
                      <option value={cat.category} data-template={cat.smsMall}>
                        {cat.icon} {cat.category}
                      </option>
                    ))}
                  </select>
                </div>

                <div class="sms-field">
                  <label for="sms-text">💬 Meddelande</label>
                  <textarea 
                    id="sms-text" 
                    placeholder="Välj en länk till vänster eller skriv eget meddelande..."
                  ></textarea>
                  <div class="char-counter">
                    <span class="char-count" id="char-count">0/160</span>
                    <span class="sms-cost" id="sms-cost">1 SMS</span>
                    <div class="char-bar">
                      <div class="char-bar-fill" id="char-bar-fill" style="width: 0%"></div>
                    </div>
                  </div>
                </div>

                <button type="submit" class="btn-send" id="send-btn" disabled>
                  <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
                  </svg>
                  Skicka SMS
                </button>
              </form>
            ) : (
              <div class="empty-sms">
                <div class="empty-sms-icon">🔧</div>
                <p><strong>SMS ej konfigurerat</strong></p>
                <p style="font-size: 0.85rem; margin-top: 0.5rem;">
                  Lägg till miljövariablerna:<br>
                  <code style="font-size: 0.8rem; background: #f1f5f9; padding: 0.25rem 0.5rem; border-radius: 0.25rem;">ELKS_API_USER</code><br>
                  <code style="font-size: 0.8rem; background: #f1f5f9; padding: 0.25rem 0.5rem; border-radius: 0.25rem;">ELKS_API_PASSWORD</code>
                </p>
              </div>
            )}
          </div>
        </div>
      </div>
    </main>
  </div>

  <!-- Toast -->
  <div class="toast" id="toast">✓ Kopierad!</div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const toast = document.getElementById('toast');
      const searchInput = document.getElementById('search-input') as HTMLInputElement;
      const categorySections = document.querySelectorAll('.category-section');
      const noResults = document.getElementById('no-results');
      
      // SMS elements
      const smsForm = document.getElementById('sms-form') as HTMLFormElement;
      const smsPhone = document.getElementById('sms-phone') as HTMLInputElement;
      const smsCategory = document.getElementById('sms-category') as HTMLSelectElement;
      const smsText = document.getElementById('sms-text') as HTMLTextAreaElement;
      const charCount = document.getElementById('char-count');
      const smsCost = document.getElementById('sms-cost');
      const charBarFill = document.getElementById('char-bar-fill');
      const sendBtn = document.getElementById('send-btn') as HTMLButtonElement;
      const messageArea = document.getElementById('sms-message-area');
      const urlParams = new URLSearchParams(window.location.search);

      // Show toast
      function showToast(text: string, isError = false) {
        if (!toast) return;
        toast.textContent = text;
        toast.style.background = isError ? '#ef4444' : '#16a34a';
        toast.classList.add('show');
        setTimeout(() => toast.classList.remove('show'), 2500);
      }

      // Prefill phone from query param (e.g. ?phone=0701234567 or ?phone=+46701234567)
      function normalizePhoneInput(raw: string) {
        let value = raw.replace(/\D/g, '');
        if (value.startsWith('46')) value = value.substring(2);
        if (value.startsWith('0')) value = value.substring(1);
        return value;
      }

      if (smsPhone) {
        const phoneParam = urlParams.get('phone') || urlParams.get('mobil') || urlParams.get('tel');
        if (phoneParam) {
          smsPhone.value = normalizePhoneInput(phoneParam);
          updateCharCounter();
          smsPhone.focus();
        }
      }

      // Copy functionality
      document.querySelectorAll('.btn-copy').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          e.stopPropagation();
          const url = btn.getAttribute('data-url');
          if (!url) return;
          
          try {
            await navigator.clipboard.writeText(url);
            btn.classList.add('copied');
            btn.innerHTML = `
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              Kopierad!
            `;
            showToast('✓ Länk kopierad!');
            
            setTimeout(() => {
              btn.classList.remove('copied');
              btn.innerHTML = `
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                </svg>
                Kopiera
              `;
            }, 2000);
          } catch (err) {
            showToast('Kunde inte kopiera', true);
          }
        });
      });

      // SMS button click - fill SMS form
      document.querySelectorAll('.btn-sms').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const linkItem = btn.closest('.link-item') as HTMLElement;
          if (!linkItem) return;
          
          const name = linkItem.dataset.name || '';
          const url = linkItem.dataset.url || '';
          const category = linkItem.dataset.category || '';
          const template = linkItem.dataset.template || '';
          
          // Update category select
          if (smsCategory) {
            smsCategory.value = category;
          }
          
          // Fill in the message using template
          const message = template
            .replace('{namn}', name)
            .replace('{länk}', url);
          
          if (smsText) {
            smsText.value = message;
            updateCharCounter();
          }
          
          // Focus phone field
          if (smsPhone) {
            smsPhone.focus();
          }
          
          // Highlight selected item
          document.querySelectorAll('.link-item').forEach(item => item.classList.remove('selected'));
          linkItem.classList.add('selected');
        });
      });

      // Link item click (entire row)
      document.querySelectorAll('.link-item').forEach(item => {
        item.addEventListener('click', (e) => {
          const target = e.target as HTMLElement;
          if (target.closest('.btn')) return; // Ignore if button clicked
          
          // Find and click the SMS button if it exists
          const smsBtn = item.querySelector('.btn-sms') as HTMLButtonElement;
          if (smsBtn) {
            smsBtn.click();
          }
        });
      });

      // Search functionality
      if (searchInput) {
        searchInput.addEventListener('input', () => {
          const term = searchInput.value.toLowerCase().trim();
          let hasResults = false;
          
          categorySections.forEach(section => {
            const items = section.querySelectorAll('.link-item');
            let categoryHasResults = false;
            
            items.forEach(item => {
              const el = item as HTMLElement;
              const name = (el.dataset.name || '').toLowerCase();
              const url = (el.dataset.url || '').toLowerCase();
              const matches = name.includes(term) || url.includes(term);
              
              el.style.display = matches ? 'flex' : 'none';
              if (matches) {
                categoryHasResults = true;
                hasResults = true;
              }
            });
            
            (section as HTMLElement).style.display = categoryHasResults ? 'block' : 'none';
          });
          
          if (noResults) {
            noResults.style.display = hasResults ? 'none' : 'block';
          }
        });
      }

      // Character counter
      function updateCharCounter() {
        if (!smsText || !charCount || !smsCost || !charBarFill || !sendBtn) return;
        
        const length = smsText.value.length;
        const smsCount = length === 0 ? 1 : Math.ceil(length / 160);
        const percent = Math.min((length / 160) * 100, 100);
        
        charCount.textContent = `${length}/160`;
        smsCost.textContent = `${smsCount} SMS${smsCount > 1 ? ' (~' + (smsCount * 0.35).toFixed(2) + ' kr)' : ''}`;
        charBarFill.style.width = `${percent}%`;
        
        // Color coding
        charCount.classList.remove('warning', 'danger');
        charBarFill.classList.remove('warning', 'danger');
        smsCost.classList.remove('multiple');
        
        if (length > 306) {
          charCount.classList.add('danger');
          charBarFill.classList.add('danger');
          smsCost.classList.add('multiple');
        } else if (length > 160) {
          charCount.classList.add('warning');
          charBarFill.classList.add('warning');
          smsCost.classList.add('multiple');
        }
        
        // Enable/disable send button
        const phoneValid = smsPhone && /^[0-9]{9,10}$/.test(smsPhone.value.replace(/\s/g, ''));
        sendBtn.disabled = !(length > 0 && phoneValid);
      }

      if (smsText) {
        smsText.addEventListener('input', updateCharCounter);
      }
      
      if (smsPhone) {
        smsPhone.addEventListener('input', () => {
          // Remove non-digits and leading zero
          let value = smsPhone.value.replace(/\D/g, '');
          if (value.startsWith('0')) {
            value = value.substring(1);
          }
          smsPhone.value = value;
          updateCharCounter();
        });
      }

      // Form submission
      if (smsForm) {
        smsForm.addEventListener('submit', async (e) => {
          e.preventDefault();
          
          if (!smsPhone || !smsText || !sendBtn) return;
          
          const phone = '+46' + smsPhone.value.replace(/\D/g, '');
          const message = smsText.value;
          
          if (!message || phone.length < 12) {
            showToast('Fyll i telefonnummer och meddelande', true);
            return;
          }
          
          sendBtn.disabled = true;
          sendBtn.innerHTML = `
            <svg class="animate-spin" fill="none" viewBox="0 0 24 24" width="20" height="20">
              <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" opacity="0.25"></circle>
              <path fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
            Skickar...
          `;
          
          try {
            const response = await fetch('/api/sms/skicka', {
              method: method,
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ phone, message })
            });
            
            const result = await response.json();
            
            if (response.ok) {
              showToast('✓ SMS skickat!');
              smsPhone.value = '';
              smsText.value = '';
              updateCharCounter();
              document.querySelectorAll('.link-item').forEach(item => item.classList.remove('selected'));
              
              if (messageArea) {
                messageArea.innerHTML = `
                  <div class="message success">
                    ✓ SMS skickat till ${phone.substring(0, 6)}***
                  </div>
                `;
                setTimeout(() => { messageArea.innerHTML = ''; }, 5000);
              }
            } else {
              throw new Error(result.error || 'Kunde inte skicka SMS');
            }
          } catch (err: any) {
            showToast(err.message || 'Fel vid sändning', true);
            if (messageArea) {
              messageArea.innerHTML = `
                <div class="message error">
                  ❌ ${err.message || 'Kunde inte skicka SMS'}
                </div>
              `;
            }
          } finally {
            sendBtn.disabled = false;
            sendBtn.innerHTML = `
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
              </svg>
              Skicka SMS
            `;
            updateCharCounter();
          }
        });
      }
    });

    // Simple toast for dynamic links
    function dlToast(msg: string) {
      const t = document.getElementById('toast');
      if (t) { t.textContent = msg; t.style.background = '#16a34a'; t.classList.add('visible'); setTimeout(() => t.classList.remove('visible'), 2500); }
    }

    // === Dynamic links from Supabase ===
    const addLinkBtn = document.getElementById('addLinkBtn');
    const addLinkForm = document.getElementById('addLinkForm');
    const cancelAddLink = document.getElementById('cancelAddLink');
    const saveAddLink = document.getElementById('saveAddLink');
    const dynamicContainer = document.getElementById('dynamicLinksContainer');

    addLinkBtn?.addEventListener('click', () => {
      addLinkForm!.style.display = addLinkForm!.style.display === 'none' ? 'block' : 'none';
    });
    cancelAddLink?.addEventListener('click', () => {
      addLinkForm!.style.display = 'none';
    });

    saveAddLink?.addEventListener('click', async () => {
      const name = (document.getElementById('newLinkName') as HTMLInputElement).value.trim();
      const code = (document.getElementById('newLinkCode') as HTMLInputElement).value.trim();
      const target = (document.getElementById('newLinkTarget') as HTMLInputElement).value.trim();
      let cat = (document.getElementById('newLinkCategory') as HTMLSelectElement).value;
      if (cat === '__new__') { cat = (document.getElementById('newCategoryInput') as HTMLInputElement).value.trim(); if (!cat) { alert('Ange kategorinamn'); return; } }
      const ext = (document.getElementById('newLinkExternal') as HTMLInputElement).checked;
      if (!name || !code || !target) { alert('Fyll i namn, kortkod och URL'); return; }

      saveAddLink!.textContent = 'Sparar...';
      (saveAddLink as HTMLButtonElement).disabled = true;
      try {
        const editId = (saveAddLink as any).dataset.editId;
        const method = editId ? 'PUT' : 'POST';
        const body = editId 
          ? JSON.stringify({ id: editId, name, short_code: code, target, category: cat, is_external: ext })
          : JSON.stringify({ name, short_code: code, target, category: cat, is_external: ext });
        const res = await fetch('/api/personal/kort-lankar', {
          method: method,
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: body
        });
        const data = await res.json();
        if (res.ok) {
          addLinkForm!.style.display = 'none';
          (document.getElementById('newLinkName') as HTMLInputElement).value = '';
          (document.getElementById('newLinkCode') as HTMLInputElement).value = '';
          (document.getElementById('newLinkTarget') as HTMLInputElement).value = '';
          loadDynamicLinks();
          showToast(editId ? 'L\u00e4nk uppdaterad!' : 'L\u00e4nk skapad!');
          delete (saveAddLink as any).dataset.editId;
          saveAddLink!.textContent = 'Spara';
        } else {
          alert(data.error || 'Kunde inte spara');
        }
      } catch (e) {
        alert('N\u00e5got gick fel');
      } finally {
        saveAddLink!.textContent = 'Spara';
        (saveAddLink as HTMLButtonElement).disabled = false;
      }
    });

    async function loadDynamicLinks() {
      if (!dynamicContainer) return;
      try {
        const res = await fetch('/api/personal/kort-lankar', { credentials: 'include' });
        const data = await res.json();
        const links = data.links || [];
        updateCategoryDropdown(links);
        if (links.length === 0) { dynamicContainer.innerHTML = ''; return; }

        // Inject into existing category sections where possible
        const existingSections = document.querySelectorAll('.category-section[data-category]');
        const existingCats = new Map<string, HTMLElement>();
        existingSections.forEach(s => {
          const cat = (s as HTMLElement).dataset.category || '';
          if (cat) existingCats.set(cat, s.querySelector('.links-list') as HTMLElement);
        });

        // Remove previously injected dynamic items
        document.querySelectorAll('.dynamic-link-item').forEach(el => el.remove());

        const grouped: Record<string, any[]> = {};
        links.forEach((l: any) => { if (!grouped[l.category]) grouped[l.category] = []; grouped[l.category].push(l); });

        const baseDomain = 'www.specialist.se';
        const catIcons: Record<string, string> = { 'Diagnoser': '\uD83E\uDE7A', 'Operationer': '\uD83D\uDD2A', 'Rehab': '\uD83C\uDFCB\uFE0F', 'Info': '\u2139\uFE0F' };
        const copyIcon = '<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>';

        function makeLinkHtml(item: any, cat: string) {
          const url = baseDomain + item.short_code;
          const esc = (s: string) => s.replace(/"/g, '&quot;');
          return '<div class="link-item dynamic-link-item" data-name="' + esc(item.name) + '" data-url="' + url + '" data-category="' + cat + '" data-template="Hej! Se denna l\u00e4nk: {l\u00e4nk} /S\u00f6dermalms Ortopedi">' +
            '<div class="link-info"><div class="link-name">' + item.name + ' <span class="dynamic-badge">Egen</span></div><div class="link-url">' + url + '</div></div>' +
            '<div class="link-actions">' +
            '<button type="button" class="btn btn-copy" data-url="' + url + '" title="Kopiera l\u00e4nk"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg> Kopiera</button>' +
            '<button type="button" class="btn btn-sms" title="Fyll i SMS"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg> SMS</button>' +
            '<button type="button" class="btn btn-edit-link" data-id="' + item.id + '" title="Redigera"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="16" height="16"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>' +
            '<button type="button" class="btn btn-delete-link" data-id="' + item.id + '" title="Ta bort"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="16" height="16"><polyline points="3 6 5 6 21 6"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg></button>' +
            '</div></div>';
        }

        let newCatsHtml = '';
        for (const [cat, items] of Object.entries(grouped)) {
          const existingList = existingCats.get(cat);
          if (existingList) {
            // Inject into existing category
            items.forEach((item: any) => { existingList.insertAdjacentHTML('beforeend', makeLinkHtml(item, cat)); });
          } else {
            // Create new category section
            const icon = catIcons[cat] || '\uD83D\uDCC4';
            newCatsHtml += '<section class="category-section" data-category="' + cat + '"><h2><span>' + icon + '</span> ' + cat + '</h2><div class="links-list">';
            items.forEach((item: any) => { newCatsHtml += makeLinkHtml(item, cat); });
            newCatsHtml += '</div></section>';
          }
        }
        dynamicContainer.innerHTML = newCatsHtml;

        // Attach handlers to ALL dynamic items (both injected and new)
        document.querySelectorAll('.dynamic-link-item .btn-delete-link').forEach(btn => {
          btn.addEventListener('click', async (e) => {
            e.stopPropagation();
            if (!confirm('Ta bort denna l\u00e4nk?')) return;
            try {
              await fetch('/api/personal/kort-lankar?id=' + (btn as HTMLElement).dataset.id, { method: 'DELETE', credentials: 'include' });
              loadDynamicLinks();
              dlToast('L\u00e4nk borttagen');
            } catch (err) { alert('Kunde inte ta bort'); }
          });
        });

        document.querySelectorAll('.dynamic-link-item .btn-edit-link').forEach(btn => {
          btn.addEventListener('click', (e) => {
            e.stopPropagation();
            const el = btn as HTMLElement;
            const item = el.closest('.link-item') as HTMLElement;
            addLinkForm!.style.display = 'block';
            (document.getElementById('newLinkName') as HTMLInputElement).value = item?.dataset.name || '';
            (document.getElementById('newLinkCode') as HTMLInputElement).value = '';
            (document.getElementById('newLinkTarget') as HTMLInputElement).value = '';
            saveAddLink!.textContent = 'Uppdatera';
            (saveAddLink as any).dataset.editId = el.dataset.id;
            window.scrollTo({ top: addLinkForm!.offsetTop - 100, behavior: 'smooth' });
          });
        });

        document.querySelectorAll('.dynamic-link-item .btn-copy').forEach(btn => {
          btn.addEventListener('click', (e) => {
            e.stopPropagation();
            const url = (btn as HTMLElement).dataset.url || '';
            navigator.clipboard.writeText(url).then(() => dlToast('Kopierad: ' + url));
          });
        });

      } catch (err) {
        console.error('Error loading dynamic links:', err);
      }
    }

    // Category handling - allow creating new categories
    const catSelect = document.getElementById('newLinkCategory') as HTMLSelectElement;
    const catInput = document.getElementById('newCategoryInput') as HTMLInputElement;
    catSelect?.addEventListener('change', () => {
      if (catSelect.value === '__new__') {
        catInput!.style.display = 'block';
        catInput!.focus();
      } else {
        catInput!.style.display = 'none';
      }
    });

    // After loading dynamic links, update category dropdown with any new categories
    function updateCategoryDropdown(links: any[]) {
      if (!catSelect) return;
      const existing = new Set(['Diagnoser', 'Operationer', 'Rehab', 'Info']);
      links.forEach((l: any) => existing.add(l.category));
      const current = catSelect.value;
      const opts = Array.from(existing).sort().map(c => '<option value="' + c + '">' + c + '</option>').join('');
      catSelect.innerHTML = opts + '<option value="__new__">+ Ny kategori...</option>';
      if (existing.has(current)) catSelect.value = current;
    }
    // Load on page init
    loadDynamicLinks();
  </script>
</body>
</html>
