              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
            </svg>
            Resurser
          </a>
        </div>

        <div class="nav-section">
          <div class="nav-section-title">Administration</div>
          <a href="/admin/obesvarade" class="nav-link">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Obesvarade frågor
          </a>
          <a href="/senast-redigerade" class="nav-link">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Senast redigerade
          </a>
        </div>
      </nav>

      <div class="sidebar-footer">
        {anvandare && (
          <div class="user-info">
            <div class="user-avatar">
              {anvandare.email.charAt(0).toUpperCase()}
            </div>
            <div class="user-details">
              <span class="user-email">{anvandare.email}</span>
              <span class="user-role">{anvandare.roll === 'admin' ? 'Administratör' : 'Personal'}</span>
            </div>
          </div>
        )}
        <a href="/personal/oversikt?logout=true" class="logout-btn">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" width="18" height="18">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
          </svg>
          Logga ut
        </a>
      </div>
    </aside>

    <!-- Main content -->
    <main class="main-content">
      <div class="page-header">
        <h1 class="page-title">📎 Kopiera länkar & Skicka SMS</h1>
        <p class="page-subtitle">Välj en länk till vänster för att kopiera eller skicka som SMS till patient</p>
      </div>

      {!elksConfigured && (
        <div class="message warning">
          ⚠️ SMS-funktionen är inte konfigurerad. Lägg till 46elks API-nycklar i miljövariablerna för att aktivera.
        </div>
      )}

      <div class="two-columns">
        <!-- Links column -->
        <div class="links-column">
          <div class="search-box">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <input 
              type="text" 
              id="search-input"
              placeholder="Sök länk, kortkod eller kategori..."
            />
          </div>

          <div class="link-filters">
            <select id="linkTypeFilter" class="link-filter-select">
              <option value="">Alla typer</option>
              <option value="internal">Interna länkar</option>
              <option value="external">Externa länkar</option>
              <option value="form">Formulär</option>
              <option value="booking">Bokning</option>
            </select>
            <label class="link-filter-check"><input type="checkbox" id="showArchivedToggle"> Visa arkiverade</label>
          </div>

          <button type="button" id="addLinkBtn" class="btn-add-link" title="Lägg till ny länk">
            + Ny länk
          </button>

          <!-- Inline form for adding new link -->
          <div id="addLinkForm" class="add-link-form" style="display:none;">
            <div class="add-link-form-inner">
              <input type="text" id="newLinkName" placeholder="Namn (t.ex. Distal bicepsruptur)" class="add-link-input">
              <input type="text" id="newLinkCode" placeholder="Kortkod (t.ex. /d/biceps-dist)" class="add-link-input">
              <input type="text" id="newLinkTarget" placeholder="Mål-URL (t.ex. /sjukdomar/axel/...)" class="add-link-input">
              <div class="add-link-category-row"><select id="newLinkCategory" class="add-link-input" style="flex:1"><option value="Diagnoser">Diagnoser</option><option value="Operationer">Operationer</option><option value="Rehab">Rehab</option><option value="Frågeformulär">Frågeformulär</option><option value="Bokningar">Bokningar</option><option value="Info" selected>Info</option><option value="__new__">+ Ny kategori...</option></select><input type="text" id="newCategoryInput" class="add-link-input" placeholder="Kategorinamn..." style="display:none;flex:1"></div>
              <select id="newLinkType" class="add-link-input">
                <option value="internal" selected>Intern länk</option>
                <option value="external">Extern länk</option>
                <option value="form">Formulär</option>
                <option value="booking">Bokning</option>
              </select>
              <textarea id="newLinkSmsTemplate" class="add-link-input" placeholder="Valfri SMS-mall. Använd {namn} och {länk} om du vill."></textarea>
              <textarea id="newLinkDescription" class="add-link-input" placeholder="Intern beskrivning eller kommentar (valfritt)"></textarea>
              <label class="add-link-check"><input type="checkbox" id="newLinkActive" checked> Aktiv länk</label>
              <label class="add-link-check"><input type="checkbox" id="newLinkExternal"> Extern URL</label>
              <div class="add-link-actions">
                <button type="button" id="cancelAddLink" class="btn btn-cancel">Avbryt</button>
                <button type="button" id="saveAddLink" class="btn btn-save">Spara</button>
              </div>
            </div>
          </div>
          <div id="dynamicLinksContainer" aria-live="polite"></div>

          <div id="no-results" class="message warning" style="display: none;">
            Inga länkar hittades i länkbiblioteket.
          </div>
        </div>

        <!-- SMS Panel -->
        <div class="sms-panel">
          <div class="sms-header">
            <h2>
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="24" height="24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
              </svg>
              Skicka SMS
            </h2>
            <p>via 46elks (~0,35 kr/SMS)</p>
          </div>

          <div class="sms-body">
            <div id="sms-message-area"></div>

            {elksConfigured ? (
              <form id="sms-form">
                <div class="sms-field">
                  <label for="sms-phone">📞 Mobilnummer</label>
                  <div class="phone-input-wrapper">
                    <span class="phone-prefix">+46</span>
                    <input 
                      type="tel" 
                      id="sms-phone" 
                      class="phone-input"
                      value={initialPhone}
                      placeholder="701234567"
                      pattern="[0-9]{9}"
                      maxlength="10"
                      required
                    />
                  </div>
                </div>

                <div class="sms-field">
                  <label for="sms-category">📁 Kategori</label>
                  <select id="sms-category">
                    {defaultCategories.map((cat) => (
                      <option value={cat.category} data-template={cat.smsMall}>
                        {cat.icon} {cat.category}
                      </option>
                    ))}
                  </select>
                </div>

                <div class="sms-field">
                  <label for="sms-text">💬 Meddelande</label>
                  <textarea 
                    id="sms-text" 
                    placeholder="Välj en länk till vänster eller skriv eget meddelande..."
                  ></textarea>
                  <div class="char-counter">
                    <span class="char-count" id="char-count">0/160</span>
                    <span class="sms-cost" id="sms-cost">1 SMS</span>
                    <div class="char-bar">
                      <div class="char-bar-fill" id="char-bar-fill" style="width: 0%"></div>
                    </div>
                  </div>
                </div>

                <button type="submit" class="btn-send" id="send-btn" disabled>
                  <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
                  </svg>
                  Skicka SMS
                </button>
              </form>
            ) : (
              <div class="empty-sms">
                <div class="empty-sms-icon">🔧</div>
                <p><strong>SMS ej konfigurerat</strong></p>
                <p style="font-size: 0.85rem; margin-top: 0.5rem;">
                  Lägg till miljövariablerna:<br>
                  <code style="font-size: 0.8rem; background: #f1f5f9; padding: 0.25rem 0.5rem; border-radius: 0.25rem;">ELKS_API_USER</code><br>
                  <code style="font-size: 0.8rem; background: #f1f5f9; padding: 0.25rem 0.5rem; border-radius: 0.25rem;">ELKS_API_PASSWORD</code>
                </p>
              </div>
            )}
          </div>
        </div>
      </div>
    </main>
  </div>

  <!-- Toast -->
  <div class="toast" id="toast">✓ Kopierad!</div>

  <div class="confirm-modal-backdrop" id="confirmModalBackdrop" hidden>
    <div class="confirm-modal" role="dialog" aria-modal="true" aria-labelledby="confirmModalTitle">
      <h3 id="confirmModalTitle">Ta bort länk?</h3>
      <p id="confirmModalText">Den här länken kommer att tas bort.</p>
      <div class="confirm-modal-actions">
        <button type="button" class="confirm-modal-btn cancel" id="confirmModalCancel">Avbryt</button>
        <button type="button" class="confirm-modal-btn confirm" id="confirmModalConfirm">Ta bort</button>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const toast = document.getElementById('toast') as HTMLDivElement | null;
      const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
      const noResultsEl = document.getElementById('no-results') as HTMLDivElement | null;
      const dynamicContainer = document.getElementById('dynamicLinksContainer') as HTMLDivElement | null;
      const linkTypeFilter = document.getElementById('linkTypeFilter') as HTMLSelectElement | null;
      const showArchivedToggle = document.getElementById('showArchivedToggle') as HTMLInputElement | null;

      // Add/edit form elements
      const addLinkBtn = document.getElementById('addLinkBtn') as HTMLButtonElement | null;
      const addLinkForm = document.getElementById('addLinkForm') as HTMLDivElement | null;
      const cancelAddLink = document.getElementById('cancelAddLink') as HTMLButtonElement | null;
      const saveAddLink = document.getElementById('saveAddLink') as HTMLButtonElement | null;
      const catSelect = document.getElementById('newLinkCategory') as HTMLSelectElement | null;
      const catInput = document.getElementById('newCategoryInput') as HTMLInputElement | null;
      const newLinkTypeSelect = document.getElementById('newLinkType') as HTMLSelectElement | null;
      const newLinkExternalCheck = document.getElementById('newLinkExternal') as HTMLInputElement | null;

      // SMS elements
      const smsForm = document.getElementById('sms-form') as HTMLFormElement | null;
      const smsPhone = document.getElementById('sms-phone') as HTMLInputElement | null;
      const smsCategorySelect = document.getElementById('sms-category') as HTMLSelectElement | null;
      const smsText = document.getElementById('sms-text') as HTMLTextAreaElement | null;
      const charCount = document.getElementById('char-count') as HTMLSpanElement | null;
      const smsCost = document.getElementById('sms-cost') as HTMLSpanElement | null;
      const charBarFill = document.getElementById('char-bar-fill') as HTMLDivElement | null;
      const sendBtn = document.getElementById('send-btn') as HTMLButtonElement | null;
      const messageArea = document.getElementById('sms-message-area') as HTMLDivElement | null;

      // Confirm modal
      const confirmModalBackdrop = document.getElementById('confirmModalBackdrop') as HTMLDivElement | null;
      const confirmModalTitle = document.getElementById('confirmModalTitle') as HTMLHeadingElement | null;
      const confirmModalText = document.getElementById('confirmModalText') as HTMLParagraphElement | null;
      const confirmModalCancel = document.getElementById('confirmModalCancel') as HTMLButtonElement | null;
      const confirmModalConfirm = document.getElementById('confirmModalConfirm') as HTMLButtonElement | null;

      const smsEnabled = smsForm !== null;
      const categoryIconsMap: Record<string, string> = {
        Diagnoser: '🩺',
        Operationer: '🔪',
        Rehab: '🏋️',
        'Frågeformulär': '📋',
        Bokningar: '📅',
        Info: 'ℹ️',
      };
      const smsTemplatesMap: Record<string, string> = {
        Diagnoser: 'Hej! Läs mer om {namn}: {länk} /Södermalms Ortopedi',
        Operationer: 'Hej! Du är planerad för {namn}. Läs mer här: {länk} /Södermalms Ortopedi',
        Rehab: 'Hej! Efter din operation, läs igenom rehabinformationen: {länk} /Södermalms Ortopedi',
        'Frågeformulär': 'Hej! Vänligen fyll i detta formulär inför ditt besök: {länk} /Södermalms Ortopedi',
        Bokningar: 'Hej! Här är bokningslänken: {länk} /Södermalms Ortopedi',
        Info: 'Hej! Här finns information som kan vara bra att läsa: {länk} /Södermalms Ortopedi',
      };
      const defaultCategories = ['Diagnoser', 'Operationer', 'Rehab', 'Frågeformulär', 'Bokningar', 'Info'];
      const noResultsDefaultText = 'Inga länkar hittades i länkbiblioteket.';
      const noResultsFilteredText = 'Inga länkar matchar din sökning eller dina filter.';
      const baseDomain = 'www.specialist.se';

      let confirmResolver: ((value: boolean) => void) | null = null;
      let searchDebounce: ReturnType<typeof setTimeout> | undefined;

      const copyButtonMarkup = `
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
        </svg>
        Kopiera
      `;
      const copiedButtonMarkup = `
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
        Kopierad!
      `;
      const smsButtonMarkup = `
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
        </svg>
        SMS
      `;
      const editButtonMarkup = `
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="16" height="16">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
        </svg>
      `;
      const deleteButtonMarkup = `
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="16" height="16">
          <polyline points="3 6 5 6 21 6"></polyline>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"></path>
        </svg>
      `;
      const sendButtonDefaultMarkup = `
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
        </svg>
        Skicka SMS
      `;

      function showToast(text: string, isError = false) {
        if (!toast) return;
        toast.textContent = text;
        toast.style.background = isError ? '#ef4444' : '#16a34a';
        toast.classList.add('show');
        setTimeout(() => toast.classList.remove('show'), 2500);
      }

      function normalizePhoneInput(raw: string) {
        let value = raw.replace(/\D/g, '');
        if (value.startsWith('46')) value = value.substring(2);
        if (value.startsWith('0')) value = value.substring(1);
        return value;
      }

      function normalizeShortCode(code: string) {
        if (!code) return '';
        return code.startsWith('/') ? code : `/${code}`;
      }

      function syncExternalFromType() {
        if (!newLinkTypeSelect || !newLinkExternalCheck) return;
        if (newLinkTypeSelect.value === 'external') {
          newLinkExternalCheck.checked = true;
        }
      }

      function buildPublicUrl(shortCode: string) {
        return `${baseDomain}${normalizeShortCode(shortCode)}`;
      }

      function getDefaultSmsTemplate(category: string) {
        return smsTemplatesMap[category] || 'Hej! Se denna länk: {länk} /Södermalms Ortopedi';
      }

      function getLinkTypeLabel(type: string | undefined, isExternal: boolean) {
        if (type === 'form') return 'Formulär';
        if (type === 'booking') return 'Bokning';
        if (type === 'external' || isExternal) return 'Extern';
        return 'Intern';
      }

      function sortCategories(input: string[]) {
        const priority = new Map(defaultCategories.map((category, index) => [category, index]));
        return [...input].sort((a, b) => {
          const aIndex = priority.has(a) ? priority.get(a)! : Number.MAX_SAFE_INTEGER;
          const bIndex = priority.has(b) ? priority.get(b)! : Number.MAX_SAFE_INTEGER;
          if (aIndex !== bIndex) return aIndex - bIndex;
          return a.localeCompare(b, 'sv');
        });
      }

      function setNoResultsVisible(visible: boolean, filtered: boolean) {
        if (!noResultsEl) return;
        noResultsEl.textContent = filtered ? noResultsFilteredText : noResultsDefaultText;
        noResultsEl.style.display = visible ? 'block' : 'none';
      }

      function updateCharCounter() {
        if (!smsText || !charCount || !smsCost || !charBarFill || !sendBtn) return;

        const length = smsText.value.length;
        const smsCount = length === 0 ? 1 : Math.ceil(length / 160);
        const percent = Math.min((length / 160) * 100, 100);

        charCount.textContent = `${length}/160`;
        smsCost.textContent = `${smsCount} SMS${smsCount > 1 ? ` (~${(smsCount * 0.35).toFixed(2)} kr)` : ''}`;
        charBarFill.style.width = `${percent}%`;

        charCount.classList.remove('warning', 'danger');
        charBarFill.classList.remove('warning', 'danger');
        smsCost.classList.remove('multiple');

        if (length > 306) {
          charCount.classList.add('danger');
          charBarFill.classList.add('danger');
          smsCost.classList.add('multiple');
        } else if (length > 160) {
          charCount.classList.add('warning');
          charBarFill.classList.add('warning');
          smsCost.classList.add('multiple');
        }

        const phoneValid = smsPhone ? /^[0-9]{9,10}$/.test(smsPhone.value.replace(/\s/g, '')) : false;
        sendBtn.disabled = !(length > 0 && phoneValid);
      }

      function closeConfirmModal(confirmed: boolean) {
        if (confirmModalBackdrop) {
          confirmModalBackdrop.classList.remove('show');
          confirmModalBackdrop.hidden = true;
        }
        if (confirmResolver) {
          const resolve = confirmResolver;
          confirmResolver = null;
          resolve(confirmed);
        }
      }

      function askLinkActionConfirm(options: { name: string; shortCode: string; isSystem: boolean }) {
        if (!confirmModalBackdrop || !confirmModalTitle || !confirmModalText || !confirmModalConfirm) {
          return Promise.resolve(window.confirm(options.isSystem ? 'Arkivera denna systemlänk?' : 'Ta bort denna länk?'));
        }

        confirmModalTitle.textContent = options.isSystem ? 'Arkivera systemlänk?' : 'Ta bort länk?';
        confirmModalText.textContent = options.isSystem
          ? `${options.name} (${options.shortCode}) kommer att döljas från listan men finnas kvar i databasen.`
          : `${options.name} (${options.shortCode}) kommer att tas bort permanent.`;
        confirmModalConfirm.textContent = options.isSystem ? 'Arkivera' : 'Ta bort';
        confirmModalConfirm.style.background = options.isSystem ? '#ea580c' : '#dc2626';
        confirmModalBackdrop.hidden = false;
        confirmModalBackdrop.classList.add('show');

        return new Promise<boolean>((resolve) => {
          confirmResolver = resolve;
        });
      }

      function applyInlineButtonStyle(btn: HTMLButtonElement, className: string) {
        btn.style.display = 'inline-flex';
        btn.style.alignItems = 'center';
        btn.style.justifyContent = 'center';
        btn.style.gap = '0.375rem';
        btn.style.padding = '0.5rem 0.875rem';
        btn.style.borderRadius = '0.5rem';
        btn.style.fontSize = '0.85rem';
        btn.style.fontWeight = '500';
        btn.style.lineHeight = '1';
        btn.style.whiteSpace = 'nowrap';
        btn.style.cursor = 'pointer';
        btn.style.border = 'none';
        btn.style.minHeight = '40px';
        btn.style.appearance = 'none';

        if (className.includes('btn-copy')) {
          btn.style.background = '#024264';
          btn.style.color = '#ffffff';
        } else if (className.includes('btn-sms')) {
          btn.style.background = '#0ea5e9';
          btn.style.color = '#ffffff';
        } else if (className.includes('btn-edit-link')) {
          btn.style.background = '#f0f9ff';
          btn.style.color = '#2563eb';
          btn.style.border = '1px solid #bfdbfe';
          btn.style.padding = '0.5rem';
          btn.style.minWidth = '40px';
        } else if (className.includes('btn-delete-link')) {
          btn.style.background = '#fef2f2';
          btn.style.color = '#ef4444';
          btn.style.border = '1px solid #fecaca';
          btn.style.padding = '0.5rem';
          btn.style.minWidth = '40px';
        } else if (className.includes('btn-archive-link')) {
          btn.style.background = '#fff7ed';
          btn.style.color = '#c2410c';
          btn.style.border = '1px solid #fdba74';
        } else if (className.includes('btn-restore-link')) {
          btn.style.background = '#ecfdf5';
          btn.style.color = '#047857';
          btn.style.border = '1px solid #86efac';
        }

        btn.querySelectorAll('svg').forEach((svg) => {
          svg.setAttribute('width', '16');
          svg.setAttribute('height', '16');
          svg.style.width = '16px';
          svg.style.height = '16px';
          svg.style.minWidth = '16px';
          svg.style.minHeight = '16px';
          svg.style.display = 'block';
          svg.style.flexShrink = '0';
        });
      }

      function createActionButton(className: string, title: string, markup: string, dataId?: string, dataUrl?: string) {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = className;
        btn.title = title;
        if (dataId) btn.dataset.id = dataId;
        if (dataUrl) btn.dataset.url = dataUrl;
        btn.innerHTML = markup.trim();
        applyInlineButtonStyle(btn, className);
        return btn;
      }

      function resetAddLinkForm() {
        (document.getElementById('newLinkName') as HTMLInputElement | null)!.value = '';
        (document.getElementById('newLinkCode') as HTMLInputElement | null)!.value = '';
        (document.getElementById('newLinkTarget') as HTMLInputElement | null)!.value = '';
        if (newLinkTypeSelect) newLinkTypeSelect.value = 'internal';
        (document.getElementById('newLinkSmsTemplate') as HTMLTextAreaElement | null)!.value = '';
        (document.getElementById('newLinkDescription') as HTMLTextAreaElement | null)!.value = '';
        (document.getElementById('newLinkActive') as HTMLInputElement | null)!.checked = true;
        if (newLinkExternalCheck) newLinkExternalCheck.checked = false;
        if (catSelect) catSelect.value = 'Info';
        if (catInput) {
          catInput.value = '';
          catInput.style.display = 'none';
        }
        if (saveAddLink) {
          delete (saveAddLink as any).dataset.editId;
          saveAddLink.textContent = 'Spara';
        }
      }

      function updateCategoryDropdown(links: any[]) {
        if (!catSelect) return;
        const categories = new Set<string>(defaultCategories);
        links.forEach((link: any) => {
          if (typeof link?.category === 'string' && link.category.trim().length > 0) {
            categories.add(link.category.trim());
          }
        });
        const ordered = sortCategories(Array.from(categories));
        const previousValue = catSelect.value;

        catSelect.innerHTML = '';
        ordered.forEach((category) => {
          const option = document.createElement('option');
          option.value = category;
          option.textContent = category;
          catSelect.appendChild(option);
        });
        const customOption = document.createElement('option');
        customOption.value = '__new__';
        customOption.textContent = '+ Ny kategori...';
        catSelect.appendChild(customOption);

        if (previousValue === '__new__') {
          catSelect.value = '__new__';
        } else if (categories.has(previousValue)) {
          catSelect.value = previousValue;
        } else {
          catSelect.value = 'Info';
        }
      }

      function updateSmsCategoryDropdown(links: any[]) {
        if (!smsCategorySelect) return;
        const categories = new Set<string>(defaultCategories);
        links.forEach((link: any) => {
          if (typeof link?.category === 'string' && link.category.trim().length > 0) {
            categories.add(link.category.trim());
          }
        });
        const ordered = sortCategories(Array.from(categories));
        const previousValue = smsCategorySelect.value;
        smsCategorySelect.innerHTML = '';

        ordered.forEach((category) => {
          const option = document.createElement('option');
          option.value = category;
          option.dataset.template = getDefaultSmsTemplate(category);
          option.textContent = `${categoryIconsMap[category] || '📄'} ${category}`;
          smsCategorySelect.appendChild(option);
        });

        if (ordered.includes(previousValue)) {
          smsCategorySelect.value = previousValue;
        }
      }

      function fillSmsFromRow(row: HTMLElement) {
        const name = row.dataset.name || '';
        const url = row.dataset.url || '';
        const category = row.dataset.category || '';
        const template = row.dataset.template || getDefaultSmsTemplate(category);

        if (smsCategorySelect && category) smsCategorySelect.value = category;
        if (smsText) {
          smsText.value = template.replace('{namn}', name).replace('{länk}', url);
          updateCharCounter();
        }
        smsPhone?.focus();
        document.querySelectorAll('.link-item').forEach((item) => item.classList.remove('selected'));
        row.classList.add('selected');
      }

      async function loadDynamicLinks() {
        if (!dynamicContainer) return;
        const searchValue = searchInput?.value.trim() || '';
        const linkTypeValue = linkTypeFilter?.value || '';
        const showArchived = showArchivedToggle?.checked || false;
        const hasFilters = Boolean(searchValue || linkTypeValue || showArchived);

        try {
          const params = new URLSearchParams();
          if (searchValue) params.set('search', searchValue);
          if (linkTypeValue) params.set('link_type', linkTypeValue);
          if (showArchived) params.set('include_inactive', 'true');

          const query = params.toString();
          const res = await fetch(`/api/personal/kort-lankar${query ? `?${query}` : ''}`, { credentials: 'include' });
          const data = await res.json().catch(() => ({}));

          if (!res.ok) {
            showToast(data.error || 'Kunde inte läsa länkar', true);
            dynamicContainer.innerHTML = '';
            setNoResultsVisible(true, hasFilters);
            return;
          }

          const links = Array.isArray(data.links) ? data.links : [];
          updateCategoryDropdown(links);
          updateSmsCategoryDropdown(links);

          dynamicContainer.innerHTML = '';
          if (links.length === 0) {
            setNoResultsVisible(true, hasFilters);
            return;
          }

          setNoResultsVisible(false, hasFilters);
          const grouped = new Map<string, any[]>();
          links.forEach((link: any) => {
            const category = typeof link?.category === 'string' && link.category.trim() ? link.category.trim() : 'Info';
            if (!grouped.has(category)) grouped.set(category, []);
            grouped.get(category)!.push(link);
          });

          const orderedCategories = sortCategories(Array.from(grouped.keys()));
          orderedCategories.forEach((category) => {
            const section = document.createElement('section');
            section.className = 'category-section';
            section.dataset.category = category;

            const heading = document.createElement('h2');
            const icon = document.createElement('span');
            icon.textContent = categoryIconsMap[category] || '📄';
            heading.append(icon, document.createTextNode(category));

            const list = document.createElement('div');
            list.className = 'links-list';
            grouped.get(category)?.forEach((item) => {
              list.appendChild(buildDynamicLinkElement(item, category));
            });

            section.append(heading, list);
            dynamicContainer.appendChild(section);
          });
        } catch (error) {
          console.error('Error loading links:', error);
          showToast('Kunde inte läsa länkbiblioteket', true);
          dynamicContainer.innerHTML = '';
          setNoResultsVisible(true, hasFilters);
        }
      }

      function buildDynamicLinkElement(item: any, category: string) {
        const shortCode = normalizeShortCode(item?.short_code || '');
        const url = buildPublicUrl(shortCode);
        const isNarrow = window.innerWidth <= 768;
        const isActive = item?.is_active !== false;
        const isSystem = Boolean(item?.is_system);
        const isExternal = Boolean(item?.is_external);

        const row = document.createElement('div');
        row.className = 'link-item dynamic-link-item';
        if (!isActive) row.classList.add('is-archived');
        row.style.display = 'flex';
        row.style.alignItems = isNarrow ? 'stretch' : 'center';
        row.style.flexDirection = isNarrow ? 'column' : 'row';
        row.style.padding = '0.875rem 1rem';
        row.style.borderBottom = '1px solid #f1f5f9';
        row.style.cursor = 'pointer';

        row.dataset.name = item?.name || '';
        row.dataset.url = url;
        row.dataset.category = category;
        row.dataset.shortCode = shortCode;
        row.dataset.target = item?.target || '';
        row.dataset.id = item?.id || '';
        row.dataset.isExternal = isExternal ? '1' : '0';
        row.dataset.isSystem = isSystem ? '1' : '0';
        row.dataset.isActive = isActive ? '1' : '0';
        row.dataset.linkType = item?.link_type || '';
        row.dataset.smsTemplate = item?.sms_template || '';
        row.dataset.description = item?.description || '';
        row.dataset.template = item?.sms_template || getDefaultSmsTemplate(category);

        const info = document.createElement('div');
        info.className = 'link-info';
        info.style.flex = '1';
        info.style.minWidth = '0';

        const name = document.createElement('div');
        name.className = 'link-name';
        name.style.display = 'flex';
        name.style.alignItems = 'center';
        name.style.flexWrap = 'wrap';
        name.style.gap = '0.35rem';
        name.style.fontWeight = '500';
        name.style.color = '#1e293b';
        name.style.marginBottom = '0.125rem';
        name.append(document.createTextNode(item?.name || 'Namnlös länk'));

        const sourceBadge = document.createElement('span');
        sourceBadge.className = `dynamic-badge ${isSystem ? 'dynamic-badge-system' : 'dynamic-badge-custom'}`;
        sourceBadge.textContent = isSystem ? 'System' : 'Egen';

        const typeBadge = document.createElement('span');
        typeBadge.className = 'dynamic-badge dynamic-badge-type';
        typeBadge.textContent = getLinkTypeLabel(item?.link_type, isExternal);

        name.appendChild(sourceBadge);
        name.appendChild(typeBadge);
        if (!isActive) {
          const archivedBadge = document.createElement('span');
          archivedBadge.className = 'dynamic-badge dynamic-badge-archived';
          archivedBadge.textContent = 'Arkiverad';
          name.appendChild(archivedBadge);
        }

        const urlEl = document.createElement('div');
        urlEl.className = 'link-url';
        urlEl.style.fontSize = '0.8rem';
        urlEl.style.color = '#64748b';
        urlEl.style.fontFamily = 'monospace';
        urlEl.textContent = url;

        info.append(name, urlEl);

        const actions = document.createElement('div');
        actions.className = 'link-actions';
        actions.style.display = 'flex';
        actions.style.flexDirection = 'row';
        actions.style.flexWrap = 'wrap';
        actions.style.alignItems = 'center';
        actions.style.gap = '0.5rem';
        actions.style.flexShrink = '0';
        actions.style.marginLeft = isNarrow ? '0' : '1rem';
        actions.style.marginTop = isNarrow ? '0.75rem' : '0';
        actions.style.justifyContent = 'flex-start';

        const copyBtn = createActionButton('btn btn-copy', 'Kopiera länk', copyButtonMarkup, item?.id, url);
        actions.appendChild(copyBtn);

        if (smsEnabled) {
          const smsBtn = createActionButton('btn btn-sms', 'Fyll i SMS', smsButtonMarkup, item?.id);
          actions.appendChild(smsBtn);
        }

        const editBtn = createActionButton('btn btn-edit-link', 'Redigera', editButtonMarkup, item?.id);
        actions.appendChild(editBtn);

        const actionClass = !isActive
          ? 'btn btn-restore-link'
          : (isSystem ? 'btn btn-archive-link' : 'btn btn-delete-link');
        const actionTitle = !isActive
          ? 'Återställ'
          : (isSystem ? 'Arkivera' : 'Ta bort');
        const actionBtn = createActionButton(actionClass, actionTitle, deleteButtonMarkup, item?.id);
        actions.appendChild(actionBtn);

        row.append(info, actions);
        bindDynamicLinkRow(row);
        return row;
      }

      function bindDynamicLinkRow(row: HTMLElement) {
        const copyBtn = row.querySelector('.btn-copy') as HTMLButtonElement | null;
        const smsBtn = row.querySelector('.btn-sms') as HTMLButtonElement | null;
        const editBtn = row.querySelector('.btn-edit-link') as HTMLButtonElement | null;
        const actionBtn = row.querySelector('.btn-delete-link, .btn-archive-link, .btn-restore-link') as HTMLButtonElement | null;

        copyBtn?.addEventListener('click', async (event) => {
          event.stopPropagation();
          const url = row.dataset.url || '';
          if (!url) return;
          try {
            await navigator.clipboard.writeText(url);
            copyBtn.classList.add('copied');
            copyBtn.innerHTML = copiedButtonMarkup;
            applyInlineButtonStyle(copyBtn, 'btn btn-copy');
            showToast('✓ Länk kopierad');
            setTimeout(() => {
              copyBtn.classList.remove('copied');
              copyBtn.innerHTML = copyButtonMarkup;
              applyInlineButtonStyle(copyBtn, 'btn btn-copy');
            }, 1800);
          } catch {
            showToast('Kunde inte kopiera länken', true);
          }
        });

        smsBtn?.addEventListener('click', (event) => {
          event.stopPropagation();
          fillSmsFromRow(row);
        });

        editBtn?.addEventListener('click', (event) => {
          event.stopPropagation();
          if (!addLinkForm || !saveAddLink) return;
          addLinkForm.style.display = 'block';

          (document.getElementById('newLinkName') as HTMLInputElement | null)!.value = row.dataset.name || '';
          (document.getElementById('newLinkCode') as HTMLInputElement | null)!.value = row.dataset.shortCode || '';
          (document.getElementById('newLinkTarget') as HTMLInputElement | null)!.value = row.dataset.target || '';
          const resolvedType = row.dataset.linkType || (row.dataset.isExternal === '1' ? 'external' : 'internal');
          if (newLinkTypeSelect) newLinkTypeSelect.value = resolvedType;
          (document.getElementById('newLinkSmsTemplate') as HTMLTextAreaElement | null)!.value = row.dataset.smsTemplate || '';
          (document.getElementById('newLinkDescription') as HTMLTextAreaElement | null)!.value = row.dataset.description || '';
          (document.getElementById('newLinkActive') as HTMLInputElement | null)!.checked = row.dataset.isActive !== '0';
          if (newLinkExternalCheck) newLinkExternalCheck.checked = row.dataset.isExternal === '1' || resolvedType === 'external';

          if (catSelect) {
            if (Array.from(catSelect.options).some((option) => option.value === row.dataset.category)) {
              catSelect.value = row.dataset.category || 'Info';
              if (catInput) catInput.style.display = 'none';
            } else {
              catSelect.value = '__new__';
              if (catInput) {
                catInput.style.display = 'block';
                catInput.value = row.dataset.category || '';
              }
            }
          }

          saveAddLink.textContent = 'Uppdatera';
          (saveAddLink as any).dataset.editId = row.dataset.id || '';
          window.scrollTo({ top: addLinkForm.offsetTop - 100, behavior: 'smooth' });
        });

        actionBtn?.addEventListener('click', async (event) => {
          event.stopPropagation();
          const id = row.dataset.id;
          if (!id) return;
          const isSystem = row.dataset.isSystem === '1';
          const isActive = row.dataset.isActive !== '0';

          if (!isActive) {
            try {
              const response = await fetch('/api/personal/kort-lankar', {
                method: 'PATCH',
                credentials: 'include',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id, is_active: true }),
              });
              const result = await response.json().catch(() => ({}));
              if (!response.ok) {
                showToast(result.error || 'Kunde inte återställa länken', true);
                return;
              }
              await loadDynamicLinks();
              showToast('Länk återställd');
            } catch {
              showToast('Kunde inte återställa länken', true);
            }
            return;
          }

          const confirmed = await askLinkActionConfirm({
            name: row.dataset.name || 'Länk',
            shortCode: row.dataset.shortCode || '',
            isSystem,
          });
          if (!confirmed) return;

          try {
            const response = isSystem
              ? await fetch('/api/personal/kort-lankar', {
                  method: 'PATCH',
                  credentials: 'include',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ id, is_active: false }),
                })
              : await fetch(`/api/personal/kort-lankar?id=${encodeURIComponent(id)}`, {
                  method: 'DELETE',
                  credentials: 'include',
                });

            const result = await response.json().catch(() => ({}));
            if (!response.ok) {
              showToast(result.error || 'Kunde inte genomföra åtgärden', true);
              return;
            }

            await loadDynamicLinks();
            showToast(isSystem ? 'Systemlänk arkiverad' : 'Länk borttagen');
          } catch {
            showToast('Kunde inte genomföra åtgärden', true);
          }
        });

        row.addEventListener('click', (event) => {
          const target = event.target as HTMLElement;
          if (target.closest('.btn') || !smsEnabled) return;
          smsBtn?.click();
        });
      }

      addLinkBtn?.addEventListener('click', () => {
        if (!addLinkForm) return;
        const shouldOpen = addLinkForm.style.display === 'none' || addLinkForm.style.display === '';
        addLinkForm.style.display = shouldOpen ? 'block' : 'none';
        if (shouldOpen && !(saveAddLink as any)?.dataset?.editId) {
          resetAddLinkForm();
        }
      });

      cancelAddLink?.addEventListener('click', () => {
        if (addLinkForm) addLinkForm.style.display = 'none';
        resetAddLinkForm();
      });

      saveAddLink?.addEventListener('click', async () => {
        const name = (document.getElementById('newLinkName') as HTMLInputElement | null)?.value.trim() || '';
        const code = (document.getElementById('newLinkCode') as HTMLInputElement | null)?.value.trim() || '';
        const target = (document.getElementById('newLinkTarget') as HTMLInputElement | null)?.value.trim() || '';
        const selectedLinkType = newLinkTypeSelect?.value.trim() || '';
        const smsTemplate = (document.getElementById('newLinkSmsTemplate') as HTMLTextAreaElement | null)?.value.trim() || '';
        const description = (document.getElementById('newLinkDescription') as HTMLTextAreaElement | null)?.value.trim() || '';
        const isActive = (document.getElementById('newLinkActive') as HTMLInputElement | null)?.checked ?? true;
        const ext = newLinkExternalCheck?.checked ?? false;
        const linkType = selectedLinkType || (ext ? 'external' : 'internal');
        const isExternal = ext || linkType === 'external';
        let category = catSelect?.value || 'Info';

        if (category === '__new__') {
          category = catInput?.value.trim() || '';
          if (!category) {
            showToast('Ange kategorinamn', true);
            return;
          }
        }

        if (!name || !code || !target) {
          showToast('Fyll i namn, kortkod och URL', true);
          return;
        }

        saveAddLink.textContent = 'Sparar...';
        saveAddLink.disabled = true;

        try {
          const editId = (saveAddLink as any).dataset.editId;
          const method = editId ? 'PUT' : 'POST';
          const payload = {
            name,
            short_code: normalizeShortCode(code),
            target,
            category,
            is_external: isExternal,
            is_active: isActive,
            link_type: linkType,
            sms_template: smsTemplate || null,
            description: description || null,
          };
          const body = editId
            ? JSON.stringify({ id: editId, ...payload })
            : JSON.stringify(payload);

          const response = await fetch('/api/personal/kort-lankar', {
            method,
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body,
          });
          const result = await response.json().catch(() => ({}));

          if (!response.ok) {
            showToast(result.error || 'Kunde inte spara', true);
            return;
          }

          if (addLinkForm) addLinkForm.style.display = 'none';
          resetAddLinkForm();
          await loadDynamicLinks();
          showToast(editId ? 'Länk uppdaterad' : 'Länk skapad');
        } catch {
          showToast('Något gick fel vid sparning', true);
        } finally {
          saveAddLink.textContent = 'Spara';
          saveAddLink.disabled = false;
        }
      });

      catSelect?.addEventListener('change', () => {
        if (!catInput || !catSelect) return;
        if (catSelect.value === '__new__') {
          catInput.style.display = 'block';
          catInput.focus();
        } else {
          catInput.style.display = 'none';
        }
      });

      newLinkTypeSelect?.addEventListener('change', () => {
        syncExternalFromType();
      });

      newLinkExternalCheck?.addEventListener('change', () => {
        if (!newLinkExternalCheck.checked && newLinkTypeSelect?.value === 'external') {
          newLinkTypeSelect.value = 'internal';
        }
      });

      searchInput?.addEventListener('input', () => {
        if (searchDebounce) clearTimeout(searchDebounce);
        searchDebounce = setTimeout(() => {
          void loadDynamicLinks();
        }, 160);
      });
      linkTypeFilter?.addEventListener('change', () => { void loadDynamicLinks(); });
      showArchivedToggle?.addEventListener('change', () => { void loadDynamicLinks(); });

      confirmModalCancel?.addEventListener('click', () => closeConfirmModal(false));
      confirmModalConfirm?.addEventListener('click', () => closeConfirmModal(true));
      confirmModalBackdrop?.addEventListener('click', (event) => {
        if (event.target === confirmModalBackdrop) closeConfirmModal(false);
      });
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && confirmResolver) closeConfirmModal(false);
      });

      smsText?.addEventListener('input', updateCharCounter);
      smsPhone?.addEventListener('input', () => {
        let value = smsPhone.value.replace(/\D/g, '');
        if (value.startsWith('0')) value = value.substring(1);
        smsPhone.value = value;
        updateCharCounter();
      });

      if (smsForm && smsPhone && smsText && sendBtn) {
        smsForm.addEventListener('submit', async (event) => {
          event.preventDefault();
          const phone = `+46${smsPhone.value.replace(/\D/g, '')}`;
          const message = smsText.value;

          if (!message || phone.length < 12) {
            showToast('Fyll i telefonnummer och meddelande', true);
            return;
          }

          sendBtn.disabled = true;
          sendBtn.innerHTML = `
            <svg class="animate-spin" fill="none" viewBox="0 0 24 24" width="20" height="20">
              <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" opacity="0.25"></circle>
              <path fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
            Skickar...
          `;

          try {
            const response = await fetch('/api/sms/skicka', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ phone, message }),
            });
            const result = await response.json().catch(() => ({}));

            if (!response.ok) {
              throw new Error(result.error || 'Kunde inte skicka SMS');
            }

            showToast('✓ SMS skickat');
            smsPhone.value = '';
            smsText.value = '';
            updateCharCounter();
            document.querySelectorAll('.link-item').forEach((item) => item.classList.remove('selected'));
            if (messageArea) {
              messageArea.innerHTML = `
                <div class="message success">
                  ✓ SMS skickat till ${phone.substring(0, 6)}***
                </div>
              `;
              setTimeout(() => { messageArea.innerHTML = ''; }, 5000);
            }
          } catch (error: any) {
            showToast(error?.message || 'Fel vid sändning', true);
            if (messageArea) {
              messageArea.innerHTML = `
                <div class="message error">
                  ❌ ${error?.message || 'Kunde inte skicka SMS'}
                </div>
              `;
            }
          } finally {
            sendBtn.disabled = false;
            sendBtn.innerHTML = sendButtonDefaultMarkup;
            updateCharCounter();
          }
        });
      }

      const urlParams = new URLSearchParams(window.location.search);
      const phoneParam = urlParams.get('phone') || urlParams.get('mobil') || urlParams.get('tel');
      if (smsPhone && phoneParam) {
        smsPhone.value = normalizePhoneInput(phoneParam);
        smsPhone.focus();
      }

      updateCharCounter();
      void loadDynamicLinks();
    });
  </script>
</body>
</html>

