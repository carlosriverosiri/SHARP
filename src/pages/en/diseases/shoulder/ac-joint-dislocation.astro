---
import { Image, getImage } from 'astro:assets';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import RefLink from '../../../../components/RefLink.astro';
import RefDrawer from '../../../../components/RefDrawer.astro';
import AcJointRtsRtplDashboard from '../../../../components/AcJointRtsRtplDashboard.astro';
import AcJointRtwCalculator from '../../../../components/AcJointRtwCalculator.astro';
import ContentListIcon from '../../../../components/ContentListIcon.astro';
import Icon from '../../../../components/Icon.astro';

import imgClinicalBump from '../../../../assets/images/ac-joint-dislocation/AC-lux_nyckelbenet_ur_led600.png';
import imgRockwood1 from '../../../../assets/images/ac-joint-dislocation/ac-lux-typ-1.webp';
import imgRockwood2 from '../../../../assets/images/ac-joint-dislocation/ac-lux-typ-2.webp';
import imgRockwood3 from '../../../../assets/images/ac-joint-dislocation/ac-lux-typ-3.webp';
import imgRockwood5 from '../../../../assets/images/ac-joint-dislocation/ac-lux-typ-5.webp';
import imgRockwoodV from '../../../../assets/images/ac-joint-dislocation/ac-lux-typ-v.webp';
import imgType4 from '../../../../assets/images/ac-joint-dislocation/ac-joint-dislocation-type-4.jpg';
import imgDiagram35 from '../../../../assets/images/ac-joint-dislocation/ac-dislocation-type-3-or-5.svg';
import imgDogBone from '../../../../assets/images/ac-joint-dislocation/ac_dog_bone_technique_0-large.png';
import imgHookPlate from '../../../../assets/images/ac-joint-dislocation/hook-plate-ac-joint.webp';

const ogShare = await getImage({ src: imgClinicalBump, width: 1200 });
const ogImageUrl = new URL(ogShare.src, Astro.site).href;

const authorName = 'Dr. Carlos Rivero Siri';
const authorUrl = 'https://sodermalmsortopedi.se/om-oss/vart-team/dr-carlos-rivero-siri';
const authorImage = '/images/team/carlos-rivero-siri.webp';
const currentDate = new Date().toISOString().split('T')[0];
const lastMedicalReview = '21 March 2026';

const tableOfContents = [
  { id: 'overview', title: 'The instability X-rays don\u2019t show', icon: '1' },
  { id: 'horizontal-instability', title: 'Horizontal instability', icon: '2' },
  { id: 'symptoms', title: 'Symptoms', icon: '3' },
  { id: 'diagnosis', title: 'Diagnosis & imaging', icon: '4' },
  { id: 'classification', title: 'Rockwood classification', icon: '5' },
  { id: 'treatment', title: 'Treatment', icon: '6' },
  { id: 'surgery', title: 'Surgical techniques', icon: '7' },
  { id: 'work-sport', title: 'Work & return to sport', icon: '8' },
  { id: 'expert', title: 'Expert perspective', icon: 'expert' },
  { id: 'faq', title: 'FAQ', icon: 'faq' },
  { id: 'references', title: 'References', icon: 'references' },
];

/* Numbered [1]–[16]; inline RefLink id matches citation index */
const references = [
  {
    id: '1',
    text: 'Michael R, Sinclair K, Bédard L, et al. A ten-year prospective randomized trial comparing non-operative treatment to hook plate fixation for Rockwood III acromio-clavicular dislocation. Orthop Traumatol Surg Res. 2025.',
    url: 'https://doi.org/10.1016/j.otsr.2025.104159',
  },
  {
    id: '2',
    text: 'Marín Fermín T, Hong CK, Lacheta L, et al. Surgical treatment of acute high-grade acromioclavicular joint dislocations. J Exp Orthop. 2025.',
    url: 'https://doi.org/10.1002/jeo2.70173',
  },
  {
    id: '3',
    text: 'Bianco Prevot L, Accetta R, Fozzato S, et al. Surgical vs conservative: what is the best treatment of acute Rockwood III acromioclavicular joint dislocation? A systematic review and meta-analysis. EFORT Open Rev. 2025.',
    url: 'https://doi.org/10.1530/EOR-2024-0077',
  },
  {
    id: '4',
    text: 'Xie C, Fan S, Chen L, et al. Comparative efficacy of operative versus conservative treatment for Rockwood type III acromioclavicular joint dislocation: a systematic review and meta-analysis of RCTs. BMC Musculoskelet Disord. 2024.',
    url: 'https://doi.org/10.1186/s12891-024-08100-x',
  },
  {
    id: '5',
    text: 'Albishi W, AlShayhan F, Alfridy A, et al. Acromioclavicular joint separation: Controversies and treatment algorithm. Orthop Rev. 2024.',
    url: 'https://doi.org/10.52965/001c.94037',
  },
  {
    id: '6',
    text: 'Yan Y, Liao M, Lai H, et al. Comparison of Effectiveness and Safety in Treating Acute Acromioclavicular Joint Dislocation with Five Different Surgical Procedures: A Systematic Review and Network Meta-Analysis. Orthop Surg. 2023.',
    url: 'https://doi.org/10.1111/os.13731',
  },
  {
    id: '7',
    text: 'Velasquez Garcia A, Liendo R, Ekdahl M, et al. The Reliability of Acromioclavicular Joint Dislocation Classification Systems: A Comparison Between the Rockwood and Kraus Classifications. Orthop J Sports Med. 2023.',
    url: 'https://doi.org/10.1177/23259671221149391',
  },
  {
    id: '8',
    text: 'Boström Windhamre H, von Heideken J, Une-Larsson V, et al. No difference in clinical outcome at 2-year follow-up in patients with type III and V acromioclavicular joint dislocation treated with hook plate or physiotherapy: a randomized controlled trial. J Shoulder Elbow Surg. 2022.',
    url: 'https://doi.org/10.1016/j.jse.2021.12.003',
  },
  {
    id: '9',
    text: 'Berthold DP, Muench LN, Dyrna F, et al. Current concepts in acromioclavicular joint (AC) instability – a proposed treatment algorithm for acute and chronic AC-joint surgery. BMC Musculoskelet Disord. 2022.',
    url: 'https://doi.org/10.1186/s12891-022-05935-0',
  },
  {
    id: '10',
    text: 'Rosso C, Martetschläger F, Saccomanno MF, et al. High degree of consensus achieved regarding diagnosis and treatment of acromioclavicular joint instability among ESA-ESSKA members. Knee Surg Sports Traumatol Arthrosc. 2021.',
    url: 'https://doi.org/10.1007/s00167-020-06286-w',
  },
  {
    id: '11',
    text: 'Petri M, Warth RJ, Greenspoon JA, et al. Clinical Results After Conservative Management for Grade III Acromioclavicular Joint Injuries: Does Eventual Surgery Affect Overall Outcomes? Arthroscopy. 2016.',
    url: 'https://doi.org/10.1016/j.arthro.2015.11.024',
  },
  {
    id: '12',
    text: 'Aliberti GM, Kraeutler MJ, Trojan JD, Mulcahey MK. Horizontal Instability of the Acromioclavicular Joint: A Systematic Review. Am J Sports Med. 2020;48(2):504-510.',
    url: 'https://doi.org/10.1177/0363546519831013',
  },
  {
    id: '13',
    text: 'Tauber M, Koller H, Hitzl W, Resch H. Dynamic Radiologic Evaluation of Horizontal Instability in Acute Acromioclavicular Joint Dislocations. Am J Sports Med. 2010;38(6):1188-1195.',
    url: 'https://doi.org/10.1177/0363546510361951',
  },
  {
    id: '14',
    text: 'Kraus N, Hann C, Gerhardt C, Scheibel M. Dynamic instability of the acromioclavicular joint. Obere Extremität. 2018;13(4):279-285.',
    url: 'https://doi.org/10.1007/s11678-018-0469-x',
  },
  {
    id: '15',
    text: 'Geyer S, Achtnich AE, Voss A, et al. Iatrogenic instability of the acromioclavicular joint leads to ongoing impairment of shoulder function even following secondary surgical stabilization. Arch Orthop Trauma Surg. 2023;143(4):1877-1886.',
    url: 'https://doi.org/10.1007/s00402-022-04387-4',
  },
  {
    id: '16',
    text: 'Groot C de, Verstift DE, Heisen J, van Deurzen DFP, van den Bekerom MPJ. Management of Acromioclavicular Injuries – Current Concepts. Orthop Res Rev. 2023;15:1–12.',
    url: 'https://doi.org/10.2147/ORR.S340531',
  },
];

const schemaData = {
  '@context': 'https://schema.org',
  '@type': 'MedicalWebPage',
  name: 'AC joint dislocation — classification & treatment',
  author: { '@type': 'Person', name: authorName, url: authorUrl },
  dateModified: currentDate,
  reviewedBy: { '@type': 'Person', name: authorName, url: authorUrl },
  about: {
    '@type': 'MedicalCondition',
    name: 'Acromioclavicular joint dislocation',
    possibleTreatment: [
      { '@type': 'MedicalTherapy', name: 'Conservative treatment and rehabilitation' },
      { '@type': 'MedicalTherapy', name: 'Surgical AC joint stabilisation' },
    ],
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Does every Rockwood type III AC dislocation need surgery?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No. High-quality reviews and trials show similar long-term functional scores after conservative care versus early surgery for many type III injuries. A structured non-operative trial is standard before considering surgery, unless specific instability or patient factors apply.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is a hook plate or cortical button better for AC joint dislocation?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Network meta-analyses summarise multiple techniques. Modern cortical button / suspension constructs avoid a subacromial hook and often remove the need for routine hardware removal compared with hook plates, which are associated with high planned reoperation rates for implant removal and impingement risk.',
      },
    },
  ],
};
---

<BaseLayout
  title="AC joint dislocation — types, treatment & surgery | Södermalms Ortopedi"
  description="Acromioclavicular (AC) joint dislocation: Rockwood types, when X-ray is enough, conservative vs surgical treatment, hook plate vs cortical buttons, and return to work and sport."
  image={ogImageUrl}
  alternateUrl="/sjukdomar/axel/nyckelbensleden-ur-led"
  type="article"
>
  <meta slot="head" property="article:author" content={authorName} />
  <meta slot="head" property="article:section" content="Shoulder" />
  <meta
    slot="head"
    name="keywords"
    content="AC joint dislocation, acromioclavicular joint injury, shoulder separation, Rockwood classification, AC joint surgery, hook plate, conservative treatment, return to sport"
  />
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify(schemaData)} />
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)} />
  <script
    is:inline
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://sodermalmsortopedi.se/en/' },
        { '@type': 'ListItem', position: 2, name: 'Diseases', item: 'https://sodermalmsortopedi.se/en/diseases' },
        { '@type': 'ListItem', position: 3, name: 'Shoulder', item: 'https://sodermalmsortopedi.se/en/diseases/shoulder' },
        {
          '@type': 'ListItem',
          position: 4,
          name: 'AC joint dislocation',
          item: 'https://sodermalmsortopedi.se/en/diseases/shoulder/ac-joint-dislocation',
        },
      ],
    })}
  />

  <!-- HERO -->
  <section class="bg-gradient-to-br from-slate-900 via-slate-800 to-sky-900 text-white pt-8 pb-12 relative">
    <div class="max-w-[1500px] mx-auto px-4 sm:px-6">
      <div class="flex flex-wrap items-center gap-2 text-sm mb-4">
        <a href="/en" class="text-slate-400 hover:text-white">Home</a>
        <span class="text-slate-500">/</span>
        <a href="/en/diseases" class="text-slate-400 hover:text-white">Diseases</a>
        <span class="text-slate-500">/</span>
        <span class="text-sky-400">Shoulder</span>
      </div>

      <div class="grid lg:grid-cols-3 gap-8 items-end">
        <div class="lg:col-span-2">
          <span
            class="inline-block py-1 px-3 rounded bg-sky-600/30 text-sky-300 text-xs font-bold mb-3 tracking-wider uppercase"
          >
            Shoulder instability
          </span>
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-black mb-4 leading-tight tracking-tight">
            AC joint dislocation
          </h1>
          <p class="text-slate-300 text-base md:text-lg max-w-2xl leading-relaxed">
            Treatment depends on Rockwood type, horizontal stability, chronicity, and patient goals<RefLink id="5" text="Treatment algorithms" url={references[4].url} /><RefLink id="9" text="Current concepts" url={references[8].url} />.
          </p>
        </div>

        <div class="bg-white/10 backdrop-blur rounded-xl p-4 border border-white/10">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-full overflow-hidden border-2 border-sky-400 shrink-0">
              <img src={authorImage} alt={authorName} class="w-full h-full object-cover" />
            </div>
            <div>
              <p class="text-xs text-sky-300 uppercase tracking-wider font-bold">Medically reviewed</p>
              <a href={authorUrl} class="text-sm font-bold text-white hover:text-sky-200">{authorName}</a>
            </div>
          </div>
          <div class="text-xs text-slate-400">Specialist in orthopaedics & shoulder surgery</div>
          <div class="mt-2 pt-2 border-t border-white/10 flex items-center gap-2">
            <svg class="w-3.5 h-3.5 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
            <span class="text-xs text-slate-300">Updated: <strong class="text-white">{lastMedicalReview}</strong></span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TL;DR -->
  <section class="bg-white border-b border-slate-200">
    <div class="max-w-[1500px] mx-auto px-0 sm:px-6 py-4 sm:py-6">
      <div class="bg-gradient-to-r from-sky-50 to-indigo-50 sm:rounded-xl px-4 py-4 sm:p-5 sm:border sm:border-sky-200">
        <div class="flex items-start gap-3 sm:gap-4">
          <div class="w-8 h-8 sm:w-10 sm:h-10 rounded-full bg-sky-100 flex items-center justify-center shrink-0">
            <svg class="w-4 h-4 sm:w-5 sm:h-5 text-sky-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <div>
            <h2 class="font-bold text-slate-800 text-sm uppercase tracking-wide mb-2">
              Key points
            </h2>
            <p class="text-slate-700 text-sm leading-relaxed mb-3">
                <strong>Types I–II</strong> are treated conservatively.<strong> Type III</strong> usually starts with structured
                non-operative care; long-term functional scores often match early surgery in trials<RefLink
                  id="3"
                  text="Meta-analysis"
                  url={references[2].url}
                /><RefLink id="4" text="RCT review" url={references[3].url} />. <strong>Surgery</strong> improves
                radiographic alignment but not consistently clinical outcome; complication rates are higher with
                surgery<RefLink id="1" text="Hook plate trial" url={references[0].url} />. When operating, many surgeons
                favour <strong>cortical button / suspension</strong> constructs over <strong>hook plates</strong> for
                biomechanics and to avoid routine second surgery for hardware removal<RefLink
                  id="2"
                  text="High-grade AC"
                  url={references[1].url}
                /><RefLink id="6" text="Network meta-analysis" url={references[5].url} />.
            </p>
            <div class="grid sm:grid-cols-3 gap-3 text-xs">
              <div class="flex items-center gap-2 bg-white/70 rounded-lg p-2">
                <span class="text-green-600 font-bold">✓</span>
                <span><strong>True AP + Zanca</strong> usually sufficient for diagnosis<RefLink
                    id="10"
                    text="Consensus"
                    url={references[9].url}
                  /></span>
              </div>
              <div class="flex items-center gap-2 bg-white/70 rounded-lg p-2">
                <span class="text-sky-600 font-bold">✓</span>
                <span><strong>~18–20%</strong> high-grade injuries have associated intra-articular lesions<RefLink
                    id="9"
                    text="Algorithm"
                    url={references[8].url}
                  /></span>
              </div>
              <div class="flex items-center gap-2 bg-white/70 rounded-lg p-2">
                <span class="text-indigo-600 font-bold">✓</span>
                <span><strong>Type V</strong>: RCT data challenge “always operate”<RefLink
                    id="8"
                    text="JSES 2022"
                    url={references[7].url}
                  /></span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <nav class="mt-3 sm:mt-4 lg:hidden">
        <details class="bg-sky-50 sm:rounded-lg sm:border sm:border-sky-200">
          <summary class="flex items-center justify-between px-4 py-3 sm:p-3 cursor-pointer select-none">
            <span class="font-bold text-sky-800 text-sm uppercase tracking-wide">Contents</span>
            <svg class="w-4 h-4 text-sky-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="px-4 sm:px-3 pb-2 flex flex-wrap gap-2">
            {tableOfContents.map((item) => (
              <a
                href={`#${item.id}`}
                class="inline-flex items-center gap-1.5 text-sm font-medium text-slate-700 hover:text-sky-700 bg-white px-2.5 py-1 rounded-full border border-slate-200"
              >
                <ContentListIcon icon={item.icon} variant="sm" accent="sky" />
                {item.title}
              </a>
            ))}
          </div>
        </details>
      </nav>
    </div>
  </section>

  <section class="bg-slate-50 py-6 md:py-10">
    <div class="max-w-[1500px] mx-auto px-0 sm:px-4 md:px-6">
      <div class="grid lg:grid-cols-12 gap-0 sm:gap-4 md:gap-6 lg:gap-8">
        <!-- LEFT -->
        <aside class="lg:col-span-3 order-2 lg:order-1 min-w-0">
          <div class="lg:sticky lg:top-6 space-y-4">
            <figure class="md:bg-white md:rounded-xl md:shadow-sm md:border md:border-slate-200 overflow-hidden m-0">
              <Image
                src={imgClinicalBump}
                alt="Visible step-off deformity at the acromioclavicular joint after dislocation"
                class="w-full h-auto"
                widths={[320, 480]}
                sizes="(max-width: 1024px) 100vw, 280px"
              />
              <figcaption class="text-[11px] text-slate-500 px-2 py-1.5 bg-slate-50">
                Typical “bump” from elevated distal clavicle (clinical photo).
              </figcaption>
            </figure>
            <div class="md:bg-white md:rounded-xl md:shadow-sm md:border md:border-slate-200 overflow-hidden">
              <div class="bg-indigo-600 text-white px-4 py-3">
                <h3 class="font-bold text-sm uppercase tracking-wide">Biomechanics snapshot</h3>
              </div>
              <div class="p-4 text-xs text-slate-700 space-y-3">
                <p>
                  <strong>AC ligaments</strong> resist <em>horizontal</em> translation; <strong>coracoclavicular (CC)</strong> complex
                  resists <em>vertical</em> displacement. Untreated horizontal instability drives poor outcomes in many
                  high-grade patterns<RefLink id="9" text="Concepts" url={references[8].url} />.
                </p>
                <p>
                  <strong>Scapular dyskinesis</strong> is common after AC injury and may persist after conservative care—worth
                  screening in chronic type III patterns<RefLink id="9" text="Rehab context" url={references[8].url} />.
                </p>
                <div class="bg-amber-50 border border-amber-200 rounded-lg p-2">
                  <p class="font-bold text-amber-900 mb-1">Type VI (rare)</p>
                  <p class="text-slate-600">
                    Inferior clavicle displacement — assess neurovascular status urgently<RefLink
                      id="5"
                      text="Algorithm"
                      url={references[4].url}
                    />.
                  </p>
                </div>
              </div>
            </div>

            <div class="md:bg-white md:rounded-xl md:shadow-sm md:border md:border-slate-200 overflow-hidden">
              <div class="bg-slate-800 text-white px-4 py-3">
                <h3 class="font-bold text-sm uppercase tracking-wide">Related (SV)</h3>
              </div>
              <div class="p-4 text-sm">
                <a
                  href="/sjukdomar/axel/nyckelbensleden-ur-led"
                  class="text-sky-600 hover:underline font-medium"
                >
                  Nyckelbenet ur led (Swedish)
                </a>
                <p class="text-xs text-slate-500 mt-2">
                  Patient-oriented summary on our clinic site (<a
                    href="https://specialist.se/nyckelbensleden-ur-led/"
                    class="text-sky-600 hover:underline"
                    target="_blank"
                    rel="noopener noreferrer">specialist.se</a
                  >) covers similar themes in Swedish.
                </p>
              </div>
            </div>
          </div>
        </aside>

        <!-- MAIN -->
        <main class="lg:col-span-6 order-1 lg:order-2 space-y-2 sm:space-y-6 min-w-0">
          <article id="overview" class="bg-white sm:rounded-xl sm:shadow-sm sm:border sm:border-slate-200 overflow-hidden scroll-mt-6">
            <div class="bg-sky-900 text-white px-4 py-4 sm:p-5 md:p-6">
              <span class="inline-block px-3 py-1 bg-sky-600 text-xs font-semibold uppercase tracking-wider rounded-full mb-3">Overview</span>
              <h2 class="text-xl font-bold mb-1 flex items-center gap-2">
                <span class="w-8 h-8 rounded-lg bg-sky-700 text-white flex items-center justify-center text-sm">1</span>
                The instability X-rays don't show
              </h2>
              <p class="text-sky-200 text-sm">Why the Rockwood grade alone doesn't tell the full story.</p>
            </div>
            <div class="px-4 py-4 sm:p-5 md:p-6">
            <p class="text-slate-600 leading-relaxed mb-3">
              The acromioclavicular (AC) joint is stabilized by the <strong>AC ligaments</strong> within the joint capsule
              and the <strong>coracoclavicular (CC) ligaments</strong> connecting the coracoid process to the clavicle.
              Together, they control joint stability in multiple planes.
            </p>
            <p class="text-slate-600 leading-relaxed mb-3">
              The Rockwood classification (types I–VI) has for decades been based almost exclusively on
              <strong>vertical instability</strong> — the superior displacement of the clavicle relative to the acromion.
              Motion in other directions has not been captured.
            </p>
            <p class="text-slate-600 leading-relaxed mb-3">
              There is now growing recognition that a key driver of persistent symptoms is
              <strong>horizontal instability</strong> — anteroposterior hypermobility that disrupts scapular kinematics and
              shoulder function<RefLink id="12" text="Systematic review" url={references[11].url} />. This component is
              invisible on standard radiographs and can only be identified through clinical examination.
            </p>
            <p class="text-slate-600 leading-relaxed">
              Two patients with the same Rockwood grade may therefore have entirely different functional impairment — and
              require entirely different treatment strategies.
            </p>
            </div>
          </article>

          <article id="horizontal-instability" class="bg-white sm:rounded-xl sm:shadow-sm sm:border sm:border-slate-200 overflow-hidden scroll-mt-6">
            <div class="bg-sky-900 text-white px-4 py-4 sm:p-5 md:p-6">
              <span class="inline-block px-3 py-1 bg-sky-600 text-xs font-semibold uppercase tracking-wider rounded-full mb-3">Key concept</span>
              <h2 class="text-xl font-bold mb-1 flex items-center gap-2">
                <span class="w-8 h-8 rounded-lg bg-sky-700 text-white flex items-center justify-center text-sm">2</span>
                Horizontal instability
              </h2>
              <p class="text-sky-200 text-sm">
                A paradigm shift in diagnosis and treatment of both acute dislocations and iatrogenic instability.
              </p>
            </div>
            <div class="px-4 py-4 sm:p-5 md:p-6 space-y-5">
              <div class="text-base text-slate-700 leading-relaxed border-l-4 border-sky-600 pl-4 bg-sky-50 py-3 pr-3 rounded-r-lg">
                AC joint injuries have traditionally been assessed primarily in terms of vertical instability. Current
                evidence shows that <strong>horizontal instability</strong> — caused by damage to the AC ligaments — is a
                critical and often overlooked factor behind chronic pain and impaired function, whether it arises acutely
                from trauma or iatrogenically after distal clavicle excision
                (DCE)<RefLink id="12" text="Systematic review" url={references[11].url} />.
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-3 lg:grid-cols-1 2xl:grid-cols-3 gap-5">
                <div class="bg-white p-5 rounded-xl border border-slate-200 shadow-sm">
                  <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center text-sky-700 mb-4">
                    <Icon name="eye" size={20} />
                  </div>
                  <h3 class="text-lg font-bold text-slate-900 mb-2">Diagnostic pitfalls</h3>
                  <p class="text-sm text-slate-600 leading-relaxed">
                    Standard seated radiographs often miss horizontal displacement. Dynamic views — such as a modified
                    bilateral Alexander view or dynamic axillary views in supine — are needed to unmask
                    it<RefLink id="13" text="Dynamic evaluation" url={references[12].url} />.
                    A glenoacromial angle (GACA) difference exceeding <strong>12.3°</strong> confirms
                    instability<RefLink id="14" text="Kraus classification" url={references[13].url} />.
                  </p>
                </div>
                <div class="bg-white p-5 rounded-xl border border-slate-200 shadow-sm">
                  <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center text-red-600 mb-4">
                    <Icon name="alert-circle" size={20} />
                  </div>
                  <h3 class="text-lg font-bold text-slate-900 mb-2">Trauma vs. iatrogenic</h3>
                  <p class="text-sm text-slate-600 leading-relaxed">
                    Dynamic horizontal translation can be present even in low-grade acute injuries
                    (Rockwood I–II)<RefLink id="14" text="Kraus" url={references[13].url} />.
                    In surgery, resection of <strong>&gt;5–10 mm</strong> of the distal clavicle risks compromising the
                    joint capsule, creating difficult-to-treat iatrogenic
                    instability<RefLink id="15" text="Iatrogenic instability" url={references[14].url} />.
                  </p>
                </div>
                <div class="bg-white p-5 rounded-xl border border-slate-200 shadow-sm">
                  <div class="w-10 h-10 rounded-full bg-green-100 flex items-center justify-center text-green-600 mb-4">
                    <Icon name="check" size={20} />
                  </div>
                  <h3 class="text-lg font-bold text-slate-900 mb-2">Surgical implications</h3>
                  <p class="text-sm text-slate-600 leading-relaxed">
                    Addressing only vertical (CC) ligaments is insufficient. Anatomic reconstruction must restore the
                    <strong>AC ligaments</strong>. Revision surgery after excessive DCE carries complication rates up to
                    <strong>33%</strong>, underscoring the importance of joint-preserving initial
                    surgery<RefLink id="15" text="Revision outcomes" url={references[14].url} />.
                  </p>
                </div>
              </div>
            </div>
          </article>

          <article id="symptoms" class="bg-white sm:rounded-xl sm:shadow-sm sm:border sm:border-slate-200 overflow-hidden scroll-mt-6">
            <div class="bg-sky-900 text-white px-4 py-4 sm:p-5 md:p-6">
              <span class="inline-block px-3 py-1 bg-sky-600 text-xs font-semibold uppercase tracking-wider rounded-full mb-3">Clinical</span>
              <h2 class="text-xl font-bold mb-1 flex items-center gap-2">
                <span class="w-8 h-8 rounded-lg bg-sky-700 text-white flex items-center justify-center text-sm">3</span>
                Symptoms
              </h2>
              <p class="text-sky-200 text-sm">What patients experience and what the clinician sees on examination.</p>
            </div>
            <div class="px-4 py-4 sm:p-5 md:p-6">
            <ul class="list-disc pl-5 text-slate-600 space-y-2 mb-4">
              <li>Pain over the AC joint, worse with cross-body adduction or overhead loading.</li>
              <li>Visible <strong>step-off</strong> or skin tenting in higher-grade injuries.</li>
              <li>Reduced push-up / bench-press confidence in athletes; difficulty with heavy overhead work.</li>
            </ul>
            </div>
          </article>

          <article id="diagnosis" class="bg-white sm:rounded-xl sm:shadow-sm sm:border sm:border-slate-200 overflow-hidden scroll-mt-6">
            <div class="bg-sky-900 text-white px-4 py-4 sm:p-5 md:p-6">
              <span class="inline-block px-3 py-1 bg-sky-600 text-xs font-semibold uppercase tracking-wider rounded-full mb-3">Diagnostics</span>
              <h2 class="text-xl font-bold mb-1 flex items-center gap-2">
                <span class="w-8 h-8 rounded-lg bg-sky-700 text-white flex items-center justify-center text-sm">4</span>
                Diagnosis & imaging
              </h2>
              <p class="text-sky-200 text-sm">Imaging strategy, when to use advanced modalities, and classification pitfalls.</p>
            </div>
            <div class="px-4 py-4 sm:p-5 md:p-6">
            <p class="text-slate-600 leading-relaxed mb-4">
              Clinical examination localises tenderness and identifies deformity. ESA–ESSKA consensus supports
              <strong>true anteroposterior radiographs</strong> with <strong>bilateral Zanca views</strong> as adequate for
              standard AC instability assessment — routine advanced imaging solely to grade the AC joint is not
              required<RefLink id="10" text="Consensus statement" url={references[9].url} />.
            </p>
            <div class="bg-sky-50 border border-sky-200 rounded-lg p-4 text-sm text-slate-700 mb-4">
              <h3 class="font-bold text-slate-900 mb-2">AP drawer test</h3>
              <p class="leading-relaxed">
                To assess for a <strong>horizontal</strong> component of AC joint instability, the <strong>distal clavicle</strong> is
                shifted <strong>posteriorly</strong> while the <strong>acromion</strong> is stabilised with the other hand.{' '}
                <strong>Increased posterior translation</strong> compared with the unaffected side indicates a horizontal component of
                AC joint instability<RefLink id="16" text="Current concepts review" url={references[15].url} />.
              </p>
            </div>
            <p class="text-slate-600 leading-relaxed mb-4">
              Use <strong>ultrasound, CT, or MRI</strong> selectively when you need to evaluate associated glenohumeral
              pathology or complex cases. Around <strong>18–20%</strong> of high-grade AC injuries may have relevant
              intra-articular lesions (e.g. SLAP or partial cuff tears), which can influence surgical planning<RefLink
                id="9"
                text="Associated injuries"
                url={references[8].url}
              />.
            </p>
            <div class="bg-purple-50 border border-purple-200 rounded-lg p-4 text-sm text-slate-700 flex gap-2 items-start">
              <Icon name="zap" size={20} class="text-purple-600 shrink-0 mt-0.5" strokeWidth={2} />
              <span>
                <strong>Classification reliability</strong> remains imperfect — interobserver disagreement is a known
                limitation when choosing conservative versus operative care<RefLink
                  id="7"
                  text="Rockwood vs Kraus"
                  url={references[6].url}
                />.
              </span>
            </div>
            </div>
          </article>

          <article id="classification" class="bg-white sm:rounded-xl sm:shadow-sm sm:border sm:border-slate-200 overflow-hidden scroll-mt-6">
            <div class="bg-sky-900 text-white px-4 py-4 sm:p-5 md:p-6">
              <span class="inline-block px-3 py-1 bg-sky-600 text-xs font-semibold uppercase tracking-wider rounded-full mb-3">Classification</span>
              <h2 class="text-xl font-bold mb-1 flex items-center gap-2">
                <span class="w-8 h-8 rounded-lg bg-sky-700 text-white flex items-center justify-center text-sm">5</span>
                Rockwood classification (illustrated)
              </h2>
              <p class="text-sky-200 text-sm">Visual guide to injury grades I through VI with type-specific details.</p>
            </div>
            <div class="px-4 py-4 sm:p-5 md:p-6">
            <p class="text-slate-600 text-sm mb-4">
              Schematic overview of common types (illustrations for patient education — not a substitute for formal
              radiographic classification).
            </p>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-6">
              {[
                { src: imgRockwood1, cap: 'Type I' },
                { src: imgRockwood2, cap: 'Type II' },
                { src: imgRockwood3, cap: 'Type III' },
                { src: imgRockwood5, cap: 'Type V' },
                { src: imgRockwoodV, cap: 'Type V (variant art)' },
              ].map((row) => (
                <figure class="rounded-lg overflow-hidden border border-slate-200 bg-slate-50">
                  <Image src={row.src} alt={`Rockwood ${row.cap} AC injury illustration`} class="w-full h-auto" widths={[200, 280]} sizes="150px" />
                  <figcaption class="text-[10px] text-center text-slate-500 py-1">{row.cap}</figcaption>
                </figure>
              ))}
            </div>
            <div class="grid md:grid-cols-2 gap-4">
              <figure class="rounded-lg overflow-hidden border border-slate-200">
                <Image src={imgType4} alt="AC joint injury type 4 posterior displacement diagram" class="w-full h-auto" widths={[400, 600]} sizes="(max-width: 768px) 100vw, 50vw" />
                <figcaption class="text-xs text-slate-500 p-2 bg-slate-50">Type IV — posterior clavicle relative to acromion.</figcaption>
              </figure>
              <figure class="rounded-lg overflow-hidden border border-slate-200 bg-white p-2">
                <Image src={imgDiagram35} alt="Diagram comparing AC joint type 3 and type 5 displacement" class="w-full h-auto" />
                <figcaption class="text-xs text-slate-500 p-2">Types III vs V — vertical displacement difference.</figcaption>
              </figure>
            </div>

            <div class="mt-6 rounded-xl border border-emerald-200 bg-gradient-to-br from-emerald-50 to-white p-5 md:p-6 shadow-sm">
              <h3 class="font-bold text-emerald-950 mb-1 text-lg tracking-tight">Rockwood types I &amp; II — what they mean</h3>
              <p class="text-sm text-slate-600 mb-4">
                Low-grade AC joint injuries (see <strong>Type I</strong> and <strong>Type II</strong> in the gallery above). They share
                <strong>intact coracoclavicular (CC) ligaments</strong> and are managed non-operatively in essentially all cases<RefLink
                  id="5"
                  text="Treatment algorithms"
                  url={references[4].url}
                /><RefLink id="9" text="Current concepts" url={references[8].url} />.
              </p>
              <div class="grid md:grid-cols-2 gap-5 text-slate-700 text-sm leading-relaxed">
                <div class="rounded-lg bg-white/80 border border-emerald-100 p-4">
                  <h4 class="font-semibold text-emerald-900 mb-2 flex items-center gap-2">
                    <span class="text-xs font-mono bg-emerald-100 text-emerald-800 px-2 py-0.5 rounded">Type I</span>
                    AC sprain
                  </h4>
                  <p class="mb-2">
                    A <strong>sprain</strong> of the AC joint: the acromioclavicular capsule and ligaments are stressed or partially
                    injured, but the AC ligament complex remains <strong>continuous</strong> and the CC ligaments are
                    <strong>uninjured</strong>. There is typically <strong>no visible clavicle displacement</strong> on standard
                    radiographs — joint alignment looks near-normal apart from soft-tissue swelling.
                  </p>
                  <p class="text-slate-600">
                    Clinically: local tenderness and swelling over the AC joint; pain with cross-body and overhead loading; no
                    fixed step-off.
                  </p>
                </div>
                <div class="rounded-lg bg-white/80 border border-emerald-100 p-4">
                  <h4 class="font-semibold text-emerald-900 mb-2 flex items-center gap-2">
                    <span class="text-xs font-mono bg-emerald-100 text-emerald-800 px-2 py-0.5 rounded">Type II</span>
                    Ruptured AC ligaments, intact CC ligaments
                  </h4>
                  <p class="mb-2">
                    The <strong>AC ligaments are disrupted</strong>, so the distal clavicle loses its primary restraint to
                    <strong>horizontal translation</strong> relative to the acromion, but the <strong>CC ligaments remain intact</strong>
                    and continue to limit <strong>vertical</strong> displacement. On X-ray you may see a <strong>mild superior shift</strong>
                    of the distal clavicle compared with the uninjured side — more than type I, but <strong>less</strong> than the
                    “full” separation pattern of type III.
                  </p>
                  <p class="text-slate-600">
                    Clinically: more pronounced pain and sometimes a subtle prominence; still classified as a
                    <strong>lower-grade</strong> injury in treatment pathways — <strong>surgery is not indicated</strong> for the AC
                    injury itself.
                  </p>
                </div>
              </div>
              <div class="mt-4 pt-4 border-t border-emerald-200/90 text-sm text-slate-700">
                <p>
                  <strong class="text-emerald-950">Practical point:</strong> Both types are treated with
                  <strong>conservative care</strong> — activity modification, sling only as needed for comfort, early controlled
                  range of motion, then progressive strengthening. Return to sport and heavy lifting is guided by symptoms and
                  strength rather than a fixed week count<RefLink id="5" text="Guidance" url={references[4].url} />.
                </p>
                <p class="mt-2 text-slate-600">
                  If pain or mechanical symptoms persist beyond the expected window, reassess for
                  <strong>missed higher-grade injury</strong>, associated glenohumeral pathology, or (in chronic cases) horizontal
                  instability patterns more often discussed in type III sub-classification<RefLink id="10" text="Consensus" url={references[9].url} />.
                </p>
                <p class="mt-3">
                  <a
                    href="/en/rehab/shoulder/ac-joint-dislocation-type-i-ii"
                    class="inline-flex items-center gap-1 text-emerald-800 font-semibold underline hover:text-emerald-950"
                    >Phased rehab program (types I &amp; II) — printable guide →</a
                  >
                </p>
              </div>
            </div>
            </div>
          </article>

          <article id="treatment" class="bg-white sm:rounded-xl sm:shadow-sm sm:border sm:border-slate-200 overflow-hidden scroll-mt-6">
            <div class="bg-sky-900 text-white px-4 py-4 sm:p-5 md:p-6">
              <span class="inline-block px-3 py-1 bg-sky-600 text-xs font-semibold uppercase tracking-wider rounded-full mb-3">Treatment</span>
              <h2 class="text-xl font-bold mb-1 flex items-center gap-2">
                <span class="w-8 h-8 rounded-lg bg-sky-700 text-white flex items-center justify-center text-sm">6</span>
                Treatment principles
              </h2>
              <p class="text-sky-200 text-sm">Evidence-based management by injury type, chronicity, and patient demands.</p>
            </div>
            <div class="px-4 py-4 sm:p-5 md:p-6">
            <div class="space-y-4 text-slate-600 leading-relaxed">
              <div class="border-l-4 border-emerald-500 pl-4">
                <h3 class="font-bold text-slate-800 mb-1">Types I & II</h3>
                <p>
                  Treat conservatively with sling as needed, early range of motion, and progressive strengthening<RefLink
                    id="5"
                    text="Guidance"
                    url={references[4].url}
                  />.
                </p>
                <p class="text-sm text-slate-500 mt-2">
                  <a href="#classification" class="text-emerald-700 underline hover:text-emerald-900">Types I &amp; II summary</a>
                  (anatomy, X-ray appearance, and practical notes) sits under Rockwood classification above.
                </p>
              </div>

              <div class="border-l-4 border-sky-500 pl-4">
                <h3 class="font-bold text-slate-800 mb-1">Type III (acute)</h3>
                <p class="mb-2">
                  Start with a structured <strong>non-operative programme</strong> (often 3–6 weeks initial focus, longer
                  rehab as needed). Meta-analyses and RCT data show <strong>no consistent long-term functional superiority</strong> of
                  early surgery for many patients<RefLink id="3" text="EFORT review" url={references[2].url} /><RefLink
                    id="4"
                    text="BMC meta-analysis"
                    url={references[3].url}
                  /><RefLink id="11" text="Conservative cohort" url={references[10].url} />.
                </p>
                <p>
                  If symptoms plateau, reassess for <strong>horizontal instability</strong> and scapular dyskinesis; some
                  “IIIB”-type patterns are more likely to benefit from surgery than horizontally stable “IIIA”
                  equivalents<RefLink id="10" text="Expert consensus" url={references[9].url} />.
                </p>
              </div>

              <div class="border-l-4 border-amber-500 pl-4">
                <h3 class="font-bold text-slate-800 mb-1">Type V & controversies</h3>
                <p>
                  Many guidelines still lean operative for marked displacement, yet a high-quality RCT reported
                  <strong>no clinical difference at 2 years</strong> between hook plate fixation and physiotherapy for
                  combined type III and V cohorts — challenging a dogmatic “always operate” stance<RefLink
                    id="8"
                    text="RCT"
                    url={references[7].url}
                  />.
                </p>
              </div>

              <div class="border-l-4 border-rose-500 pl-4">
                <h3 class="font-bold text-slate-800 mb-1">Chronic injuries (&gt;3–6 weeks)</h3>
                <p>
                  Delayed reconstruction may need <strong>biological augmentation</strong> (e.g. graft reconstruction) because
                  native ligament healing potential decreases<RefLink id="2" text="Surgical review" url={references[1].url} /><RefLink
                    id="9"
                    text="Algorithm"
                    url={references[8].url}
                  />.
                </p>
              </div>
            </div>

            <div class="mt-6 bg-slate-50 rounded-lg p-4 border border-slate-200 text-sm text-slate-700">
              <strong>Surgery vs conservative — outcomes:</strong> Operative treatment achieves superior radiographic
              reduction, but this does not reliably translate into better long-term patient-reported function; complication
              rates are higher with surgery<RefLink id="1" text="Long-term RCT" url={references[0].url} /><RefLink
                id="4"
                text="Meta-analysis"
                url={references[3].url}
              />. Conservative care typically allows <strong>faster early return to work and sport</strong> in aggregate<RefLink
                id="4"
                text="Review"
                url={references[3].url}
              />.
            </div>
            </div>
          </article>

          <article id="surgery" class="bg-white sm:rounded-xl sm:shadow-sm sm:border sm:border-slate-200 overflow-hidden scroll-mt-6">
            <div class="bg-sky-900 text-white px-4 py-4 sm:p-5 md:p-6">
              <span class="inline-block px-3 py-1 bg-sky-600 text-xs font-semibold uppercase tracking-wider rounded-full mb-3">Surgery</span>
              <h2 class="text-xl font-bold mb-1 flex items-center gap-2">
                <span class="w-8 h-8 rounded-lg bg-sky-700 text-white flex items-center justify-center text-sm">7</span>
                Surgical techniques
              </h2>
              <p class="text-sky-200 text-sm">Current fixation methods, comparative outcomes, and complication profiles.</p>
            </div>
            <div class="px-4 py-4 sm:p-5 md:p-6">
            <p class="text-slate-600 leading-relaxed mb-4">
              Many techniques exist (CC fixation, AC cerclage, hook plate, suture-button / tape constructs, free tendon
              grafts). Network meta-analyses summarise comparative effectiveness and complication profiles<RefLink
                id="6"
                text="Network MA"
                url={references[5].url}
              />.
            </p>

            <div class="grid md:grid-cols-2 gap-4 mb-4">
              <figure class="rounded-xl overflow-hidden border border-slate-200 shadow-sm">
                <Image
                  src={imgDogBone}
                  alt="Illustration of double cortical button CC ligament reconstruction (dog-bone construct)"
                  class="w-full h-auto bg-white"
                  widths={[400, 700]}
                  sizes="(max-width: 768px) 100vw, 50vw"
                />
                <figcaption class="text-xs text-slate-600 p-3 bg-slate-50">
                  <strong>Cortical buttons / suspension tape</strong> — restores CC distance without a subacromial hook; avoids
                  routine planned removal in many protocols<RefLink id="2" text="Modern fixation" url={references[1].url} /><RefLink
                    id="6"
                    text="Comparative data"
                    url={references[5].url}
                  />.
                </figcaption>
              </figure>
              <figure class="rounded-xl overflow-hidden border border-slate-200 shadow-sm">
                <Image
                  src={imgHookPlate}
                  alt="Hook plate fixation of acromioclavicular joint dislocation"
                  class="w-full h-auto bg-white"
                  widths={[400, 700]}
                  sizes="(max-width: 768px) 100vw, 50vw"
                />
                <figcaption class="text-xs text-slate-600 p-3 bg-slate-50">
                  <strong>Hook plate</strong> — effective reduction but frequent planned reoperation for hardware removal and
                  risks such as subacromial impingement / acromial erosion in a proportion of patients<RefLink
                    id="1"
                    text="Ten-year data"
                    url={references[0].url}
                  /><RefLink id="6" text="Complications overview" url={references[5].url} />.
                </figcaption>
              </figure>
            </div>
            </div>
          </article>

          <article id="work-sport" class="bg-white sm:rounded-xl sm:shadow-sm sm:border sm:border-slate-200 overflow-hidden scroll-mt-6">
            <div class="bg-sky-900 text-white px-4 py-4 sm:p-5 md:p-6">
              <span class="inline-block px-3 py-1 bg-sky-600 text-xs font-semibold uppercase tracking-wider rounded-full mb-3">Recovery</span>
              <h2 class="text-xl font-bold mb-1 flex items-center gap-2">
                <span class="w-8 h-8 rounded-lg bg-sky-700 text-white flex items-center justify-center text-sm">8</span>
                Work & return to sport
              </h2>
              <p class="text-sky-200 text-sm">Timeline and criteria for returning to work, training, and competition.</p>
            </div>
            <div class="px-4 py-4 sm:p-5 md:p-6">
            <p class="text-slate-600 leading-relaxed mb-4">
              Timeline depends on Rockwood type, treatment path, and demands. Conservative protocols generally permit an
              earlier resumption of light activity than operative protocols complicated by immobilisation and hardware
              logistics<RefLink id="4" text="Meta-analysis" url={references[3].url} />. Athletes in collision sports may need
              longer graded contact progressions — individualise using strength, pain, and sport-specific testing<RefLink
                id="5"
                text="Return considerations"
                url={references[4].url}
              />.
            </p>
            <p class="text-slate-600 leading-relaxed mb-4 text-sm">
              <strong>Return to work (RTW)</strong> depends on the same injury pattern plus job demands. The tool below
              compares illustrative week ranges across common treatment paths; it is not a substitute for workplace
              assessment or legal timelines<RefLink id="4" text="Outcomes overview" url={references[3].url} />.
            </p>
            <AcJointRtwCalculator />
            <p class="text-slate-600 leading-relaxed mb-2 text-sm mt-10">
              Outcome studies often separate <strong>return to sport (RTS)</strong> from{' '}
              <strong>return to previous level (RTPL)</strong>. The interactive summary below uses pooled, illustrative
              percentages for counselling; for trial-level evidence see recent reviews and consensus statements<RefLink
                id="3"
                text="Systematic review"
                url={references[2].url}
              /><RefLink id="10" text="Expert consensus" url={references[9].url} />.
            </p>
            <AcJointRtsRtplDashboard />
            </div>
          </article>
        </main>

        <!-- RIGHT -->
        <aside class="lg:col-span-3 order-3 min-w-0">
          <div class="lg:sticky lg:top-6 space-y-4">
            <nav class="hidden lg:block bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
              <div class="bg-sky-700 px-4 py-2.5">
