---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const title = 'Nyckelbenet ur led | Södermalms Ortopedi';
const description =
  'Urledvridning i yttre nyckelbensleden (AC-luxation). Sidan byggs upp; kliniskt innehåll kommer inom kort.';
---

<BaseLayout
  title={title}
  description={description}
  alternateUrl="/en/diseases/shoulder/ac-joint-dislocation"
  noindex={true}
>
  <main class="container mx-auto px-4 py-16 max-w-3xl">
    <nav class="text-sm text-slate-500 mb-8 flex flex-wrap gap-1 items-center" aria-label="Brödsmulor">
      <a href="/" class="hover:text-sky-600">Startsida</a>
      <span class="text-slate-300">/</span>
      <a href="/sjukdomar" class="hover:text-sky-600">Sjukdomar</a>
      <span class="text-slate-300">/</span>
      <a href="/sjukdomar/axel" class="hover:text-sky-600">Axel</a>
      <span class="text-slate-300">/</span>
      <span class="text-slate-600">Nyckelbenet ur led</span>
    </nav>

    <h1 class="text-4xl font-bold text-[#024264] mb-4">Nyckelbenet ur led</h1>
    <p class="text-slate-600 text-lg mb-6">
      Sidan är under uppbyggnad. Innehåll om akuta och kroniska AC-luxationer, klassifikation och behandling
      publiceras här inom kort.
    </p>
    <p class="text-slate-500 text-sm">
      <a href="/en/diseases/shoulder/ac-joint-dislocation" class="text-sky-600 hover:underline"
        >English (under development)</a
      >
    </p>
  </main>
</BaseLayout>
