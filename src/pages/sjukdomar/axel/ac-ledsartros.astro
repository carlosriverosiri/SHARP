            <p class="text-slate-700 text-sm leading-relaxed mb-3">
              <strong>AC-ledsartros</strong> (artros i yttre nyckelbensleden) är vanligt – 83% har röntgenfynd efter 40 år – men 
              <strong>de flesta har inga besvär</strong>. Smärtan är belastningsberoende och uppstår vid overhead-arbete, 
              träning eller tunga lyft.
            </p>
            <div class="grid sm:grid-cols-3 gap-3 text-xs">
              <div class="flex items-center gap-2 bg-white/70 rounded-lg p-2">
                <span class="text-green-600 font-bold">✓</span>
                <span><strong>De flesta</strong> förbättras utan operation</span>
              </div>
              <div class="flex items-center gap-2 bg-white/70 rounded-lg p-2">
                <span class="text-sky-600 font-bold">✓</span>
                <span><strong>Operation</strong> vid långvariga smärtor</span>
              </div>
              <div class="flex items-center gap-2 bg-white/70 rounded-lg p-2">
                <span class="text-purple-600 font-bold">✓</span>
                <span><strong>&gt;90%</strong> nöjda efter kirurgi</span>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Innehållsförteckning - endast mobil -->
      <nav class="mt-4 lg:hidden">
        <details class="bg-sky-50 rounded-lg border border-sky-200">
          <summary class="flex items-center justify-between p-3 cursor-pointer select-none">
            <span class="font-bold text-sky-800 text-sm uppercase tracking-wide">📑 Innehåll</span>
            <svg class="w-4 h-4 text-sky-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-3 pb-2 flex flex-wrap gap-2">
            {tableOfContents.map((item) => (
              <a href={`#${item.id}`} class="inline-flex items-center gap-1.5 text-sm font-medium text-slate-700 hover:text-sky-700 bg-white px-2.5 py-1 rounded-full border border-slate-200 hover:border-sky-300 transition-colors">
                <span class="w-4 h-4 rounded-full bg-sky-100 text-sky-700 flex items-center justify-center text-xs font-bold">{item.icon}</span>
                {item.title}
              </a>
            ))}
          </div>
        </details>
      </nav>
    </div>
  </section>

  <!-- VIDEO SEKTION (visas endast om videoUrl är satt) -->
  {videoUrl && (
    <section class="bg-slate-900 py-10">
      <div class="max-w-4xl mx-auto px-4 sm:px-6">
        <h2 class="text-xl font-bold text-white mb-4 flex items-center gap-2">
          <svg class="w-6 h-6 text-red-500" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814z"/>
            <path fill="#fff" d="M9.545 15.568V8.432L15.818 12z"/>
          </svg>
          {videoTitle}
        </h2>
        <div class="aspect-video rounded-xl overflow-hidden bg-slate-800">
          <iframe 
            src={videoUrl}
            title={videoTitle}
            class="w-full h-full"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
        <p class="text-slate-400 text-sm mt-3 text-center">
          Video: Dr. Carlos Rivero Siri förklarar AC-ledsartros
        </p>
      </div>
    </section>
  )}

  <!-- HUVUDINNEHÅLL: 3-KOLUMN LAYOUT -->
  <section class="bg-slate-50 py-10">
    <div class="max-w-[1500px] mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-12 gap-8">
        
        <!-- VÄNSTER SIDEBAR: SNABBFAKTA -->
        <aside class="lg:col-span-3 order-2 lg:order-1">
          <div class="lg:sticky lg:top-6 space-y-4">
            
<!-- Distal Klavikulär Osteolys (DCO) / Weightlifter's Shoulder -->
            <div class="md:bg-white md:rounded-xl md:shadow-sm md:border md:border-slate-200 md:overflow-hidden">
              <div class="bg-amber-600 text-white px-4 py-3">
                <h3 class="font-bold text-sm uppercase tracking-wide">Weightlifter's Shoulder</h3>
              </div>
              <div class="p-4">
                <figure class="rounded-lg overflow-hidden border border-slate-200 mb-4">
                  <Image 
                    src={dcoXray}
                    alt={imageData.dcoXray.alt}
                    title={imageData.dcoXray.title}
                    widths={[200, 400]}
                    sizes="200px"
                    loading="lazy"
                    decoding="async"
                    class="w-full h-auto"
                  />
                  <figcaption class="p-2 text-xs text-slate-500 bg-slate-50">
                    <strong>Röntgen DCO:</strong> benresorption i distala klavikeln.
                  </figcaption>
                </figure>
                
                <h4 class="font-bold text-slate-800 text-sm mb-2">Distal klavikulär osteolys (DCO)</h4>
                <p class="text-xs text-slate-600 leading-relaxed mb-3">
                  Överbelastningsskada med benresorption i distala nyckelbensänden<RefLink id="12" text="DCO patofysiologi." url={references[11].url} />. 
                  Ses hos tyngdlyftare och vid repetitiva press-/overhead-rörelser, men även posttraumatiskt<RefLink id="25" text="Diagnos och behandling." url={references[24].url} />.
                </p>
                
                <div class="space-y-2 text-xs text-slate-600 mb-3">
                  <div class="flex gap-2">
                    <span class="text-amber-600 font-bold">•</span>
                    <span>Lokaliserad smärta vid palpation och horisontell adduktion</span>
                  </div>
                  <div class="flex gap-2">
                    <span class="text-amber-600 font-bold">•</span>
                    <span>Röntgen: osteolys, cystor, förlust av subkondral kontur</span>
                  </div>
                  <div class="flex gap-2">
                    <span class="text-amber-600 font-bold">•</span>
                    <span>MRI: benmärgsödem, subkondrala frakturer<RefLink id="25" text="MRI-fynd." url={references[24].url} /></span>
                  </div>
                </div>

                <div class="bg-green-50 border border-green-200 rounded-lg p-3 mb-3">
                  <h5 class="font-bold text-green-800 text-xs mb-1">Behandling</h5>
                  <p class="text-xs text-slate-600">
                    Konservativt först: aktivitetsmodifiering, NSAID, fysioterapi. Många blir symtomfria inom månader<RefLink id="26" text="Konservativ behandling." url={references[25].url} />. 
                    Vid terapisvikt: artroskopisk DCR med direkt operationsteknik<RefLink id="20" text="Kirurgisk teknik." url={references[19].url} />.
                  </p>
                </div>

                <div class="bg-slate-50 border border-slate-200 rounded-lg p-3">
                  <h5 class="font-bold text-slate-700 text-xs mb-1 flex items-center gap-1">
                    <span class="text-green-600">✓</span> Prognos
                  </h5>
                  <p class="text-xs text-slate-600">
                    Utmärkt efter kirurgi: &gt;90% framgång, snabb återgång till sport<RefLink id="24" text="Kirurgisk prognos." url={references[23].url} />.
                  </p>
                </div>

                <!-- Dr. Carlos kommentar -->
                <blockquote class="mt-3 p-3 bg-slate-800 text-white rounded-lg border-l-3 border-l-amber-500">
                  <p class="text-xs italic text-slate-200 leading-relaxed mb-1">
                    "Weightlifter's shoulder är ofta självläkande. Men har det inte gått över efter ett år och förhindrar träning, så är det lika bra att operera."
                  </p>
                  <p class="text-xs text-amber-300 font-medium">— Dr. Carlos Rivero Siri</p>
                </blockquote>
              </div>
            </div>

            <!-- Ganglion -->
            <div class="md:bg-white md:rounded-xl md:shadow-sm md:border md:border-slate-200 md:overflow-hidden">
              <div class="bg-amber-600 text-white px-4 py-3">
                <h3 class="font-bold text-sm uppercase tracking-wide">Ganglion vid AC-leden</h3>
              </div>
              <div class="p-4">
                <figure class="rounded-lg overflow-hidden border border-slate-200 mb-3">
                  <Image
                    src={acGanglion}
                    alt={imageData.acGanglion.alt}
                    title={imageData.acGanglion.title}
                    widths={[200, 400]}
                    sizes="200px"
                    loading="lazy"
                    decoding="async"
                    class="w-full h-auto"
                  />
                </figure>
                <p class="text-xs text-slate-600 leading-relaxed">
                  Vätskecysta som kan uppstå vid uttalad artros i yttre nyckelbensleden. Synlig svullnad överst på axeln.
                </p>
              </div>
            </div>

          </div>
        </aside>

        <!-- HUVUDKOLUMN -->
        <main class="lg:col-span-6 order-1 lg:order-2 space-y-8">
          
          <!-- SYMTOM -->
          <article id="symtom" class="md:bg-white md:rounded-xl md:shadow-sm md:border md:border-slate-200 md:p-6 scroll-mt-6">
            <h2 class="text-xl font-bold text-slate-900 mb-4 flex items-center gap-2">
              <span class="w-8 h-8 rounded-lg bg-amber-100 text-amber-600 flex items-center justify-center text-sm">1</span>
              Så känner du igen AC-ledsartros
            </h2>
            <p class="text-slate-600 mb-5 text-base leading-relaxed">
              Symtomen är belastningsberoende och uppstår vid specifika aktiviteter. Smärtan är sällan intensiv<RefLink id="10" text="Lätta till moderata besvär." url={references[9].url} />.
            </p>
            
            <div class="grid sm:grid-cols-3 gap-3 mb-6">
              <div class="bg-slate-50 rounded-lg p-4 border-l-3 border-l-amber-500">
                <h3 class="font-bold text-slate-800 text-sm mb-1">Belastningssmärta</h3>
                <p class="text-slate-600 text-sm">Overhead-arbete, grävning, cross-body rörelser<RefLink id="2" text="Avlastning mest effektivt." url={references[1].url} />.</p>
              </div>
              <div class="bg-slate-50 rounded-lg p-4 border-l-3 border-l-amber-500">
                <h3 class="font-bold text-slate-800 text-sm mb-1">Lokaliserad värk</h3>
                <p class="text-slate-600 text-sm">Överst på axeln där nyckelbenet möter skulderbladet.</p>
              </div>
              <div class="bg-slate-50 rounded-lg p-4 border-l-3 border-l-amber-500">
                <h3 class="font-bold text-slate-800 text-sm mb-1">Lågintensiv smärta</h3>
                <p class="text-slate-600 text-sm">Lätta-moderata, långvariga besvär.</p>
              </div>
            </div>

            <!-- Bilder i rad -->
            <div class="grid grid-cols-2 gap-3">
              <figure class="rounded-lg overflow-hidden border border-slate-200">
                <Image 
                  src={acClinicalArrow}
                  alt={imageData.acClinicalArrow.alt}
                  title={imageData.acClinicalArrow.title}
                  widths={[300, 600]}
                  sizes="(max-width: 640px) 50vw, 300px"
                  loading="lazy"
                  decoding="async"
                  class="w-full h-auto"
                />
                <figcaption class="p-2 text-xs text-slate-500 bg-slate-50">
                  <strong>Smärtpunkt:</strong> pilen markerar AC-leden överst på axeln.
                </figcaption>
              </figure>
              <figure class="rounded-lg overflow-hidden border border-slate-200">
                <Image 
                  src={acPalpation}
                  alt={imageData.acPalpation.alt}
                  title={imageData.acPalpation.title}
                  widths={[300, 600]}
                  sizes="(max-width: 640px) 50vw, 300px"
                  loading="lazy"
                  decoding="async"
                  class="w-full h-auto"
                />
                <figcaption class="p-2 text-xs text-slate-500 bg-slate-50">
                  <strong>Palpationsömhet:</strong> direkt ömhet vid tryck över AC-leden har 96% sensitivitet för AC-ledssmärta.
                </figcaption>
              </figure>
            </div>

            <!-- Kliniskt tecken: Palpationsömhet -->
            <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mt-4">
              <h4 class="font-bold text-amber-800 text-sm mb-2">Viktigt kliniskt tecken: Palpationsömhet</h4>
              <p class="text-sm text-slate-700 leading-relaxed">
                Palpationsömhet över AC-leden har <strong>96% sensitivitet</strong> – det mest känsliga kliniska testet för AC-ledssmärta<RefLink id="28" text="Walton et al. 2004" url={references[27].url} />. 
                Ett negativt test talar starkt emot AC-ledsursprung. Specificiteten är dock låg (10%), varför testet bäst kombineras med provocerande tester som Paxinos test eller O'Brien's test<RefLink id="29" text="Krill et al. 2018" url={references[28].url} />.
              </p>
            </div>

            <!-- Smärtutstrålning -->
            <div class="mt-6 flex flex-col md:flex-row gap-4">
              <div class="flex-1">
                <h4 class="font-bold text-slate-800 text-sm mb-2">Varför gör det ont i nacken?</h4>
                <p class="text-sm text-slate-600 leading-relaxed mb-3">
                  Många patienter undrar varför de får ont i nacken vid AC-ledsartros. Smärtan sitter oftast direkt över AC-leden, men <strong>referred pain</strong> (överförd smärta) till nacke och skulderblad är vanligt förekommande.
                </p>
                <ul class="space-y-1 text-sm text-slate-600">
                  <li class="flex gap-2"><span class="text-amber-500">•</span><strong>Vanligast:</strong> Smärta rakt över AC-leden</li>
                  <li class="flex gap-2"><span class="text-amber-500">•</span><strong>Nacke:</strong> Relativt vanlig referred pain</li>
                  <li class="flex gap-2"><span class="text-amber-500">•</span><strong>Skulderblad:</strong> Också vanligt förekommande</li>
                </ul>
              </div>
              <figure class="w-full md:w-48 shrink-0 rounded-lg overflow-hidden border border-slate-200">
                <Image 
                  src={acPainDistribution}
                  alt={imageData.acPainDistribution.alt}
                  title={imageData.acPainDistribution.title}
                  widths={[200, 400]}
                  sizes="200px"
                  loading="lazy"
                  decoding="async"
                  class="w-full h-auto"
                />
                <figcaption class="p-2 text-xs text-slate-500 bg-slate-50 text-center">
                  <strong>Smärtutbredning:</strong> rött område visar typisk smärtlokalisation
                </figcaption>
              </figure>
            </div>
          </article>

          <!-- DIAGNOS -->
          <article id="diagnos" class="md:bg-white md:rounded-xl md:shadow-sm md:border md:border-slate-200 md:p-6 scroll-mt-6">
            <h2 class="text-xl font-bold text-slate-900 mb-4 flex items-center gap-2">
              <span class="w-8 h-8 rounded-lg bg-sky-100 text-sky-600 flex items-center justify-center text-sm">2</span>
              Diagnos och prevalens
            </h2>
            
            <div class="flex flex-col md:flex-row gap-5 mb-6">
              <div class="flex-1">
                <p class="text-slate-600 text-base leading-relaxed mb-4">
                  <strong>83% av personer över 40 år</strong> har radiologiska tecken på artros<RefLink id="5" text="MRI-fynd normala efter 40." url={references[4].url} />. Efter 70 år: nästan 100%<RefLink id="4" text="Hög prevalens med åldern." url={references[3].url} />. Trots detta är de flesta asymptomatiska.
                </p>
                <ul class="space-y-2 text-sm text-slate-600">
                  <li class="flex gap-2"><span class="text-sky-500">•</span>Åldersrelaterad degeneration</li>
                  <li class="flex gap-2"><span class="text-sky-500">•</span>Ofta asymptomatisk trots röntgenfynd</li>
                  <li class="flex gap-2"><span class="text-sky-500">•</span>Symtom vid överbelastning/trauma</li>
                  <li class="flex gap-2"><span class="text-amber-500">⚠</span>Risk för överdiagnostik</li>
                </ul>
              </div>
              <figure class="w-full md:w-48 shrink-0 rounded-lg overflow-hidden border border-slate-200">
                <Image 
                  src={acAnatomy}
                  alt={imageData.acAnatomy.alt}
                  title={imageData.acAnatomy.title}
                  widths={[200, 400]}
                  sizes="200px"
                  loading="lazy"
                  decoding="async"
                  class="w-full h-auto"
                />
                <figcaption class="p-2 text-xs text-slate-500 bg-slate-50 text-center">
                  <strong>AC-ledens anatomi:</strong> nyckelbenet möter skulderbladet
                </figcaption>
              </figure>
            </div>

            <!-- MRI-prevalens diagram -->
            <figure class="rounded-lg overflow-hidden border border-slate-200 bg-white">
              <Image 
                src={acMriPrevalence}
                alt={imageData.acMriPrevalence.alt}
                title={imageData.acMriPrevalence.title}
                widths={[400, 600, 800]}
                sizes="(max-width: 768px) 100vw, 600px"
                loading="lazy"
                decoding="async"
                class="w-full h-auto"
              />
              <figcaption class="p-3 text-xs text-slate-600 bg-slate-50 border-t border-slate-100">
                <strong>MRI-prevalens av AC-ledsartros per åldersgrupp.</strong> Redan vid 40–49 år har 75% artrosförändringar på MRI. Efter 80 år: nästan 100%.
                <br />
                <span class="text-slate-500 italic mt-1 block">
                  Källa: Patterson et al. "MRI findings of acromioclavicular joint osteoarthritis are the norm after age 40." 2023<RefLink id="5" text="Patterson et al. 2023" url={references[4].url} />
                </span>
              </figcaption>
            </figure>
          </article>

          <!-- BEHANDLING -->
          <article id="behandling" class="md:bg-white md:rounded-xl md:shadow-sm md:border md:border-slate-200 md:p-6 scroll-mt-6">
            <h2 class="text-xl font-bold text-slate-900 mb-4 flex items-center gap-2">
              <span class="w-8 h-8 rounded-lg bg-green-100 text-green-600 flex items-center justify-center text-sm">3</span>
              Behandlingsalternativ
            </h2>
            
            <p class="text-slate-600 text-base leading-relaxed mb-5">
              Konservativ behandling (avlastning, NSAID, fysioterapi, eventuellt kortison) rekommenderas i 3–6 månader<RefLink id="2" text="Konservativ behandling först." url={references[1].url} />. Systematiska översikter visar likvärdiga långsiktiga resultat som kirurgi för de flesta patienter<RefLink id="6" text="Likvärdiga resultat." url={references[5].url} /><RefLink id="1" text="Systematisk översikt." url={references[0].url} />.
            </p>

            <!-- Konservativ -->
            <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-5">
              <h3 class="font-bold text-green-800 mb-3 text-sm uppercase tracking-wide">Konservativ behandling</h3>
              <div class="grid sm:grid-cols-2 gap-3 text-sm">
                <div class="flex gap-2">
                  <span class="text-green-600 font-bold">✓</span>
                  <div><strong>Avlastning:</strong> Förstahandsval – majoriteten förbättras<RefLink id="6" text="Konservativ lika effektivt som kirurgi." url={references[5].url} /></div>
                </div>
                <div class="flex gap-2">
                  <span class="text-green-600 font-bold">✓</span>
                  <div><strong>NSAID:</strong> Vid akuta skov</div>
                </div>
                <div class="flex gap-2">
                  <span class="text-amber-500 font-bold">~</span>
                  <div><strong>Kortison:</strong> 40–60% långvarig lindring, korttidseffekt vanligare<RefLink id="27" text="Injektionsstudier." url={references[26].url} /><RefLink id="8" text="Korttidseffekt." url={references[7].url} /></div>
                </div>
                <div class="flex gap-2">
                  <span class="text-amber-500 font-bold">~</span>
                  <div><strong>Fysioterapi:</strong> Svag evidens (~20%)<RefLink id="2" text="Fysioterapi svag evidens." url={references[1].url} /></div>
                </div>
              </div>
            </div>

            <!-- Kirurgisk -->
            <div class="bg-sky-50 border border-sky-200 rounded-lg p-4">
              <h3 id="kirurgisk-behandling" class="font-bold text-sky-800 mb-3 text-sm uppercase tracking-wide scroll-mt-16">Kirurgisk behandling</h3>
              <div class="flex flex-col md:flex-row gap-4">
                <div class="flex-1 text-sm text-slate-700">
                  <p class="mb-2">
                    <strong>Distal klavikelresektion (DCR)</strong> vid ihållande symtom efter 3-6 månaders konservativ behandling<RefLink id="7" text="Kirurgi efter misslyckad konservativ." url={references[6].url} />.
                  </p>
                  <p class="mb-3 text-slate-600">
                    Flera studier stödjer en begränsad resektionslängd på <strong>4–7 mm</strong>, vilket ger god smärtlindring och funktionell förbättring utan ökad risk för instabilitet<RefLink id="16" text="Biomekanisk analys av resektionslängd." url={references[15].url} /><RefLink id="17" text="Begränsad resektion effektiv." url={references[16].url} /><RefLink id="18" text="Artroskopisk DCR vid artros." url={references[17].url} />.
                  </p>
                  <ul class="space-y-1 text-slate-600">
                    <li>• Rekommenderad resektion: <strong>~5 mm</strong> – eliminerar benkontakt (särskilt posteriort-inferiort) med bevarade ligament<RefLink id="16" text="5mm tillräckligt." url={references[15].url} /><RefLink id="19" text="Patientrapporterade utfall." url={references[18].url} /></li>
                    <li>• Signifikant förbättring i UCLA/OSS-score, hög patientnöjdhet<RefLink id="17" text="Kliniska resultat." url={references[16].url} /><RefLink id="18" text="Förbättrade funktionsscore." url={references[17].url} /></li>
                    <li>• Öppen och artroskopisk operationsteknik ger likvärdiga resultat<RefLink id="1" text="Likvärdiga resultat." url={references[0].url} /></li>
                    <li class="text-amber-700">⚠ Överresektion &gt;10mm → instabilitetsrisk<RefLink id="13" text="Risk för instabilitet." url={references[12].url} /></li>
                  </ul>
                </div>
                <figure class="w-full md:w-40 shrink-0 rounded-lg overflow-hidden border border-slate-200">
                  <Image 
                    src={acXray}
                    alt={imageData.acXray.alt}
                    title={imageData.acXray.title}
                    widths={[160, 320]}
                    sizes="160px"
                    loading="lazy"
                    decoding="async"
                    class="w-full h-auto"
                  />
                  <figcaption class="p-1 text-xs text-slate-500 bg-slate-50 text-center">
                    <strong>Röntgen:</strong> före/efter DCR-operation
                  </figcaption>
                </figure>
              </div>
            </div>
          </article>

          <!-- SJUKSKRIVNINGSTID -->
          <article id="sjukskrivning" class="md:bg-white md:rounded-xl md:shadow-sm md:border md:border-slate-200 md:p-6 scroll-mt-6">
            <h2 class="text-xl font-bold text-slate-900 mb-4 flex items-center gap-2">
              <span class="w-8 h-8 rounded-lg bg-purple-100 text-purple-600 flex items-center justify-center text-sm">4</span>
              Sjukskrivningstid efter operation
            </h2>
            
            <p class="text-slate-600 text-base leading-relaxed mb-5">
              Vid artroskopisk distal klavikelresektion (DCR) med <strong>direkt operationsteknik</strong> är återhämtningen ofta betydligt snabbare än vad litteraturen anger för indirekta metoder<RefLink id="20" text="Direkt operationsteknik ger snabbare återhämtning." url={references[19].url} /><RefLink id="21" text="Minimal vävnadsskada." url={references[20].url} />.
            </p>

            <!-- Direkt operationsteknik förklaring -->
            <div class="bg-purple-50 border border-purple-200 rounded-lg p-4 mb-5">
              <h3 class="font-bold text-purple-800 mb-2 text-sm uppercase tracking-wide">Vad är direkt operationsteknik?</h3>
              <p class="text-sm text-slate-700 leading-relaxed">
                Vid den direkta (superiora) operationstekniken går man in med artroskopet antingen framifrån eller bakifrån i AC-leden, och använder burren från motsatt håll. Operationen sker helt inuti nyckelbensleden, vilket ger ett extremt litet operationsområde och minimalt trauma mot omgivande strukturer<RefLink id="21" text="Teknisk beskrivning." url={references[20].url} /><RefLink id="22" text="Jämförelse öppen vs artroskopisk." url={references[21].url} />.
              </p>
            </div>

            <!-- Återgångstider -->
            <div class="space-y-3 mb-5">
              <div class="flex items-center gap-4 bg-green-50 border border-green-200 rounded-lg p-4">
                <div class="w-12 h-12 rounded-full bg-green-100 flex items-center justify-center shrink-0">
                  <svg class="w-6 h-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                </div>
                <div class="flex-1">
                  <h4 class="font-bold text-slate-800 text-sm">Kontorsarbete / Lätt arbete</h4>
                  <p class="text-slate-600 text-sm">Ofta <strong>ingen sjukskrivning</strong> – återgång inom dagar<RefLink id="21" text="Snabb återgång kontorsarbete." url={references[20].url} /><RefLink id="22" text="Minimal postoperativ smärta." url={references[21].url} /></p>
                </div>
                <div class="text-green-700 font-bold text-sm whitespace-nowrap">0–1 v</div>
              </div>

              <div class="flex items-center gap-4 bg-sky-50 border border-sky-200 rounded-lg p-4">
                <div class="w-12 h-12 rounded-full bg-sky-100 flex items-center justify-center shrink-0">
                  <svg class="w-6 h-6 text-sky-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                </div>
                <div class="flex-1">
                  <h4 class="font-bold text-slate-800 text-sm">Måttligt fysiskt arbete</h4>
                  <p class="text-slate-600 text-sm">Lättare manuellt arbete utan tung lyft<RefLink id="20" text="Måttligt arbete återgång." url={references[19].url} /></p>
                </div>
                <div class="text-sky-700 font-bold text-sm whitespace-nowrap">2–4 v</div>
              </div>

              <div class="flex items-center gap-4 bg-amber-50 border border-amber-200 rounded-lg p-4">
                <div class="w-12 h-12 rounded-full bg-amber-100 flex items-center justify-center shrink-0">
                  <svg class="w-6 h-6 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>
                </div>
                <div class="flex-1">
                  <h4 class="font-bold text-slate-800 text-sm">Tungt fysiskt arbete</h4>
                  <p class="text-slate-600 text-sm">Tung lyft, overhead-aktiviteter. Egna företagare återgår ofta tidigare<RefLink id="20" text="Tungt arbete återgång." url={references[19].url} /><RefLink id="23" text="Individuell variation." url={references[22].url} /></p>
                </div>
                <div class="text-amber-700 font-bold text-sm whitespace-nowrap">4–8 v</div>
              </div>
            </div>

            <!-- Jämförelse med litteraturen -->
            <div class="bg-slate-50 border border-slate-200 rounded-lg p-4">
              <h4 class="font-bold text-slate-700 text-sm mb-2 flex items-center gap-2">
                <span class="text-purple-500">📊</span> Jämfört med generella rekommendationer
              </h4>
              <p class="text-sm text-slate-600 leading-relaxed">
                Dessa tider är kortare än generella rekommendationer för kombinerade ingrepp (t.ex. DCR med subakromiell dekompression), där återgång till tungt arbete kan ta 6–12 veckor. Den direkta operationstekniken med minimalt operationsområde förklarar den snabbare återhämtningen<RefLink id="20" text="Direkt operationsteknik snabbare." url={references[19].url} /><RefLink id="21" text="Mindre vävnadstrauma." url={references[20].url} />.
              </p>
            </div>

            <!-- Dr. Carlos kommentar -->
            <blockquote class="mt-5 p-4 bg-slate-800 text-white rounded-lg border-l-4 border-sky-500">
              <div class="flex items-start gap-3">
                <div class="w-10 h-10 rounded-full overflow-hidden border-2 border-sky-400 shrink-0">
                  <img src={authorImage} alt="Dr Carlos" class="w-full h-full object-cover">
                </div>
                <div>
                  <p class="text-sm italic text-slate-200 leading-relaxed mb-2">
                    "Min erfarenhet är att sjukskrivningstider vid isolerad DCR med direkt operationsteknik är betydligt kortare än i litteraturen. Jag sjukskriver normalt sett inte efter operationen om patienten har kontorsarbete. Egna företagare med tungt arbete kan ofta återgå redan efter 2–4 veckor."
                  </p>
                  <p class="text-xs text-sky-300 font-medium">— Dr. Carlos Rivero Siri</p>
                </div>
              </div>
            </blockquote>
          </article>

          <!-- ÅTERGÅNG TILL SPORT -->
          <article id="sport" class="md:bg-white md:rounded-xl md:shadow-sm md:border md:border-slate-200 md:p-6 scroll-mt-6">
            <h2 class="text-xl font-bold text-slate-900 mb-4 flex items-center gap-2">
              <span class="w-8 h-8 rounded-lg bg-rose-100 text-rose-600 flex items-center justify-center text-sm">5</span>
              Återgång till sport (Return to Sport)
            </h2>
            
            <p class="text-slate-600 text-base leading-relaxed mb-5">
              Vid artroskopisk distal klavikulär resektion (DCR) för AC-ledsartros eller osteolys rapporteras generellt god <strong>return to sport</strong> (RTS) med hög framgångsgrad, särskilt hos idrottare<RefLink id="20" text="RTS hos idrottare." url={references[19].url} /><RefLink id="24" text="Viktlyftare RTS." url={references[23].url} /><RefLink id="23" text="Patientrapporterade utfall." url={references[22].url} />.
            </p>

            <!-- Direkt vs indirekt operationsteknik -->
            <div class="bg-rose-50 border border-rose-200 rounded-lg p-4 mb-5">
              <h3 class="font-bold text-rose-800 mb-3 text-sm uppercase tracking-wide">Direkt operationsteknik ger snabbare återgång</h3>
              <p class="text-sm text-slate-700 leading-relaxed mb-3">
                Den direkta (superiora) operationstekniken ger ofta snabbare RTS jämfört med indirekt (bursal) operationsteknik. I en prospektiv randomiserad studie på 38 idrottare återgick patienter med direkt operationsteknik till sport i genomsnitt efter <strong>21 dagar</strong>, medan indirekt operationsteknik tog <strong>42 dagar</strong>, med likvärdiga långsiktiga resultat<RefLink id="20" text="Direkt operationsteknik 21 dagar vs 42 dagar." url={references[19].url} />.
              </p>
              <div class="grid sm:grid-cols-2 gap-3">
                <div class="flex items-center gap-3 bg-white rounded-lg p-3 border border-rose-100">
                  <div class="w-10 h-10 rounded-full bg-green-100 flex items-center justify-center shrink-0">
                    <svg class="w-5 h-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                  </div>
                  <div>
                    <p class="font-bold text-slate-800 text-sm">Direkt operationsteknik</p>
                    <p class="text-green-600 font-bold text-lg">~21 dagar</p>
                  </div>
                </div>
                <div class="flex items-center gap-3 bg-white rounded-lg p-3 border border-rose-100">
                  <div class="w-10 h-10 rounded-full bg-amber-100 flex items-center justify-center shrink-0">
                    <svg class="w-5 h-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                  </div>
                  <div>
                    <p class="font-bold text-slate-800 text-sm">Indirekt operationsteknik</p>
                    <p class="text-amber-600 font-bold text-lg">~42 dagar</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Viktlyftare-studie -->
            <div class="bg-slate-50 border border-slate-200 rounded-lg p-4 mb-5">
              <h4 class="font-bold text-slate-700 text-sm mb-2 flex items-center gap-2">
                <span class="text-rose-500">🏋️</span> Extrem snabb återhämtning hos viktlyftare
              </h4>
              <p class="text-sm text-slate-600 leading-relaxed">
                En studie på viktlyftare med isolerad osteolys och direkt operationsteknik visade RTS efter i genomsnitt <strong>3,2 dagar</strong> och full träning efter <strong>9,1 dagar</strong><RefLink id="24" text="Viktlyftare 3,2 dagar RTS." url={references[23].url} />.
              </p>
            </div>

            <!-- Sammanfattning -->
            <div class="bg-green-50 border border-green-200 rounded-lg p-4">
              <h4 class="font-bold text-green-800 text-sm mb-2 flex items-center gap-2">
                <span class="text-green-600">✓</span> Evidenssammanfattning
              </h4>
              <ul class="text-sm text-slate-700 space-y-2">
                <li class="flex gap-2">
                  <span class="text-green-600 font-bold">•</span>
                  <span>Artroskopisk DCR (särskilt direkt operationsteknik) möjliggör snabbare RTS än öppen operationsteknik<RefLink id="22" text="Artroskopisk vs öppen." url={references[21].url} /></span>
                </li>
                <li class="flex gap-2">
                  <span class="text-green-600 font-bold">•</span>
                  <span>Framgångsgrad över <strong>90%</strong> för återgång till sport<RefLink id="22" text="Över 90% framgång." url={references[21].url} /><RefLink id="23" text="Hög framgångsgrad." url={references[22].url} /></span>
                </li>
                <li class="flex gap-2">
                  <span class="text-green-600 font-bold">•</span>
                  <span>Minimalt bursatrauma vid direkt operationsteknik bidrar till tidig smärtlindring och funktion</span>
                </li>
              </ul>
            </div>

            <!-- Klinisk kommentar -->
            <p class="mt-4 text-sm text-slate-600 italic bg-slate-50 p-3 rounded-lg border-l-3 border-l-rose-400">
              Dessa fynd stödjer den kliniska erfarenheten av extremt snabb återhämtning med direkt operationsteknik, där minimalt bursatrauma bidrar till tidig smärtlindring och funktion. Det är inte ovanligt att patienter kan komma igång med idrott redan inom 2–3 veckor.
            </p>
          </article>

        </main>

        <!-- HÖGER SIDEBAR - höjd matchar vänster sidebar -->
        <aside class="lg:col-span-3 order-3">
          <div class="lg:sticky lg:top-6 space-y-4 flex flex-col lg:min-h-[820px]">
            
            <!-- Innehållsförteckning - endast desktop -->
            <nav class="hidden lg:block bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
              <div class="bg-sky-700 px-4 py-2.5">
                <h3 class="font-bold text-sm text-white uppercase tracking-wide">Innehåll</h3>
              </div>
              <div class="p-2">
                {tableOfContents.map((item) => (
                  <a 
                    href={`#${item.id}`} 
                    class="flex items-center gap-2 text-sm font-medium text-slate-700 hover:text-sky-700 hover:bg-sky-50 py-1.5 px-2 rounded transition-colors"
                  >
                    <span class="w-5 h-5 rounded bg-sky-100 text-sky-700 flex items-center justify-center text-xs font-bold shrink-0">
                      {item.icon}
                    </span>
                    {item.title}
                  </a>
                ))}
              </div>
            </nav>

            <!-- Dr. Carlos rekommenderar -->
            <div class="md:bg-white md:rounded-xl md:shadow-sm md:border md:border-slate-200 md:overflow-hidden">
              <div class="bg-slate-800 text-white px-4 py-3 flex items-center gap-3">
                <div class="w-8 h-8 rounded-full overflow-hidden border-2 border-sky-400 shrink-0">
                  <img src={authorImage} alt="Dr Carlos" class="w-full h-full object-cover">
                </div>
                <div>
                  <h3 class="font-bold text-sm">Dr. Carlos säger</h3>
                </div>
              </div>
              <blockquote class="p-4 text-sm text-slate-700 italic leading-relaxed border-l-3 border-l-sky-500 ml-4 my-4">
                "Det enklaste sättet att bli kvitt smärtan är att avlasta. Gräver man i trädgården får man ont. Sitter man på kontoret försvinner smärtan."
              </blockquote>
              <div class="px-4 pb-4">
                <p class="text-sm text-slate-600">
                  Vid ihållande symtom: isolerad DCR med <strong>~5 mm</strong> resektion – tillräckligt för att eliminera benkontakt samtidigt som ligament bevaras<RefLink id="16" text="Biomekanisk analys." url={references[15].url} /><RefLink id="17" text="Kliniskt effektivt." url={references[16].url} />.
                </p>
              </div>
            </div>

            <!-- Relaterade frågor & svar -->
            {relatedQuestions.length > 0 && (
              <div class="md:bg-white md:rounded-xl md:shadow-sm md:border md:border-slate-200 md:overflow-hidden lg:mt-auto">
                <div class="bg-emerald-600 text-white px-4 py-3 flex items-center gap-2">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <h3 class="font-bold text-sm uppercase tracking-wide">Frågor & Svar</h3>
                </div>
                <div class="p-4 space-y-3">
                  <p class="text-xs text-slate-500 mb-2">Patientfrågor om AC-ledsartros:</p>
                  {relatedQuestions.map((q) => (
                    <a 
                      href={`/fraga-doktorn/${q.slug}/`}
                      class="block text-sm text-slate-700 hover:text-emerald-700 hover:bg-emerald-50 p-2 rounded-lg transition-colors border border-transparent hover:border-emerald-200"
                    >
                      <span class="font-medium line-clamp-2">{q.data.title}</span>
                    </a>
                  ))}
                  <a 
                    href="/fraga-doktorn/axel/ac-ledsartros"
                    class="flex items-center gap-1 text-xs text-emerald-600 hover:text-emerald-800 font-medium mt-2 pt-2 border-t border-slate-100"
                  >
                    Se alla AC-ledsartros frågor
                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </a>
                </div>
              </div>
            )}

          </div>
        </aside>

      </div>
    </div>
  </section>

  <!-- FAQ SEKTION - KOMPAKT -->
  <section id="faq" class="bg-white py-10 border-t border-slate-200 scroll-mt-6">
    <div class="max-w-[1500px] mx-auto px-4 sm:px-6">
      <h2 class="text-xl font-bold text-slate-900 mb-6">Vanliga frågor</h2>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        <details class="group bg-slate-50 rounded-lg cursor-pointer open:bg-sky-50 open:ring-1 open:ring-sky-200 transition-all">
          <summary class="flex justify-between items-center p-4 font-bold text-slate-800 text-sm list-none select-none">
            <span>Varför fungerar inte fysioterapi?</span>
            <span class="transition-transform group-open:rotate-180 text-slate-400 shrink-0 ml-2">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </span>
          </summary>
          <div class="px-4 pb-4 text-slate-600 text-sm leading-relaxed">
            Vid isolerad AC-ledsartros har fysioterapi begränsad evidens. Smärtan är belastningsberoende och rehab kan inte ändra degenerationen<RefLink id="2" text="Fysioterapi svag evidens." url={references[1].url} />.
          </div>
        </details>

        <details class="group bg-slate-50 rounded-lg cursor-pointer open:bg-sky-50 open:ring-1 open:ring-sky-200 transition-all">
          <summary class="flex justify-between items-center p-4 font-bold text-slate-800 text-sm list-none select-none">
            <span>Risk för komplikationer?</span>
            <span class="transition-transform group-open:rotate-180 text-slate-400 shrink-0 ml-2">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </span>
          </summary>
          <div class="px-4 pb-4 text-slate-600 text-sm leading-relaxed">
            Sällsynta (5-15%). Underresektion (10-15%) korrigeras enkelt<RefLink id="1" text="Enkel korrigering." url={references[0].url} />. Överresektion (&gt;10mm) kan ge instabilitet<RefLink id="13" text="Instabilitetsrisk." url={references[12].url} />.
          </div>
        </details>

        <details class="group bg-slate-50 rounded-lg cursor-pointer open:bg-sky-50 open:ring-1 open:ring-sky-200 transition-all">
          <summary class="flex justify-between items-center p-4 font-bold text-slate-800 text-sm list-none select-none">
            <span>Varför är resektionsstorlek viktig?</span>
            <span class="transition-transform group-open:rotate-180 text-slate-400 shrink-0 ml-2">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </span>
          </summary>
          <div class="px-4 pb-4 text-slate-600 text-sm leading-relaxed">
            Flera studier visar att 4-7mm är optimalt<RefLink id="16" text="Biomekanisk analys." url={references[15].url} /><RefLink id="17" text="Begränsad resektion." url={references[16].url} /><RefLink id="18" text="Kliniska resultat." url={references[17].url} />. ~5mm eliminerar benkontakt (särskilt posteriort-inferiort) utan att skada ligament<RefLink id="16" text="Ligamentbevarande." url={references[15].url} />. &lt;4mm = kvarstående smärta. &gt;10mm = instabilitetsrisk<RefLink id="13" text="Överresektion." url={references[12].url} />.
          </div>
        </details>

        <details class="group bg-slate-50 rounded-lg cursor-pointer open:bg-sky-50 open:ring-1 open:ring-sky-200 transition-all">
          <summary class="flex justify-between items-center p-4 font-bold text-slate-800 text-sm list-none select-none">
            <span>AC-artros + impingement?</span>
            <span class="transition-transform group-open:rotate-180 text-slate-400 shrink-0 ml-2">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </span>
          </summary>
          <div class="px-4 pb-4 text-slate-600 text-sm leading-relaxed">
            Fysioterapi kan då vara mer värdefullt för scapulär rytm. Kirurgi kan kombineras med andra axeloperationer.
          </div>
        </details>

        <details class="group bg-slate-50 rounded-lg cursor-pointer open:bg-sky-50 open:ring-1 open:ring-sky-200 transition-all md:col-span-2 lg:col-span-2">
          <summary class="flex justify-between items-center p-4 font-bold text-slate-800 text-sm list-none select-none">
            <span>Hur länge varar kortisoneffekten?</span>
            <span class="transition-transform group-open:rotate-180 text-slate-400 shrink-0 ml-2">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </span>
          </summary>
          <div class="px-4 pb-4 text-slate-600 text-sm leading-relaxed">
            Korttidslindring 1–3 månader är vanligast, men 40–60% uppnår långvarig lindring efter ett år<RefLink id="27" text="Injektionsstudier." url={references[26].url} />. Många får dock återfall vid belastning<RefLink id="8" text="Korttidseffekt." url={references[7].url} />.
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- KOMPAKT REFERENSER -->
  <section class="bg-slate-100 py-8">
    <div class="max-w-[1500px] mx-auto px-4 sm:px-6">
      <details class="group">
        <summary class="flex items-center gap-2 cursor-pointer text-slate-700 font-bold text-sm uppercase tracking-wide select-none">
          <svg class="w-4 h-4 transition-transform group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          Visa alla {references.length} referenser
        </summary>
        <div class="mt-4 grid md:grid-cols-2 lg:grid-cols-3 gap-2">
          {references.map((ref, i) => (
            <a href={ref.url} class="text-xs text-slate-600 hover:text-sky-700 hover:bg-white p-2 rounded transition block" target="_blank" rel="noopener noreferrer">
              <span class="font-bold text-slate-400 mr-1">[{i + 1}]</span>
              {ref.text}
            </a>
          ))}
        </div>
        <p class="text-xs text-slate-500 mt-4 italic">
          Alla referenser granskade för hög medicinsk tillförlitlighet. Uppdaterad {currentDate}.
        </p>
      </details>
    </div>
  </section>

  <!-- REFDRAWER -->
  <section class="bg-slate-100 pb-8">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <RefDrawer references={references} />
    </div>
  </section>

</BaseLayout>
