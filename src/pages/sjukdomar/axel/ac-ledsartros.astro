// SCHEMA.ORG - FAQPage (visas i Google-sökresultat)
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Varför fungerar inte fysioterapi vid AC-ledsartros?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Vid isolerad AC-ledsartros har fysioterapi begränsad evidens. Smärtan är belastningsberoende och rehabilitering kan inte ändra den degenerativa processen i leden. Avlastning är ofta mer effektivt."
      }
    },
    {
      "@type": "Question",
      "name": "Hur länge varar kortisoneffekten vid AC-ledsartros?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Kortisoninjektioner ger korttidslindring på 1-3 månader hos de flesta, men 40-60% uppnår långvarig lindring efter ett år enligt injektionsstudier. Många får dock återfall vid fortsatt belastning."
      }
    },
    {
      "@type": "Question",
      "name": "Vilken resektionsstorlek är optimal vid DCR-operation?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Flera studier visar att 4-7mm är optimalt. Cirka 5mm eliminerar benkontakt utan att skada ligamenten. Mindre än 4mm ger kvarstående smärta, mer än 10mm ökar risken för instabilitet."
      }
    },
    {
      "@type": "Question",
      "name": "Hur lång är sjukskrivningen efter AC-ledsoperation?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Vid isolerad DCR med direkt operationsteknik: kontorsarbete 0-1 vecka, lätt manuellt arbete 2-4 veckor, tungt arbete 4-8 veckor. Återgång till sport ofta inom 3 veckor."
      }
    },
    {
      "@type": "Question",
      "name": "Vad är weightlifter's shoulder (distal klavikulär osteolys)?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Distal klavikulär osteolys (DCO) är en överbelastningsskada som orsakar benresorption i yttersta nyckelbensänden. Vanligt hos tyngdlyftare och vid repetitiva pressrörelser. Ofta självläkande, men kirurgi kan behövas om besvären kvarstår över ett år."
      }
    }
  ]
};
