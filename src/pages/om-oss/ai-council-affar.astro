---
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "AI Council för Affärsprojekt";
const description = "Använd AI Council för investeringsbeslut, affärsplaner och komplexa projekt. Se hur en vingårdsinvestering i Toscana analyserades av fyra AI-modeller.";
---

<BaseLayout title={title} description={description}>
  <main class="min-h-screen bg-gradient-to-b from-slate-900 via-slate-800 to-slate-900">
    
    <!-- Hero Section -->
    <section class="relative py-20 overflow-hidden">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-amber-900/20 via-transparent to-transparent"></div>
      <div class="container mx-auto px-4 relative">
        <div class="text-center max-w-4xl mx-auto">
          <div class="mb-6">
            <span class="inline-flex items-center gap-2 px-4 py-2 bg-amber-500/10 border border-amber-500/30 rounded-full text-amber-300 text-sm">
              <span>🍷</span>
              Case Study: Vingårdsinvestering
            </span>
          </div>
          <h1 class="text-4xl md:text-5xl font-extrabold mb-6">
            <span class="bg-gradient-to-r from-white via-amber-200 to-orange-300 bg-clip-text text-transparent">
              AI Council för Affärsprojekt
            </span>
          </h1>
          <p class="text-xl text-slate-300 font-light mb-4">
            Fyra AI-modeller. En syntes. Bättre beslut.
          </p>
          <p class="text-slate-400 max-w-2xl mx-auto">
            Se hur AI Council hjälpte en investerare analysera ett vingårdsköp i Toscana 
            — från prisvalidering till affärsplan på under 10 minuter.
          </p>
        </div>
      </div>
    </section>

    <!-- Problem Statement -->
    <section class="py-16">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <div class="bg-gradient-to-r from-red-500/10 to-slate-800/50 border border-red-500/30 rounded-2xl p-8">
            <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
              <span class="text-3xl">😤</span>
              Problemet med vanliga AI-verktyg
            </h2>
            <div class="grid md:grid-cols-2 gap-6">
              <div class="space-y-4">
                <div class="flex items-start gap-3">
                  <span class="text-red-400 mt-1">✗</span>
                  <div>
                    <p class="text-white font-semibold">Hallucinationer</p>
                    <p class="text-slate-400 text-sm">AI:n hittar på fakta som låter trovärdiga men är fel</p>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <span class="text-red-400 mt-1">✗</span>
                  <div>
                    <p class="text-white font-semibold">Ingen second opinion</p>
                    <p class="text-slate-400 text-sm">Du vet inte om svaret är rätt eller fel</p>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <span class="text-red-400 mt-1">✗</span>
                  <div>
                    <p class="text-white font-semibold">Fragmenterad dokumentation</p>
                    <p class="text-slate-400 text-sm">Svar försvinner i chatthistorik</p>
                  </div>
                </div>
              </div>
              <div class="space-y-4">
                <div class="flex items-start gap-3">
                  <span class="text-red-400 mt-1">✗</span>
                  <div>
                    <p class="text-white font-semibold">Svårt att diktera</p>
                    <p class="text-slate-400 text-sm">Många verktyg kräver skrivande</p>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <span class="text-red-400 mt-1">✗</span>
                  <div>
                    <p class="text-white font-semibold">Inga källor</p>
                    <p class="text-slate-400 text-sm">Omöjligt att verifiera påståenden</p>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <span class="text-red-400 mt-1">✗</span>
                  <div>
                    <p class="text-white font-semibold">Fel priser och siffror</p>
                    <p class="text-slate-400 text-sm">Finansiella rekommendationer kan vara helt fel</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Solution -->
    <section class="py-16 bg-slate-800/30">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-3xl font-bold text-white text-center mb-4">
            AI Council löser detta
          </h2>
          <p class="text-slate-400 text-center mb-12 max-w-2xl mx-auto">
            Fyra oberoende AI-modeller analyserar din fråga, granskar varandras svar, 
            och en femte modell syntetiserar det bästa från alla.
          </p>
          
          <div class="grid md:grid-cols-3 gap-6">
            <div class="bg-slate-900/50 border border-emerald-500/30 rounded-xl p-6 text-center">
              <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-emerald-500/20 border-2 border-emerald-500/50 flex items-center justify-center">
                <span class="text-3xl">🔍</span>
              </div>
              <h3 class="text-white font-bold mb-2">Hallucinationsdetektion</h3>
              <p class="text-slate-400 text-sm">
                När 3 av 4 modeller flaggar samma fel = säker hallucination. 
                Du ser direkt vad som är pålitligt.
              </p>
            </div>
            
            <div class="bg-slate-900/50 border border-blue-500/30 rounded-xl p-6 text-center">
              <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-blue-500/20 border-2 border-blue-500/50 flex items-center justify-center">
                <span class="text-3xl">🎤</span>
              </div>
              <h3 class="text-white font-bold mb-2">Diktera & Transkribera</h3>
              <p class="text-slate-400 text-sm">
                Spela in ett samtal, ladda upp som kontext. 
                Perfekt för dyslektiker och de som tänker bäst när de pratar.
              </p>
            </div>
            
            <div class="bg-slate-900/50 border border-amber-500/30 rounded-xl p-6 text-center">
              <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-amber-500/20 border-2 border-amber-500/50 flex items-center justify-center">
                <span class="text-3xl">💾</span>
              </div>
              <h3 class="text-white font-bold mb-2">Spara & Exportera</h3>
              <p class="text-slate-400 text-sm">
                Ge sessioner egna namn, exportera som Markdown. 
                Skriv ut, dela, arkivera.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Case Study -->
    <section class="py-16">
      <div class="container mx-auto px-4">
        <div class="max-w-5xl mx-auto">
          <div class="text-center mb-12">
            <span class="inline-block px-3 py-1 bg-amber-500/10 border border-amber-500/30 rounded-full text-amber-400 text-sm mb-4">
              Verkligt exempel
            </span>
            <h2 class="text-3xl font-bold text-white mb-4">
              Case Study: Vingård i Toscana
            </h2>
            <p class="text-slate-400 max-w-2xl mx-auto">
              En investerare ville köpa en vingård i Italien för 30 miljoner euro. 
              Så här hjälpte AI Council med analysen.
            </p>
          </div>
          
          <!-- The conversation -->
          <div class="bg-slate-900 border border-slate-700 rounded-2xl overflow-hidden mb-8">
            <div class="flex items-center gap-2 px-4 py-3 border-b border-slate-700 bg-slate-800/50">
              <div class="w-3 h-3 rounded-full bg-red-500"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
              <div class="w-3 h-3 rounded-full bg-green-500"></div>
              <span class="ml-2 text-slate-500 text-xs font-mono">ai-council-session.md</span>
            </div>
            <div class="p-6">
              <div class="mb-6">
                <p class="text-slate-500 text-xs uppercase tracking-wide mb-2">Frågeställning</p>
                <p class="text-amber-400 font-medium">
                  "Jag vill investera upp till 30 miljoner euro i en vingård i Toscana. 
                  Vad behöver jag veta om priser, finansiering, och hur jag hittar rätt objekt?"
                </p>
              </div>
              
              <div class="mb-6">
                <p class="text-slate-500 text-xs uppercase tracking-wide mb-2">Kontext (transkriberat samtal)</p>
                <p class="text-slate-400 text-sm italic">
                  "Min bakgrund är vinprovning, UC Davis-utbildning, 15 års erfarenhet..."
                </p>
              </div>
              
              <div class="border-t border-slate-700 pt-6">
                <p class="text-slate-500 text-xs uppercase tracking-wide mb-4">AI-modellernas analys</p>
                <div class="grid md:grid-cols-4 gap-4">
                  <div class="bg-slate-800/50 rounded-lg p-3">
                    <div class="flex items-center gap-2 mb-2">
                      <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
                      <span class="text-slate-300 text-sm font-semibold">OpenAI o1</span>
                    </div>
                    <p class="text-slate-500 text-xs">Finansiell struktur, ROI-modeller</p>
                  </div>
                  <div class="bg-slate-800/50 rounded-lg p-3">
                    <div class="flex items-center gap-2 mb-2">
                      <span class="w-2 h-2 rounded-full bg-orange-500"></span>
                      <span class="text-slate-300 text-sm font-semibold">Claude</span>
                    </div>
                    <p class="text-slate-500 text-xs">Due diligence, juridik</p>
                  </div>
                  <div class="bg-slate-800/50 rounded-lg p-3">
                    <div class="flex items-center gap-2 mb-2">
                      <span class="w-2 h-2 rounded-full bg-blue-500"></span>
                      <span class="text-slate-300 text-sm font-semibold">Gemini</span>
                    </div>
                    <p class="text-slate-500 text-xs">Marknadsdata, trender</p>
                  </div>
                  <div class="bg-slate-800/50 rounded-lg p-3">
                    <div class="flex items-center gap-2 mb-2">
                      <span class="w-2 h-2 rounded-full bg-sky-500"></span>
                      <span class="text-slate-300 text-sm font-semibold">Grok 4</span>
                    </div>
                    <p class="text-slate-500 text-xs">Kontakter, praktiska tips</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Hallucination caught -->
          <div class="bg-gradient-to-r from-red-500/10 to-amber-500/10 border border-red-500/30 rounded-2xl p-6 mb-8">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-full bg-red-500/20 border-2 border-red-500 flex items-center justify-center flex-shrink-0">
                <span class="text-xl">🔍</span>
              </div>
              <div>
                <h3 class="text-red-400 font-bold text-lg mb-2">Hallucination upptäckt!</h3>
                <p class="text-slate-300 mb-4">
                  <strong>Anthropic (Claude)</strong> påstod att en vingård med 100 000 flaskors produktion 
                  kostar "2-4 miljoner euro". De andra tre modellerna flaggade detta som fel.
                </p>
                <div class="bg-slate-900/50 rounded-lg p-4">
                  <p class="text-slate-400 text-sm mb-2"><strong class="text-white">Korrigerat pris:</strong></p>
                  <p class="text-emerald-400 font-semibold">8-20 miljoner euro (validerat av 3/4 modeller)</p>
                </div>
                <p class="text-slate-500 text-xs mt-3">
                  ⚠️ Utan hallucinationsdetektion hade investeraren kunnat basera sin budget på helt fel siffror.
                </p>
              </div>
            </div>
          </div>
          
          <!-- Key findings -->
          <div class="grid md:grid-cols-2 gap-6">
            <div class="bg-slate-900/50 border border-slate-700 rounded-xl p-6">
              <h3 class="text-white font-bold mb-4 flex items-center gap-2">
                <span class="text-emerald-400">✓</span> Validerade rekommendationer
              </h3>
              <ul class="space-y-3 text-slate-400 text-sm">
                <li class="flex items-start gap-2">
                  <span class="text-emerald-400 mt-1">•</span>
                  <span><strong class="text-white">Pris:</strong> 12-18M€ för optimal vingård</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-emerald-400 mt-1">•</span>
                  <span><strong class="text-white">Mäklare:</strong> Romolini/Christie's, Sotheby's</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-emerald-400 mt-1">•</span>
                  <span><strong class="text-white">Bank:</strong> Intesa Sanpaolo (20-30% LTV)</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-emerald-400 mt-1">•</span>
                  <span><strong class="text-white">Break-even:</strong> 3-5 år med agroturism</span>
                </li>
              </ul>
            </div>
            
            <div class="bg-slate-900/50 border border-slate-700 rounded-xl p-6">
              <h3 class="text-white font-bold mb-4 flex items-center gap-2">
                <span class="text-red-400">⚠</span> Flaggade risker
              </h3>
              <ul class="space-y-3 text-slate-400 text-sm">
                <li class="flex items-start gap-2">
                  <span class="text-red-400 mt-1">•</span>
                  <span><strong class="text-white">Bank:</strong> Monte dei Paschi (ekonomiska problem)</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-red-400 mt-1">•</span>
                  <span><strong class="text-white">ROI:</strong> "300-500% på vinmässor" = överdrivet</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-red-400 mt-1">•</span>
                  <span><strong class="text-white">Klimat:</strong> Investera i bevattning dag 1</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-red-400 mt-1">•</span>
                  <span><strong class="text-white">Byråkrati:</strong> Lokala experter är ett måste</span>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="py-16 bg-slate-800/30">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-3xl font-bold text-white text-center mb-12">
            Så fungerar det
          </h2>
          
          <div class="space-y-6">
            <div class="flex items-start gap-6">
              <div class="w-12 h-12 rounded-full bg-amber-500/20 border-2 border-amber-500/50 flex items-center justify-center flex-shrink-0">
                <span class="text-amber-400 font-bold">1</span>
              </div>
              <div>
                <h3 class="text-white font-bold text-lg mb-2">Beskriv ditt projekt</h3>
                <p class="text-slate-400">
                  Skriv eller diktera din fråga. Ladda upp dokument, bilder eller transkriberade samtal som kontext.
                </p>
              </div>
            </div>
            
            <div class="flex items-start gap-6">
              <div class="w-12 h-12 rounded-full bg-amber-500/20 border-2 border-amber-500/50 flex items-center justify-center flex-shrink-0">
                <span class="text-amber-400 font-bold">2</span>
              </div>
              <div>
                <h3 class="text-white font-bold text-lg mb-2">Fyra AI-modeller analyserar</h3>
                <p class="text-slate-400">
                  OpenAI, Claude, Gemini och Grok arbetar parallellt. Varje modell ger sitt perspektiv.
                </p>
              </div>
            </div>
            
            <div class="flex items-start gap-6">
              <div class="w-12 h-12 rounded-full bg-amber-500/20 border-2 border-amber-500/50 flex items-center justify-center flex-shrink-0">
                <span class="text-amber-400 font-bold">3</span>
              </div>
              <div>
                <h3 class="text-white font-bold text-lg mb-2">Deliberation: De granskar varandra</h3>
                <p class="text-slate-400">
                  I en andra runda läser varje modell de andras svar och flaggar fel, 
                  motsägelser och osäkerheter.
                </p>
              </div>
            </div>
            
            <div class="flex items-start gap-6">
              <div class="w-12 h-12 rounded-full bg-emerald-500/20 border-2 border-emerald-500/50 flex items-center justify-center flex-shrink-0">
                <span class="text-emerald-400 font-bold">4</span>
              </div>
              <div>
                <h3 class="text-white font-bold text-lg mb-2">Supersyntes + Trovärdighetsrapport</h3>
                <p class="text-slate-400">
                  En femte modell (t.ex. Claude Opus 4.5) syntetiserar det bästa från alla. 
                  Du får en trovärdighetsrapport som visar vad som är säkert och vad som är osäkert.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Features for business -->
    <section class="py-16">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-3xl font-bold text-white text-center mb-4">
            Perfekt för affärsprojekt
          </h2>
          <p class="text-slate-400 text-center mb-12">
            Funktioner som gör AI Council till ditt bästa verktyg för komplexa beslut.
          </p>
          
          <div class="grid md:grid-cols-2 gap-6">
            <div class="bg-slate-900/50 border border-slate-700 rounded-xl p-6">
              <div class="text-3xl mb-4">🎙️</div>
              <h3 class="text-white font-bold mb-2">Transkribering & Diktering</h3>
              <p class="text-slate-400 text-sm">
                Spela in brainstorming-sessioner, möten eller tankar. 
                Ladda upp som kontext och låt AI:n strukturera.
              </p>
              <p class="text-amber-400 text-xs mt-3">Perfekt för dyslektiker och de som tänker bäst muntligt.</p>
            </div>
            
            <div class="bg-slate-900/50 border border-slate-700 rounded-xl p-6">
              <div class="text-3xl mb-4">📄</div>
              <h3 class="text-white font-bold mb-2">Dokumentuppladdning</h3>
              <p class="text-slate-400 text-sm">
                Ladda upp PDF:er, bilder, Excel-filer. 
                AI:n analyserar innehållet som del av kontexten.
              </p>
              <p class="text-amber-400 text-xs mt-3">Kontrakt, prospekt, finansiella rapporter.</p>
            </div>
            
            <div class="bg-slate-900/50 border border-slate-700 rounded-xl p-6">
              <div class="text-3xl mb-4">💾</div>
              <h3 class="text-white font-bold mb-2">Spara med eget namn</h3>
              <p class="text-slate-400 text-sm">
                Ge varje session ett beskrivande namn. 
                Hitta tillbaka till "Vingård Toscana - Due Diligence" istället för "Session 47".
              </p>
              <p class="text-amber-400 text-xs mt-3">Auto-spara tillgängligt för att aldrig förlora arbete.</p>
            </div>
            
            <div class="bg-slate-900/50 border border-slate-700 rounded-xl p-6">
              <div class="text-3xl mb-4">📥</div>
              <h3 class="text-white font-bold mb-2">Export som Markdown</h3>
              <p class="text-slate-400 text-sm">
                Ladda ned hela sessionen med metadata, alla modellsvar, 
                trovärdighetsrapport och syntes.
              </p>
              <p class="text-amber-400 text-xs mt-3">Skriv ut, dela med partners, arkivera.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing context -->
    <section class="py-16 bg-slate-800/30">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-3xl font-bold text-white text-center mb-6">
            Välj din nivå
          </h2>
          <p class="text-slate-400 text-center mb-12 max-w-2xl mx-auto">
            Börja enkelt med dokumentation. Skala upp till full analys när projektet kräver det.
          </p>
          
          <div class="grid md:grid-cols-3 gap-6 mb-12">
            <!-- Dokumentation -->
            <div class="bg-slate-900/50 border border-slate-700 rounded-xl p-6">
              <div class="text-center mb-6">
                <div class="text-3xl mb-3">📝</div>
                <h3 class="text-white font-bold text-lg">Dokumentation</h3>
                <p class="text-slate-500 text-sm">Strukturera dina tankar</p>
              </div>
              <div class="text-center mb-6">
                <div class="text-3xl font-bold text-white">50 kr</div>
                <p class="text-slate-500 text-sm">per session</p>
              </div>
              <ul class="space-y-3 text-sm mb-6">
                <li class="flex items-start gap-2">
                  <span class="text-emerald-400">✓</span>
                  <span class="text-slate-400">Diktera eller skriv</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-emerald-400">✓</span>
                  <span class="text-slate-400">Ladda upp dokument</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-emerald-400">✓</span>
                  <span class="text-slate-400">1 AI-modell (Gemini)</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-emerald-400">✓</span>
                  <span class="text-slate-400">Spara med eget namn</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-emerald-400">✓</span>
                  <span class="text-slate-400">Export som Markdown</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-slate-600">–</span>
                  <span class="text-slate-600">Ingen multi-modell</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-slate-600">–</span>
                  <span class="text-slate-600">Ingen hallucinationskontroll</span>
                </li>
              </ul>
              <p class="text-slate-500 text-xs text-center">
                Perfekt för brainstorming och anteckningar
              </p>
            </div>
            
            <!-- Analys -->
            <div class="bg-slate-900/50 border border-blue-500/30 rounded-xl p-6">
              <div class="text-center mb-6">
                <div class="text-3xl mb-3">🔍</div>
                <h3 class="text-white font-bold text-lg">Analys</h3>
                <p class="text-blue-400 text-sm">Fler perspektiv</p>
              </div>
              <div class="text-center mb-6">
                <div class="text-3xl font-bold text-blue-400">250 kr</div>
                <p class="text-slate-500 text-sm">per session</p>
              </div>
              <ul class="space-y-3 text-sm mb-6">
                <li class="flex items-start gap-2">
                  <span class="text-emerald-400">✓</span>
                  <span class="text-slate-400">Allt i Dokumentation</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-emerald-400">✓</span>
