---
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "AI Council — Elixir Edition";
const description = "AI Council Elixir Edition (Phoenix LiveView): 5-fas pipeline med Orchestrator, Claim Ledger, 8 modeller i 2 tiers, ReferenceEnricher och CitationVerifier för PMID/PMCID/DOI.";
---

<BaseLayout title={title} description={description}>
  <main class="min-h-screen bg-gradient-to-b from-slate-900 via-slate-800 to-slate-900">

    <!-- Hero Section -->
    <section class="relative py-20 overflow-hidden">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-purple-900/20 via-transparent to-transparent"></div>
      <div class="container mx-auto px-4 relative">
        <div class="text-center max-w-4xl mx-auto">
          <div class="mb-6">
            <span class="inline-flex items-center gap-2 px-4 py-2 bg-purple-500/10 border border-purple-500/30 rounded-full text-purple-300 text-sm">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
              Elixir/Phoenix LiveView
            </span>
          </div>
          <h1 class="text-5xl md:text-6xl font-extrabold mb-6">
            <span class="bg-gradient-to-r from-white via-purple-200 to-violet-300 bg-clip-text text-transparent">
              AI Council
            </span>
            <br />
            <span class="text-3xl md:text-4xl bg-gradient-to-r from-purple-400 to-indigo-400 bg-clip-text text-transparent">
              Elixir Edition
            </span>
          </h1>
          <p class="text-xl md:text-2xl text-slate-300 font-light mb-4">
            Samma koncept, ny stack
          </p>
          <p class="text-slate-400 max-w-2xl mx-auto">
            Fristående Phoenix-app (<code class="text-purple-300 text-sm">AiCouncilEx</code>) — multi-modell AI-rådgivning med automatisk syntes,
            <strong class="text-purple-400">realtids-UI via LiveView</strong> och samma typ av arkitektur som i produktion byggs i repots Dockerfile.
          </p>
          <div class="mt-5 flex flex-wrap justify-center gap-2 text-xs font-semibold uppercase tracking-wide text-slate-300">
            <span class="px-3 py-1 rounded-full border border-purple-500/30 bg-purple-500/10">Elixir</span>
            <span class="px-3 py-1 rounded-full border border-purple-500/30 bg-purple-500/10">Phoenix</span>
            <span class="px-3 py-1 rounded-full border border-purple-500/30 bg-purple-500/10">LiveView</span>
            <span class="px-3 py-1 rounded-full border border-purple-500/30 bg-purple-500/10">PostgreSQL</span>
          </div>
        </div>
      </div>
    </section>

    <!-- What is it Section -->
    <section class="py-16">
      <div class="container mx-auto px-4">
        <div class="max-w-5xl mx-auto">
          <h2 class="text-3xl font-bold text-white text-center mb-4">
            Vad är Elixir Edition?
          </h2>
          <p class="text-slate-400 text-center mb-12 max-w-3xl mx-auto">
            En komplett omskrivning av AI Council i Elixir/Phoenix. Skickar en fråga till 
            <strong class="text-purple-400">upp till 8 AI-modeller parallellt</strong>, syntetiserar svaren via 
            <strong class="text-purple-400">Claim Ledger</strong>-metodik, och kör en delibereringsomgång 
            där modellerna granskar varandra. Resultatet: en <strong class="text-white">supersyntes</strong>.
          </p>

          <div class="grid md:grid-cols-3 gap-6">
            <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-6 hover:border-purple-500/50 transition-colors">
              <div class="w-10 h-10 rounded-lg bg-purple-500/20 flex items-center justify-center mb-4">
                <svg class="w-5 h-5 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              </div>
              <h3 class="text-lg font-semibold text-white mb-2">Erlang/OTP &amp; BEAM</h3>
              <p class="text-slate-400 text-sm">
                Körs på Erlang/OTP och BEAM — samma familj av runtime som används i feltoleranta, långlivade backendsystem.
              </p>
            </div>

            <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-6 hover:border-purple-500/50 transition-colors">
              <div class="w-10 h-10 rounded-lg bg-indigo-500/20 flex items-center justify-center mb-4">
                <svg class="w-5 h-5 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
              </div>
              <h3 class="text-lg font-semibold text-white mb-2">Realtid med LiveView</h3>
              <p class="text-slate-400 text-sm">
                Varje pipelinesteg syns i UI:t omedelbart via WebSocket — med minimal klientlogik och utan tung frontend.
              </p>
            </div>

            <div class="bg-gradient-to-b from-purple-500/10 to-slate-800/50 border border-purple-500/40 rounded-xl p-6 hover:border-purple-400 transition-colors">
              <div class="w-10 h-10 rounded-lg bg-emerald-500/20 flex items-center justify-center mb-4">
                <svg class="w-5 h-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              </div>
              <h3 class="text-lg font-semibold text-white mb-2">Graceful degradation</h3>
              <p class="text-slate-400 text-sm">
                Circuit breaker, retry med backoff och fallback-modeller — pipelinen klarar API-problem.
              </p>
            </div>
          </div>

          <!-- Vetenskaplig litteratur & referenskontroll -->
          <div class="mt-8 bg-gradient-to-r from-emerald-500/10 via-teal-500/10 to-emerald-500/10 border-2 border-emerald-500/40 rounded-xl p-6">
            <div class="flex flex-col md:flex-row md:items-center gap-4">
              <div class="inline-flex items-center justify-center px-3 py-2 rounded-lg bg-emerald-500/15 border border-emerald-500/30 text-emerald-300 text-xs font-semibold uppercase tracking-wide">
                PMID / PMCID / DOI
              </div>
              <div class="flex-1">
                <h3 class="text-white font-bold text-lg mb-1">Vetenskaplig litteratur: spårbarhet och automatisk referenskontroll</h3>
                <p class="text-slate-300 text-sm mb-3">
                  För vetenskaplig skrivning är inte blind tillit det viktigaste, utan <strong class="text-emerald-400">spårbarhet</strong>. 
                  I Elixir Edition uppmanas modellerna att skriva ut maskinläsbara identifierare i referensraderna — främst 
                  <strong class="text-white">PMID</strong>, <strong class="text-white">PMCID</strong> och <strong class="text-white">DOI</strong>. När sådana identifierare finns i svaret 
                  verifieras de automatiskt efter supersyntesen via <strong class="text-emerald-400">PubMed</strong>, <strong class="text-emerald-400">PMC ID Converter</strong> respektive <strong class="text-emerald-400">Crossref</strong>.
                </p>
                <p class="text-slate-400 text-xs">
                  Efter supersyntes kör appen <strong class="text-slate-300">ReferenceEnricher</strong> (normalisering och konservativ komplettering av identifierare) och därefter <strong class="text-slate-300">CitationVerifier</strong> mot PubMed, PMC och Crossref. Zotero-listan i svaret kan byggas om utifrån det resultatet. Målet är färre felaktiga referenser och enklare manuell granskning.
                </p>
                <p class="text-slate-500 text-xs mt-2">
                  Verifieringen kontrollerar identifierare och metadata, men ersätter inte manuell bedömning av om rätt artikel verkligen stödjer rätt påstående i brödtexten.
                </p>
              </div>
              <div class="text-right">
                <span class="inline-block px-3 py-1 bg-emerald-500/20 text-emerald-300 text-xs rounded-full font-semibold">Nyckelfördel</span>
              </div>
            </div>
          </div>

          <div class="mt-6 bg-slate-900/50 border border-slate-700 rounded-xl p-6">
            <div class="flex flex-wrap items-center gap-2 mb-4">
              <span class="inline-block px-3 py-1 bg-indigo-500/10 border border-indigo-500/30 rounded-full text-indigo-300 text-xs font-semibold uppercase tracking-wide">
                Vetenskapligt arbetsflöde
              </span>
              <span class="text-slate-500 text-sm">Så är Elixir Edition tänkt att användas i litteraturtunga körningar</span>
            </div>

            <div class="grid md:grid-cols-2 gap-3 text-sm">
              <div class="rounded-lg bg-slate-800/60 border border-slate-700 p-4">
                <p class="text-white font-semibold mb-1">1. Ladda upp underlag</p>
                <p class="text-slate-400">Lägg in PDF:er, utdrag eller annat bakgrundsmaterial i kontexten innan körningen startar.</p>
              </div>
              <div class="rounded-lg bg-slate-800/60 border border-slate-700 p-4">
                <p class="text-white font-semibold mb-1">2. Kör Council med evidensfokus</p>
                <p class="text-slate-400">Använd en systemprompt som kräver referensrader med identifierare och ett tydligt, strukturerat slutsvar.</p>
              </div>
              <div class="rounded-lg bg-slate-800/60 border border-slate-700 p-4">
                <p class="text-white font-semibold mb-1">3. Granska kvalitetsstatus</p>
                <p class="text-slate-400">Titta först på den kompakta kvalitetsstatusen, sedan på panelerna för referenskomplettering och referensverifiering.</p>
              </div>
              <div class="rounded-lg bg-slate-800/60 border border-slate-700 p-4">
                <p class="text-white font-semibold mb-1">4. Exportera till Zotero</p>
                <p class="text-slate-400">Låt den ombyggda Zotero-listan ge ett renare underlag för import och fortsatt manuell granskning.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Pipeline Section -->
    <section class="py-16 bg-slate-800/30">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <div class="text-center mb-12">
            <span class="inline-block px-3 py-1 bg-purple-500/10 border border-purple-500/30 rounded-full text-purple-400 text-sm mb-4">
              Kärnan i systemet
            </span>
            <h2 class="text-3xl font-bold text-white mb-4">
              5-fas pipeline
            </h2>
            <p class="text-slate-400 max-w-xl mx-auto">
              Fem synliga steg i UI:t motsvarar <code class="text-purple-300 text-xs">Orchestrator.run/4</code> — från brief till supersyntes; därefter referenskomplettering och verifiering innan körningen markeras klar.
            </p>
          </div>

          <div class="flex flex-col items-center gap-4">

            <!-- Fas 1: Brief -->
            <div class="w-full max-w-lg bg-slate-900/50 border border-blue-500/30 rounded-xl px-6 py-4">
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-full bg-blue-500/20 border-2 border-blue-500/50 flex items-center justify-center flex-shrink-0">
                  <span class="text-blue-400 font-bold text-sm">1</span>
                </div>
                <div>
                  <h4 class="text-blue-400 font-semibold">Brief</h4>
                  <p class="text-slate-400 text-sm">Vald <strong class="text-slate-300">syntesmotor</strong> (samma inställning som för syntesfasen) tolkar frågan — standard är <strong class="text-slate-300">Gemini 3.1 Pro</strong>: tolkning, strategi, komplexitet och domänrisk. Vid byte av syntesleverantör körs brief med den modellen.</p>
                </div>
              </div>
            </div>

            <svg class="w-6 h-6 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>

            <!-- Fas 2: Runda 1 -->
            <div class="w-full max-w-lg bg-slate-900/50 border border-indigo-500/30 rounded-xl px-6 py-4">
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-full bg-indigo-500/20 border-2 border-indigo-500/50 flex items-center justify-center flex-shrink-0">
                  <span class="text-indigo-400 font-bold text-sm">2</span>
                </div>
                <div>
                  <h4 class="text-indigo-400 font-semibold">Runda 1 — Parallella modellsvar</h4>
                  <p class="text-slate-400 text-sm">Alla valda modeller svarar oberoende och parallellt via <code class="text-purple-300 text-xs">Task.async</code>.</p>
                </div>
              </div>
            </div>

            <svg class="w-6 h-6 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>

            <!-- Fas 3: Syntes -->
            <div class="w-full max-w-lg bg-slate-900/50 border border-violet-500/30 rounded-xl px-6 py-4">
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-full bg-violet-500/20 border-2 border-violet-500/50 flex items-center justify-center flex-shrink-0">
                  <span class="text-violet-400 font-bold text-sm">3</span>
                </div>
                <div>
                  <h4 class="text-violet-400 font-semibold">Syntes via Claim Ledger</h4>
                  <p class="text-slate-400 text-sm">Två API-anrop internt: extrahering till strukturerat Claim Ledger-JSON och skrivning av syntestext. Påståenden klassificeras (supported / contested / unsupported / ambiguous) med <code class="text-violet-300 text-xs">confidence_self</code> och <code class="text-violet-300 text-xs">confidence_evidence</code>.</p>
                </div>
              </div>
            </div>

            <svg class="w-6 h-6 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>

            <!-- Fas 4: Deliberering -->
            <div class="w-full max-w-lg bg-slate-900/50 border border-orange-500/30 rounded-xl px-6 py-4">
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-full bg-orange-500/20 border-2 border-orange-500/50 flex items-center justify-center flex-shrink-0">
                  <span class="text-orange-400 font-bold text-sm">4</span>
                </div>
                <div>
                  <h4 class="text-orange-400 font-semibold">Deliberering — Runda 2</h4>
                  <p class="text-slate-400 text-sm">Modellerna granskar varandras svar med tilldelade roller: Skeptiker, Domänexpert, Pedagog, Red Team.</p>
                </div>
              </div>
            </div>

            <svg class="w-6 h-6 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>

            <!-- Fas 5: Supersyntes -->
            <div class="w-full max-w-lg bg-emerald-500/10 border-2 border-emerald-500/50 rounded-xl px-6 py-4">
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-full bg-emerald-500/20 border-2 border-emerald-500 flex items-center justify-center flex-shrink-0">
                  <span class="text-emerald-400 font-bold text-sm">5</span>
                </div>
                <div>
                  <h4 class="text-emerald-400 font-semibold">Supersyntes</h4>
                  <p class="text-slate-400 text-sm">Ny extraktion + skrivning efter deliberation — uppdaterat ledger med changes-diff (added / removed / reworded / flagged). Därefter <strong class="text-slate-300">ReferenceEnricher</strong> och <strong class="text-slate-300">CitationVerifier</strong> på sluttexten.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Deliberation roles -->
          <div class="mt-12 bg-slate-900 border border-slate-700 rounded-xl overflow-hidden">
            <div class="flex items-center gap-2 px-4 py-3 border-b border-slate-700 bg-slate-800/50">
              <div class="w-3 h-3 rounded-full bg-red-500"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
              <div class="w-3 h-3 rounded-full bg-green-500"></div>
              <span class="ml-2 text-slate-500 text-xs font-mono">Prompts @deliberation_roles</span>
            </div>
            <div class="p-6">
              <h4 class="text-white font-semibold mb-4">Delibereringsroller i Runda 2</h4>
              <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                <div class="bg-emerald-500/10 border border-emerald-500/30 rounded-lg p-3 text-center">
                  <div class="w-8 h-8 rounded-full bg-emerald-500/20 flex items-center justify-center mx-auto mb-2">
                    <span class="text-emerald-400 font-bold text-xs">O</span>
                  </div>
                  <p class="text-white text-sm font-semibold">OpenAI</p>
                  <p class="text-emerald-400 text-xs">Skeptiker</p>
                </div>
                <div class="bg-orange-500/10 border border-orange-500/30 rounded-lg p-3 text-center">
                  <div class="w-8 h-8 rounded-full bg-orange-500/20 flex items-center justify-center mx-auto mb-2">
                    <span class="text-orange-400 font-bold text-xs">C</span>
                  </div>
                  <p class="text-white text-sm font-semibold">Anthropic</p>
                  <p class="text-orange-400 text-xs">Domänexpert</p>
                </div>
                <div class="bg-blue-500/10 border border-blue-500/30 rounded-lg p-3 text-center">
                  <div class="w-8 h-8 rounded-full bg-blue-500/20 flex items-center justify-center mx-auto mb-2">
                    <span class="text-blue-400 font-bold text-xs">G</span>
                  </div>
                  <p class="text-white text-sm font-semibold">Gemini</p>
                  <p class="text-blue-400 text-xs">Pedagog</p>
                </div>
                <div class="bg-purple-500/10 border border-purple-500/30 rounded-lg p-3 text-center">
                  <div class="w-8 h-8 rounded-full bg-purple-500/20 flex items-center justify-center mx-auto mb-2">
                    <span class="text-purple-400 font-bold text-xs">X</span>
                  </div>
                  <p class="text-white text-sm font-semibold">Grok</p>
                  <p class="text-purple-400 text-xs">Red Team</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Models Section -->
    <section class="py-16">
      <div class="container mx-auto px-4">
        <div class="max-w-5xl mx-auto">
          <h2 class="text-3xl font-bold text-white text-center mb-4">
            8 modeller i 2 tiers
          </h2>
          <p class="text-slate-400 text-center mb-12 max-w-2xl mx-auto">
            Växla mellan <strong class="text-purple-400">Snabb</strong> (2 modeller) och 
            <strong class="text-purple-400">Avancerad</strong> (3 standard + 3 tillval, djupare analys) med ett klick.
          </p>

          <!-- Fast Tier -->
          <div class="mb-8">
            <div class="flex items-center gap-3 mb-4">
              <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-emerald-500/10 border border-emerald-500/30 rounded-full text-emerald-400 text-sm font-semibold">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
                Snabb tier
              </span>
              <span class="text-slate-500 text-sm">2 modeller</span>
            </div>
            <div class="grid md:grid-cols-2 gap-4">
              <div class="bg-slate-900/50 border border-slate-700 rounded-xl p-5 flex gap-4">
                <div class="w-12 h-12 rounded-lg bg-blue-500/20 flex items-center justify-center flex-shrink-0">
                  <span class="text-blue-400 text-xl font-bold">G</span>
                </div>
                <div>
                  <h4 class="text-lg font-semibold text-white">Gemini 3.1 Flash-Lite</h4>
                  <p class="text-slate-500 text-sm">Google</p>
                  <p class="text-slate-400 text-sm mt-1">Snabb, kostnadseffektiv modell för fast tier (hög volym, korta svar)</p>
                </div>
              </div>
              <div class="bg-slate-900/50 border border-slate-700 rounded-xl p-5 flex gap-4">
                <div class="w-12 h-12 rounded-lg bg-orange-500/20 flex items-center justify-center flex-shrink-0">
                  <span class="text-orange-400 text-xl font-bold">C</span>
                </div>
                <div>
                  <h4 class="text-lg font-semibold text-white">Claude Haiku 4.5</h4>
                  <p class="text-slate-500 text-sm">Anthropic</p>
                  <p class="text-slate-400 text-sm mt-1">Kompakt och snabb med hög precision</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Advanced Tier -->
          <div>
            <div class="flex items-center gap-3 mb-4">
              <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-violet-500/10 border border-violet-500/30 rounded-full text-violet-400 text-sm font-semibold">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
                </svg>
                Avancerad tier
              </span>
              <span class="text-slate-500 text-sm">3 standard + 3 opt-in</span>
            </div>
            <div class="grid md:grid-cols-2 gap-4">
              <div class="bg-slate-900/50 border border-slate-700 rounded-xl p-5 flex gap-4">
                <div class="w-12 h-12 rounded-lg bg-emerald-500/20 flex items-center justify-center flex-shrink-0">
                  <span class="text-emerald-400 text-xl font-bold">O</span>
                </div>
                <div>
                  <h4 class="text-lg font-semibold text-white">GPT-5.4</h4>
                  <p class="text-slate-500 text-sm">OpenAI</p>
