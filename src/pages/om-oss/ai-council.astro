              </div>
            </div>
            
            <div class="bg-slate-900/50 border border-slate-700 rounded-xl p-6 flex gap-4">
              <div class="w-12 h-12 rounded-lg bg-sky-500/20 flex items-center justify-center flex-shrink-0">
                <span class="text-sky-400 text-xl font-bold">X</span>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-white">Grok 4</h3>
                <p class="text-slate-500 text-sm">xAI вҖў 2M tokens kontext</p>
                <p class="text-slate-400 text-sm mt-2">Г–verlГӨgsen fГ¶r vetenskaplig litteratursyntes och evidensgranskning</p>
              </div>
            </div>
          </div>
        </div>
      </div>
