                  <p class="text-slate-500 text-xs">Vetenskap</p>
                </div>
              </div>
              <p class="text-slate-400 text-sm">Stark pГҘ referenshantering och vetenskaplig litteratur.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Architecture Section -->
    <section class="py-16 bg-slate-800/30">
      <div class="container mx-auto px-4">
