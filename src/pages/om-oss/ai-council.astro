                <span class="text-emerald-400 text-xl font-bold">O</span>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-white">GPT-5.2</h3>
                <p class="text-slate-500 text-sm">OpenAI</p>
                <p class="text-slate-400 text-sm mt-2">Djup resonering & steg-fГ¶r-steg logik</p>
              </div>
            </div>
            
            <div class="bg-slate-900/50 border border-slate-700 rounded-xl p-6 flex gap-4">
              <div class="w-12 h-12 rounded-lg bg-orange-500/20 flex items-center justify-center flex-shrink-0">
                <span class="text-orange-400 text-xl font-bold">C</span>
