            <div class="flex flex-col md:flex-row md:items-center gap-4">
              <div class="text-4xl">рҹ”Қ</div>
              <div class="flex-1">
                <div class="flex items-center gap-2 mb-1">
                  <h3 class="text-white font-bold text-lg">Hybrid-sГ¶kning & kГӨllverifiering</h3>
                  <span class="text-xs bg-emerald-500/20 text-emerald-300 px-2 py-0.5 rounded-full">NY!</span>
                </div>
                <p class="text-slate-300 text-sm">
                  SГ¶k verifierade kГӨllor i <strong class="text-emerald-400">PubMed</strong>, <strong class="text-emerald-400">Scholar</strong>, 
                  <strong class="text-emerald-400">Google</strong> och <strong class="text-emerald-400">Nyheter</strong> вҖ” med 
                  <strong class="text-white">trovГӨrdighetspoГӨng</strong> och samma underlag till alla AI-modeller.
                </p>
              </div>
              <div class="text-right">
                <span class="inline-block px-3 py-1 bg-emerald-500/30 text-emerald-300 text-xs rounded-full font-semibold">v3.9</span>
              </div>
            </div>
