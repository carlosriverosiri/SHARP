---
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "AI Council - Internt AI-verktyg";
const description = "AI Council är vårt interna verktyg för att konsultera flera AI-modeller samtidigt och få syntetiserade rekommendationer för komplexa beslut.";
---

<BaseLayout title={title} description={description}>
  <main class="min-h-screen bg-gradient-to-b from-slate-900 via-slate-800 to-slate-900">
    
    <!-- Hero Section -->
    <section class="relative py-20 overflow-hidden">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-indigo-900/20 via-transparent to-transparent"></div>
      <div class="container mx-auto px-4 relative">
        <div class="text-center max-w-4xl mx-auto">
          <div class="mb-6">
            <span class="inline-flex items-center gap-2 px-4 py-2 bg-indigo-500/10 border border-indigo-500/30 rounded-full text-indigo-300 text-sm">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
              </svg>
              Internt forskningsverktyg
            </span>
          </div>
          <h1 class="text-5xl md:text-6xl font-extrabold mb-6">
            <span class="bg-gradient-to-r from-white via-indigo-200 to-violet-300 bg-clip-text text-transparent">
              AI Council
            </span>
          </h1>
          <p class="text-xl md:text-2xl text-slate-300 font-light mb-4">
            Master Mind Tool <span class="text-sm text-slate-500">v3.10</span>
          </p>
          <p class="text-slate-400 max-w-2xl mx-auto">
            Multi-modell AI-rådgivning med automatisk syntes för komplexa tekniska och vetenskapliga frågor — 
            <span class="text-emerald-400">nu med hybrid-sökning för verifierade källor</span>
          </p>
          <div class="mt-5 flex flex-wrap justify-center gap-2 text-xs font-semibold uppercase tracking-wide text-slate-300">
            <span class="px-3 py-1 rounded-full border border-indigo-500/30 bg-indigo-500/10">Project</span>
            <span class="px-3 py-1 rounded-full border border-indigo-500/30 bg-indigo-500/10">Context</span>
            <span class="px-3 py-1 rounded-full border border-indigo-500/30 bg-indigo-500/10">Prompt</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Section -->
    <section class="py-16">
      <div class="container mx-auto px-4">
        <div class="max-w-5xl mx-auto">
          <h2 class="text-3xl font-bold text-white text-center mb-4">
            Varför AI Council?
          </h2>
          <p class="text-slate-400 text-center mb-12 max-w-2xl mx-auto">
            Ett internt verktyg för att få <span class="text-indigo-400 font-semibold">konsensus</span> från världens ledande AI-modeller i en och samma körning.
          </p>
          
          <div class="grid md:grid-cols-3 gap-6">
            <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-6 hover:border-indigo-500/50 transition-colors">
              <div class="text-3xl mb-4">🔍</div>
              <h3 class="text-lg font-semibold text-white mb-2">Arkitekturbeslut</h3>
              <p class="text-slate-400 text-sm">
                Validera tekniska beslut mot flera AI-experter innan implementation.
              </p>
            </div>
            
            <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-6 hover:border-indigo-500/50 transition-colors">
              <div class="text-3xl mb-4">📝</div>
              <h3 class="text-lg font-semibold text-white mb-2">Kodgranskning</h3>
              <p class="text-slate-400 text-sm">
                Få optimeringstips från olika perspektiv: säkerhet, prestanda, läsbarhet.
              </p>
            </div>
            
            <div class="bg-gradient-to-b from-indigo-500/10 to-slate-800/50 border border-indigo-500/40 rounded-xl p-6 hover:border-indigo-400 transition-colors">
              <div class="text-3xl mb-4">📚</div>
              <h3 class="text-lg font-semibold text-white mb-2">Vetenskaplig forskning</h3>
              <p class="text-slate-400 text-sm">
                <strong class="text-indigo-300">Inbyggd referenshantering</strong> med inline-citat, DOI-länkar och Zotero-import.
              </p>
            </div>
          </div>
          
          <!-- Highlight box for reference handling -->
          <div class="mt-8 bg-gradient-to-r from-indigo-500/10 via-violet-500/10 to-indigo-500/10 border border-indigo-500/30 rounded-xl p-6">
            <div class="flex flex-col md:flex-row md:items-center gap-4">
              <div class="text-4xl">📖</div>
              <div class="flex-1">
                <h3 class="text-white font-bold text-lg mb-1">Vetenskapligt anpassad med enkel referenshantering</h3>
                <p class="text-slate-300 text-sm">
                  Välj <span class="text-indigo-400 font-semibold">🔬 Vetenskap</span>-profilen och få automatiskt 
                  <strong class="text-white">inline-referenser [1], [2]</strong>, 
                  <strong class="text-white">klickbara DOI/PubMed-länkar</strong> och en 
                  <strong class="text-white">Zotero Bulk Import-lista</strong> som du kopierar direkt in i ditt referenshanteringsprogram.
                </p>
              </div>
              <div class="text-right">
                <span class="inline-block px-3 py-1 bg-indigo-500/20 text-indigo-300 text-xs rounded-full">Nyckelfunktion</span>
              </div>
            </div>
          </div>
          
          <!-- Hybrid search highlight - NEW! -->
          <div class="mt-4 bg-gradient-to-r from-emerald-500/10 via-teal-500/10 to-emerald-500/10 border-2 border-emerald-500/40 rounded-xl p-6">
            <div class="flex flex-col md:flex-row md:items-center gap-4">
              <div class="text-4xl">🔍</div>
              <div class="flex-1">
                <div class="flex items-center gap-2 mb-1">
                  <h3 class="text-white font-bold text-lg">Hybrid-sökning & källverifiering</h3>
                  <span class="text-xs bg-emerald-500/20 text-emerald-300 px-2 py-0.5 rounded-full">NY!</span>
                </div>
                <p class="text-slate-300 text-sm">
                  Sök verifierade källor i <strong class="text-emerald-400">PubMed</strong>, <strong class="text-emerald-400">Scholar</strong>, 
                  <strong class="text-emerald-400">Google</strong> och <strong class="text-emerald-400">Nyheter</strong> — med 
                  <strong class="text-white">trovärdighetspoäng</strong> och samma underlag till alla AI-modeller.
                </p>
              </div>
              <div class="text-right">
                <span class="inline-block px-3 py-1 bg-emerald-500/30 text-emerald-300 text-xs rounded-full font-semibold">v3.9</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Models Section -->
    <section class="py-16 bg-slate-800/30">
      <div class="container mx-auto px-4">
        <div class="max-w-5xl mx-auto">
          <h2 class="text-3xl font-bold text-white text-center mb-12">
            Rådsmedlemmarna
          </h2>
          
          <div class="grid md:grid-cols-2 gap-4">
            <div class="bg-slate-900/50 border border-slate-700 rounded-xl p-6 flex gap-4">
              <div class="w-12 h-12 rounded-lg bg-emerald-500/20 flex items-center justify-center flex-shrink-0">
                <span class="text-emerald-400 text-xl font-bold">O</span>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-white">GPT-5.2</h3>
                <p class="text-slate-500 text-sm">OpenAI</p>
                <p class="text-slate-400 text-sm mt-2">Djup resonering & steg-för-steg logik</p>
              </div>
            </div>
            
            <div class="bg-slate-900/50 border border-slate-700 rounded-xl p-6 flex gap-4">
              <div class="w-12 h-12 rounded-lg bg-orange-500/20 flex items-center justify-center flex-shrink-0">
                <span class="text-orange-400 text-xl font-bold">C</span>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-white">Claude Sonnet</h3>
                <p class="text-slate-500 text-sm">Anthropic</p>
                <p class="text-slate-400 text-sm mt-2">Kodstruktur & tydlig syntes</p>
              </div>
            </div>
            
            <div class="bg-slate-900/50 border border-slate-700 rounded-xl p-6 flex gap-4">
              <div class="w-12 h-12 rounded-lg bg-blue-500/20 flex items-center justify-center flex-shrink-0">
                <span class="text-blue-400 text-xl font-bold">G</span>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-white">Gemini 2.0 Flash</h3>
                <p class="text-slate-500 text-sm">Google</p>
                <p class="text-slate-400 text-sm mt-2">Snabb, prisvärd & multimodal</p>
              </div>
            </div>
            
            <div class="bg-slate-900/50 border border-slate-700 rounded-xl p-6 flex gap-4">
              <div class="w-12 h-12 rounded-lg bg-sky-500/20 flex items-center justify-center flex-shrink-0">
                <span class="text-sky-400 text-xl font-bold">X</span>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-white">Grok 4</h3>
                <p class="text-slate-500 text-sm">xAI • 2M tokens kontext</p>
                <p class="text-slate-400 text-sm mt-2">Överlägsen för vetenskaplig litteratursyntes och evidensgranskning</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Synthesis Models Section -->
    <section class="py-16">
      <div class="container mx-auto px-4">
        <div class="max-w-5xl mx-auto">
          <h2 class="text-3xl font-bold text-white text-center mb-4">
            Syntesmodeller ("Domaren")
          </h2>
          <p class="text-slate-400 text-center mb-12 max-w-2xl mx-auto">
            Välj vilken AI som ska analysera alla svar och ge slutgiltig rekommendation.
          </p>
          
          <div class="grid md:grid-cols-3 gap-4">
            <div class="bg-gradient-to-b from-amber-500/10 to-slate-800/50 border border-amber-500/30 rounded-xl p-5">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-2xl">👑</span>
                <div>
                  <h4 class="text-white font-semibold">Claude Opus 4.5</h4>
                  <p class="text-amber-400 text-xs">Premium</p>
                </div>
              </div>
              <p class="text-slate-400 text-sm">Anthropics bästa modell. Djupast möjliga analys för kritiska beslut.</p>
            </div>
            
            <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-5">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-2xl">🔧</span>
                <div>
                  <h4 class="text-white font-semibold">Claude Sonnet</h4>
                  <p class="text-slate-500 text-xs">Standard</p>
                </div>
              </div>
              <p class="text-slate-400 text-sm">Balanserad - perfekt för kod och tekniska frågor.</p>
            </div>
            
            <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-5">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-2xl">🧪</span>
                <div>
                  <h4 class="text-white font-semibold">GPT-5.2</h4>
                  <p class="text-slate-500 text-xs">Resonering</p>
                </div>
              </div>
              <p class="text-slate-400 text-sm">Step-by-step logik för komplexa vetenskapliga frågor.</p>
            </div>
            
            <div class="bg-gradient-to-b from-emerald-500/10 to-slate-800/50 border border-emerald-500/30 rounded-xl p-5">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-2xl">💎</span>
                <div>
                  <h4 class="text-white font-semibold">GPT-5.2 Pro</h4>
                  <p class="text-emerald-400 text-xs">Premium</p>
                </div>
              </div>
              <p class="text-slate-400 text-sm">OpenAIs kraftfullaste modell.</p>
            </div>
            
            <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-5">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-2xl">⚡</span>
                <div>
                  <h4 class="text-white font-semibold">GPT-4o</h4>
                  <p class="text-slate-500 text-xs">Snabb</p>
                </div>
              </div>
              <p class="text-slate-400 text-sm">Hög kvalitet, snabb respons. Bra för iteration.</p>
            </div>
            
            <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-5">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-2xl">📚</span>
                <div>
                  <h4 class="text-white font-semibold">Gemini 2.0 Flash</h4>
                  <p class="text-slate-500 text-xs">Kontext</p>
                </div>
              </div>
              <p class="text-slate-400 text-sm">Bäst för stora dokument och långa kodbaser.</p>
            </div>
            
            <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-5">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-2xl">🌐</span>
                <div>
                  <h4 class="text-white font-semibold">Grok 4</h4>
                  <p class="text-slate-500 text-xs">Vetenskap</p>
                </div>
              </div>
              <p class="text-slate-400 text-sm">Stark på referenshantering och vetenskaplig litteratur.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Architecture Section -->
    <section class="py-16 bg-slate-800/30">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-3xl font-bold text-white text-center mb-12">
            Systemarkitektur
          </h2>
          
          <div class="bg-slate-900 border border-slate-700 rounded-xl overflow-hidden">
            <div class="flex items-center gap-2 px-4 py-3 border-b border-slate-700 bg-slate-800/50">
              <div class="w-3 h-3 rounded-full bg-red-500"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
              <div class="w-3 h-3 rounded-full bg-green-500"></div>
              <span class="ml-2 text-slate-500 text-xs font-mono">architecture.diagram</span>
            </div>
            <pre class="p-6 text-xs text-slate-300 font-mono overflow-x-auto"><code>┌─────────────────────────────────────────────────────────────────────────┐
│                          FRONTEND v3.0 (Astro)                            │
│  ┌─────────────────┬────────────────────────────────────────────────┐    │
│  │ 📁 PROJEKTSIDEBAR│              HUVUDOMRÅDE                       │    │
│  │                 │   [Prompt + Kontext + Profilval]                │    │
│  │ + Nytt projekt  │                    │                            │    │
│  │ 📂 Historik     │                    ▼                            │    │
│  └─────────────────┴────────────────────────────────────────────────┘    │
├─────────────────────────────────────────────────────────────────────────┤
│                         AI COUNCIL API                                    │
│    ┌────────┐ ┌────────┐ ┌────────┐ ┌────────┐                           │
│    │OpenAI  │ │ Claude │ │ Gemini │ │ Grok 4 │   ← Parallell             │
│    │ GPT5.2 │ │ Sonnet │ │ 2.0    │ │  Fast  │     körning               │
│    └────┬───┘ └────┬───┘ └────┬───┘ └────┬───┘                           │
│         └──────────┴──────────┴──────────┘                               │
│                             ▼                                            │
│              ┌────────────────────────────┐                              │
│              │    SYNTES ("Domaren")      │                              │
│              │   7 valbara modeller       │                              │
│              └────────────────────────────┘                              │
├─────────────────────────────────────────────────────────────────────────┤
│                      SUPABASE (Datalagring)                               │
│   [ai_council_projects] ◄─ [ai_council_sessions] ◄─ [ai_profiles]        │
└─────────────────────────────────────────────────────────────────────────┘</code></pre>
          </div>
        </div>
      </div>
    </section>

    <!-- Deliberation Section -->
    <section class="py-16 bg-gradient-to-b from-slate-800/30 to-transparent">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <div class="text-center mb-12">
            <span class="inline-block px-3 py-1 bg-orange-500/10 border border-orange-500/30 rounded-full text-orange-400 text-sm mb-4">
              Avancerad funktion
            </span>
            <h2 class="text-3xl font-bold text-white mb-4">
              Riktad Deliberation
            </h2>
            <p class="text-slate-400 max-w-xl mx-auto">
              Runda 2: AI-modellerna utför <strong class="text-orange-400">strukturerad konfliktanalys</strong> och kategoriserar problem efter typ.
            </p>
          </div>
          
          <div class="flex flex-col items-center gap-4">
            <div class="bg-indigo-500/10 border border-indigo-500/30 rounded-xl px-8 py-4 text-indigo-300">
              <span class="font-semibold">Runda 1:</span> Alla modeller svarar individuellt
            </div>
            
            <svg class="w-6 h-6 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
            
            <div class="bg-orange-500/10 border border-orange-500/30 rounded-xl px-8 py-4 text-orange-300">
              <span class="font-semibold text-orange-400">Runda 2 - Konfliktanalys:</span>
              <div class="grid grid-cols-2 gap-2 mt-2 text-xs">
                <span class="bg-red-500/20 px-2 py-1 rounded">MOTSÄGELSE</span>
                <span class="bg-amber-500/20 px-2 py-1 rounded">UNIK_INSIKT</span>
                <span class="bg-slate-500/20 px-2 py-1 rounded">UTAN_KÄLLA</span>
                <span class="bg-purple-500/20 px-2 py-1 rounded">HALLUCINATION</span>
              </div>
            </div>
            
            <svg class="w-6 h-6 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
            
            <div class="bg-emerald-500/10 border-2 border-emerald-500/50 rounded-xl px-8 py-4 text-center">
              <div class="text-emerald-400 font-bold mb-1">SUPERSYNTES</div>
              <div class="text-slate-400 text-xs">med konsensusanalys + lösta/olösta konflikter</div>
            </div>
          </div>
          
          <!-- New: Consensus analysis box -->
          <div class="mt-8 bg-slate-900 border border-slate-700 rounded-xl overflow-hidden">
            <div class="flex items-center gap-2 px-4 py-3 border-b border-slate-700 bg-slate-800/50">
              <div class="w-3 h-3 rounded-full bg-red-500"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
              <div class="w-3 h-3 rounded-full bg-green-500"></div>
              <span class="ml-2 text-slate-500 text-xs font-mono">konsensusanalys.exempel</span>
            </div>
            <pre class="p-4 text-xs text-slate-300 font-mono overflow-x-auto"><code>📊 KONSENSUSANALYS (efter riktad faktagranskning)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Överensstämmelse: HÖG - 3/4 modeller överens

🔍 Identifierade konflikter i Runda 2:
• MOTSÄGELSER: 1 st
• UNIKA INSIKTER (hallucinationsrisk): 2 st  

🔄 Lösta konflikter:
• Prissättning → 8-20M€ (säkerhet: HÖG)

⚠️ OLÖSTA konflikter:
• ROI-uppskattning varierar kraftigt

✅ Slutgiltig konsensus:
• Använd lokala mäklare
• Investera i bevattning dag 1

❌ Förkastade påståenden:
• Claude: "2-4M€ för 100k flaskor" - FELAKTIGT
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━</code></pre>
          </div>
          
          <div class="mt-8 grid md:grid-cols-2 gap-6">
            <div class="bg-emerald-500/5 border border-emerald-500/20 rounded-xl p-6">
              <h4 class="text-emerald-400 font-semibold mb-3">✅ Fördelar</h4>
              <ul class="text-slate-400 text-sm space-y-2">
                <li>• <strong class="text-white">Kategoriserade konflikter</strong> - vet exakt vad som är osäkert</li>
                <li>• <strong class="text-white">Lösta vs olösta</strong> - tydlig uppföljning</li>
                <li>• Hallucinationer upptäcks och förkastas explicit</li>
                <li>• Bra för vetenskaplig litteratur</li>
              </ul>
            </div>
            <div class="bg-red-500/5 border border-red-500/20 rounded-xl p-6">
              <h4 class="text-red-400 font-semibold mb-3">⚠️ Nackdelar</h4>
              <ul class="text-slate-400 text-sm space-y-2">
                <li>• Tar 2-3x längre tid</li>
                <li>• Dubbla API-kostnader</li>
                <li>• Kräver minst 2 modeller</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Hallucination Detection Section -->
    <section class="py-16">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <div class="text-center mb-12">
            <span class="inline-block px-3 py-1 bg-red-500/10 border border-red-500/30 rounded-full text-red-400 text-sm mb-4">
              Nyckelfunktion
            </span>
            <h2 class="text-3xl font-bold text-white mb-4">
              Hallucinationsdetektion
            </h2>
            <p class="text-slate-400 max-w-xl mx-auto">
              AI Council upptäcker automatiskt när AI-modellerna motsäger varandra och flaggar potentiella felaktigheter.
            </p>
